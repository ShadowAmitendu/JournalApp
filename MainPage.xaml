<?xml version="1.0" encoding="utf-8" ?>
<Page
    x:Class="JournalApp.MainPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:local="using:JournalApp"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    mc:Ignorable="d"
    NavigationCacheMode="Enabled"
    KeyDown="Page_KeyDown">

    <Page.Resources>
        <ThemeShadow x:Key="SharedShadow" />
        <local:BoolToVisibilityConverter x:Key="BoolToVisibilityConverter" />
        <local:BoolToVisibilityInverseConverter x:Key="BoolToVisibilityInverseConverter" />
        <local:StringToVisibilityConverter x:Key="StringToVisibilityConverter" />
        <local:ImagePathConverter x:Key="ImagePathConverter" />
        <local:HexToBrushConverter x:Key="HexToBrushConverter" />
        
        <!-- Notes List Item Grouping Source -->
        <CollectionViewSource x:Key="NotesCVS" x:Name="NotesCVS" IsSourceGrouped="True"/>

        <!-- Notes List Item Context Menu -->
        <MenuFlyout x:Key="NotesListContextFlyout" x:Name="NotesListContextFlyout" Opening="NotesListContextFlyout_Opening">
            <MenuFlyoutItem x:Name="ContextMenuDelete" Text="Move to Trash" Click="DeleteNoteButton_Click">
                <MenuFlyoutItem.Icon>
                    <FontIcon Glyph="&#xE74D;" FontFamily="{ThemeResource SymbolThemeFontFamily}" />
                </MenuFlyoutItem.Icon>
            </MenuFlyoutItem>
            
            <MenuFlyoutSubItem x:Name="ContextMenuMoveToCategorySubItem" Text="Move to Category">
                <MenuFlyoutSubItem.Icon>
                    <FontIcon Glyph="&#xE8DE;" FontFamily="{ThemeResource SymbolThemeFontFamily}" />
                </MenuFlyoutSubItem.Icon>
            </MenuFlyoutSubItem>
            
            <MenuFlyoutSeparator />
            
            <MenuFlyoutSubItem Text="Export &amp; Print">
                <MenuFlyoutSubItem.Icon>
                    <FontIcon Glyph="&#xEDE1;" FontFamily="{ThemeResource SymbolThemeFontFamily}" />
                </MenuFlyoutSubItem.Icon>
                <MenuFlyoutItem Text="Export as HTML..." Click="ContextMenuExportHtml_Click">
                    <MenuFlyoutItem.Icon>
                        <FontIcon Glyph="&#xE943;" FontFamily="{ThemeResource SymbolThemeFontFamily}" />
                    </MenuFlyoutItem.Icon>
                </MenuFlyoutItem>
                <MenuFlyoutItem Text="Export as Markdown (.md)..." Click="ContextMenuExportMarkdown_Click">
                    <MenuFlyoutItem.Icon>
                        <FontIcon Glyph="&#xE70F;" FontFamily="{ThemeResource SymbolThemeFontFamily}" />
                    </MenuFlyoutItem.Icon>
                </MenuFlyoutItem>
                <MenuFlyoutItem Text="Print or Save as PDF..." Click="ContextMenuPrint_Click">
                    <MenuFlyoutItem.Icon>
                        <FontIcon Glyph="&#xE749;" FontFamily="{ThemeResource SymbolThemeFontFamily}" />
                    </MenuFlyoutItem.Icon>
                </MenuFlyoutItem>
            </MenuFlyoutSubItem>
            
            <MenuFlyoutSeparator />
            
            <MenuFlyoutItem Text="Add Unsplash Cover..." Click="SearchUnsplashHeroImage_Click">
                <MenuFlyoutItem.Icon>
                    <FontIcon Glyph="&#xEB9F;" FontFamily="{ThemeResource SymbolThemeFontFamily}" />
                </MenuFlyoutItem.Icon>
            </MenuFlyoutItem>
        </MenuFlyout>
    </Page.Resources>

    <Grid>
        <!-- NavigationView replacing manual Sidebar Grid -->
        <NavigationView x:Name="CategoriesNavView"
                        PaneDisplayMode="Left"
                        IsSettingsVisible="False"
                        IsBackButtonVisible="Collapsed"
                        IsPaneToggleButtonVisible="True"
                        OpenPaneLength="240"
                        SelectionChanged="CategoriesNavView_SelectionChanged"
                        Background="Transparent">

            <NavigationView.PaneHeader>
                <Grid Padding="16,8" VerticalAlignment="Center">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="Auto" />
                    </Grid.RowDefinitions>
                    <TextBlock Text="Categories" FontWeight="SemiBold" FontSize="15" VerticalAlignment="Center" />
                    <TextBlock x:Name="StreakBadgeText" Grid.Row="1" Text="" FontSize="11"
                               Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                               Visibility="Collapsed" Margin="0,2,0,0" />
                </Grid>
            </NavigationView.PaneHeader>



            <NavigationView.FooterMenuItems>
                <NavigationViewItem x:Name="FavoritesNavItem" Content="Favorites" ToolTipService.ToolTip="Favorites">
                    <NavigationViewItem.Icon>
                        <FontIcon Glyph="&#xE734;" FontFamily="{ThemeResource SymbolThemeFontFamily}" />
                    </NavigationViewItem.Icon>
                </NavigationViewItem>
                <NavigationViewItem x:Name="TrashNavItem" Content="Trash" ToolTipService.ToolTip="Trash">
                    <NavigationViewItem.Icon>
                        <FontIcon Glyph="&#xE74D;" FontFamily="{ThemeResource SymbolThemeFontFamily}" />
                    </NavigationViewItem.Icon>
                    <NavigationViewItem.InfoBadge>
                        <InfoBadge x:Name="TrashInfoBadge" Value="0" Visibility="Collapsed" />
                    </NavigationViewItem.InfoBadge>
                </NavigationViewItem>
                <NavigationViewItem x:Name="GitHubNavItem" Content="GitHub History" ToolTipService.ToolTip="GitHub History">
                    <NavigationViewItem.Icon>
                        <FontIcon Glyph="&#xE150;" FontFamily="{ThemeResource SymbolThemeFontFamily}" />
                    </NavigationViewItem.Icon>
                </NavigationViewItem>
                <NavigationViewItem x:Name="StatsNavItem" Content="Stats" ToolTipService.ToolTip="Writing Stats &amp; Insights">
                    <NavigationViewItem.Icon>
                        <FontIcon Glyph="&#xE9D2;" FontFamily="{ThemeResource SymbolThemeFontFamily}" />
                    </NavigationViewItem.Icon>
                </NavigationViewItem>
                <NavigationViewItem x:Name="GalleryNavItem" Content="Gallery" ToolTipService.ToolTip="Photo Diary Gallery">
                    <NavigationViewItem.Icon>
                        <FontIcon Glyph="&#xEB9F;" FontFamily="{ThemeResource SymbolThemeFontFamily}" />
                    </NavigationViewItem.Icon>
                </NavigationViewItem>
                <NavigationViewItem x:Name="SettingsNavItem" Content="Settings" ToolTipService.ToolTip="Settings">
                    <NavigationViewItem.Icon>
                        <FontIcon Glyph="&#xE713;" FontFamily="{ThemeResource SymbolThemeFontFamily}" />
                    </NavigationViewItem.Icon>
                </NavigationViewItem>
            </NavigationView.FooterMenuItems>

            <!-- Main Content Container Grid -->
            <Grid>
                <!-- Main Layout Content Pane (split into Notes List and Editor) -->
                <Grid x:Name="MainEditorGrid" Visibility="Visible">
                <Grid.ColumnDefinitions>
                    <!-- Left: Notes List -->
                    <ColumnDefinition x:Name="NotesListColumn" Width="370" MinWidth="200" MaxWidth="500" />
                    <!-- Middle: Resizable Column Splitter -->
                    <ColumnDefinition Width="Auto" />
                    <!-- Right: Editor -->
                    <ColumnDefinition Width="*" />
                </Grid.ColumnDefinitions>

                <!-- Notes List (Grid.Column="0") -->
                <Grid x:Name="NotesListGrid" Grid.Column="0" Background="Transparent" Padding="16">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="*" />
                    </Grid.RowDefinitions>

                    <!-- Tint Overlay behind everything else -->
                    <Border x:Name="NotesListTintOverlay" Grid.RowSpan="2" Margin="-16" IsHitTestVisible="False" Opacity="0">
                        <Border.Background>
                            <LinearGradientBrush StartPoint="0,0" EndPoint="0,1">
                                <GradientStop x:Name="NotesListTintStop1" Offset="0.0" Color="Transparent" />
                                <GradientStop x:Name="NotesListTintStop2" Offset="0.8" Color="Transparent" />
                            </LinearGradientBrush>
                        </Border.Background>
                    </Border>
 
                    <!-- Top Actions -->
                    <Grid Grid.Row="0" Margin="0,0,0,12">
                        <TextBlock x:Name="SelectedCategoryTitle" Text="All Entries" FontSize="18" FontWeight="Bold" Foreground="{ThemeResource TextFillColorPrimaryBrush}" VerticalAlignment="Center" Margin="4,0,0,0" />
                        <StackPanel Orientation="Horizontal" Spacing="8" HorizontalAlignment="Right">
                            <!-- Sort Button -->
                            <Button x:Name="SortNoteButton" ToolTipService.ToolTip="Sort Entries" Width="32" Height="32" CornerRadius="16" Padding="0">
                                <Button.Content>
                                    <FontIcon Glyph="&#xE8CB;" FontFamily="{ThemeResource SymbolThemeFontFamily}" FontSize="14" />
                                </Button.Content>
                                <Button.Flyout>
                                    <MenuFlyout>
                                        <MenuFlyoutItem Text="Date Created (Newest First)" Click="SortOption_Click" Tag="DateCreatedDesc" />
                                        <MenuFlyoutItem Text="Date Created (Oldest First)" Click="SortOption_Click" Tag="DateCreatedAsc" />
                                        <MenuFlyoutItem Text="Date Modified (Newest First)" Click="SortOption_Click" Tag="DateModifiedDesc" />
                                        <MenuFlyoutItem Text="Title (A-Z)" Click="SortOption_Click" Tag="TitleAsc" />
                                        <MenuFlyoutItem Text="Title (Z-A)" Click="SortOption_Click" Tag="TitleDesc" />
                                    </MenuFlyout>
                                </Button.Flyout>
                            </Button>
                            
                            <!-- Empty Trash Button -->
                            <Button x:Name="EmptyTrashButton" ToolTipService.ToolTip="Empty Trash" Click="EmptyTrashButton_Click" Height="32" CornerRadius="16" Padding="8,0" Visibility="Collapsed" Background="#FF3B30" BorderBrush="#FF3B30" Foreground="White">
                                <Button.Resources>
                                    <SolidColorBrush x:Key="ButtonBackgroundPointerOver" Color="#D32F2F" />
                                    <SolidColorBrush x:Key="ButtonForegroundPointerOver" Color="White" />
                                    <SolidColorBrush x:Key="ButtonBorderBrushPointerOver" Color="#D32F2F" />
                                    <SolidColorBrush x:Key="ButtonBackgroundPressed" Color="#B71C1C" />
                                    <SolidColorBrush x:Key="ButtonForegroundPressed" Color="White" />
                                    <SolidColorBrush x:Key="ButtonBorderBrushPressed" Color="#B71C1C" />
                                </Button.Resources>
                                <Button.Content>
                                    <StackPanel Orientation="Horizontal" Spacing="6">
                                        <FontIcon Glyph="&#xE74D;" FontFamily="{ThemeResource SymbolThemeFontFamily}" FontSize="12" />
                                        <TextBlock Text="Empty Trash" FontSize="11" FontWeight="Medium" VerticalAlignment="Center"/>
                                    </StackPanel>
                                </Button.Content>
                            </Button>
                            
                            <!-- Import Entry Button -->
                            <Button x:Name="ImportNoteButton" ToolTipService.ToolTip="Import Entry (.md, .rtf, .txt)" Click="ImportNoteButton_Click" Width="32" Height="32" CornerRadius="16" Padding="0">
                                <Button.Content>
                                    <FontIcon Glyph="&#xE8B5;" FontFamily="{ThemeResource SymbolThemeFontFamily}" FontSize="14" />
                                </Button.Content>
                            </Button>
                            
                            <!-- New Entry Button -->
                            <Button x:Name="NewNoteButton" ToolTipService.ToolTip="New Entry" Click="NewNoteButton_Click" Width="32" Height="32" CornerRadius="16" Padding="0">
                                <Button.Content>
                                    <FontIcon Glyph="&#xE710;" FontFamily="{ThemeResource SymbolThemeFontFamily}" FontSize="14" />
                                </Button.Content>
                            </Button>
                        </StackPanel>
                    </Grid>
 
                    <!-- Notes List -->
                    <ListView x:Name="NotesListView" Grid.Row="1" 
                              ItemsSource="{x:Bind NotesCVS.View, Mode=OneWay}"
                              SelectionMode="Single" SelectionChanged="NotesListView_SelectionChanged" Padding="0,2">
                        <ListView.ItemsPanel>
                            <ItemsPanelTemplate>
                                <ItemsStackPanel AreStickyGroupHeadersEnabled="True"/>
                            </ItemsPanelTemplate>
                        </ListView.ItemsPanel>
                        <ListView.GroupStyle>
                            <GroupStyle>
                                <GroupStyle.HeaderTemplate>
                                    <DataTemplate x:DataType="local:NotesGroup">
                                        <Border Visibility="{x:Bind IsHeaderVisible, Converter={StaticResource BoolToVisibilityConverter}, Mode=OneWay}"
                                                Padding="16,16,16,8" 
                                                Background="Transparent"
                                                HorizontalAlignment="Stretch">
                                            <Grid HorizontalAlignment="Stretch">
                                                <Grid.ColumnDefinitions>
                                                    <ColumnDefinition Width="Auto" />
                                                    <ColumnDefinition Width="Auto" />
                                                    <ColumnDefinition Width="*" />
                                                </Grid.ColumnDefinitions>
                                                
                                                <FontIcon Grid.Column="0" 
                                                          Glyph="{x:Bind CategoryIcon, Mode=OneWay}" 
                                                          Foreground="{x:Bind CategoryColor, Converter={StaticResource HexToBrushConverter}, Mode=OneWay}" 
                                                          FontFamily="{ThemeResource SymbolThemeFontFamily}" 
                                                          FontSize="18" 
                                                          Margin="0,0,8,0" 
                                                          VerticalAlignment="Center" />
                                                
                                                <TextBlock Grid.Column="1" 
                                                           Text="{x:Bind Key, Mode=OneWay}" 
                                                           Style="{ThemeResource BodyLargeTextBlockStyle}"
                                                           VerticalAlignment="Center" />
                                                
                                                <Border Grid.Column="2" 
                                                        Height="1" 
                                                        Background="{ThemeResource DividerStrokeColorDefaultBrush}" 
                                                        Margin="16,0,0,0" 
                                                        VerticalAlignment="Center" />
                                            </Grid>
                                        </Border>
                                    </DataTemplate>
                                </GroupStyle.HeaderTemplate>
                            </GroupStyle>
                        </ListView.GroupStyle>
                        <ListView.ItemTemplate>
                            <DataTemplate x:DataType="local:JournalNote">
                                <!-- Note Item Grid -->
                                <Grid ContextFlyout="{StaticResource NotesListContextFlyout}"
                                      RightTapped="NotesListItem_RightTapped"
                                      PointerEntered="NotesListItem_PointerEntered"
                                      PointerExited="NotesListItem_PointerExited"
                                      HorizontalAlignment="Stretch">
                                    <Grid.RowDefinitions>
                                        <RowDefinition Height="*" />
                                        <RowDefinition Height="Auto" />
                                    </Grid.RowDefinitions>
                                    
                                    <!-- Inner Content Grid (with padding) -->
                                    <Grid Grid.Row="0" Padding="12,14" Background="Transparent">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="Auto" />
                                            <ColumnDefinition Width="*" />
                                            <ColumnDefinition Width="Auto" />
                                            <ColumnDefinition Width="Auto" />
                                        </Grid.ColumnDefinitions>
                                        
                                        <!-- Left: Rounded-Square cover thumbnail (Column 0) -->
                                        <Grid Grid.Column="0" Width="48" Height="48" CornerRadius="8" Background="{ThemeResource CardBackgroundFillColorDefaultBrush}" BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}" BorderThickness="1" Margin="0,0,12,0" VerticalAlignment="Center">
                                            <!-- Fallback Image Icon -->
                                            <FontIcon Glyph="&#xE722;" FontFamily="{ThemeResource SymbolThemeFontFamily}" FontSize="16" Foreground="{ThemeResource TextFillColorSecondaryBrush}" VerticalAlignment="Center" HorizontalAlignment="Center" />
                                            <!-- Thumbnail Image -->
                                            <Image Source="{x:Bind AvatarImagePath, Converter={StaticResource ImagePathConverter}, Mode=OneWay}" Stretch="UniformToFill" />
                                        </Grid>
                                        
                                        <!-- Middle: Content Info (Column 1) -->
                                        <StackPanel Grid.Column="1" Spacing="2" VerticalAlignment="Center">
                                            <StackPanel Orientation="Horizontal" Spacing="6">
                                                <TextBlock Text="{x:Bind Title}" FontSize="14" FontWeight="SemiBold" TextTrimming="CharacterEllipsis" Foreground="{ThemeResource TextFillColorPrimaryBrush}" MaxWidth="120" />
                                                <FontIcon Glyph="&#xE735;" FontFamily="{ThemeResource SymbolThemeFontFamily}" FontSize="14" Foreground="Gold" Visibility="{x:Bind IsFavorite, Converter={StaticResource BoolToVisibilityConverter}, Mode=OneWay}" VerticalAlignment="Center" />
                                                <FontIcon Glyph="&#xE840;" FontFamily="{ThemeResource SymbolThemeFontFamily}" FontSize="14" Foreground="{ThemeResource SystemControlHighlightAccentBrush}" Visibility="{x:Bind IsPinned, Converter={StaticResource BoolToVisibilityConverter}, Mode=OneWay}" VerticalAlignment="Center" />
                                            </StackPanel>
                                            <TextBlock Text="{x:Bind Snippet}" FontSize="12" Foreground="{ThemeResource TextFillColorSecondaryBrush}" TextTrimming="CharacterEllipsis" TextWrapping="NoWrap" />
                                        </StackPanel>
                                        
                                        <!-- Right: Date Card (Column 2) -->
                                        <StackPanel Grid.Column="2" VerticalAlignment="Center" HorizontalAlignment="Center" Spacing="2" Margin="8,0,0,0" Width="56">
                                            <TextBlock Text="{x:Bind DateDayOfWeek, Mode=OneWay}" FontSize="9" FontWeight="Bold" HorizontalAlignment="Center" Foreground="{ThemeResource SystemControlHighlightAccentBrush}" />
                                            <TextBlock Text="{x:Bind DateDayNumber, Mode=OneWay}" FontSize="22" FontWeight="Bold" HorizontalAlignment="Center" Foreground="{ThemeResource TextFillColorPrimaryBrush}" Margin="0,-4" />
                                            <TextBlock Text="{x:Bind DateMonthYear, Mode=OneWay}" FontSize="9" FontWeight="Medium" HorizontalAlignment="Center" Foreground="{ThemeResource TextFillColorSecondaryBrush}" />
                                        </StackPanel>
             
                                         <!-- Rightmost: Vertical Actions Column (Column 3) -->
                                        <StackPanel Grid.Column="3" Orientation="Vertical" Spacing="4" VerticalAlignment="Center" Margin="8,0,0,0">
                                            <!-- Pin Button -->
                                            <Button Click="PinListButton_Click" Tag="ActionButton" Opacity="0" IsHitTestVisible="False" Foreground="{ThemeResource TextFillColorSecondaryBrush}" Background="Transparent" BorderThickness="0" Padding="0" Width="26" Height="26" CornerRadius="13" ToolTipService.ToolTip="Pin to Top" Visibility="{x:Bind IsDeleted, Converter={StaticResource BoolToVisibilityInverseConverter}, Mode=OneWay}">
                                                <Button.Resources>
                                                    <SolidColorBrush x:Key="ButtonForegroundPointerOver" Color="{ThemeResource SystemAccentColor}" />
                                                    <SolidColorBrush x:Key="ButtonForegroundPressed" Color="{ThemeResource SystemAccentColor}" />
                                                </Button.Resources>
                                                <Grid>
                                                    <FontIcon Glyph="&#xE840;" FontFamily="{ThemeResource SymbolThemeFontFamily}" FontSize="14" Visibility="{x:Bind IsPinned, Converter={StaticResource BoolToVisibilityConverter}, Mode=OneWay}" />
                                                    <FontIcon Glyph="&#xE718;" FontFamily="{ThemeResource SymbolThemeFontFamily}" FontSize="14" Visibility="{x:Bind IsPinned, Converter={StaticResource BoolToVisibilityInverseConverter}, Mode=OneWay}" />
                                                </Grid>
                                            </Button>
                                            <!-- Star Button -->
                                            <Button Click="FavoriteListButton_Click" Tag="ActionButton" Opacity="0" IsHitTestVisible="False" Foreground="{ThemeResource TextFillColorSecondaryBrush}" Background="Transparent" BorderThickness="0" Padding="0" Width="26" Height="26" CornerRadius="13" ToolTipService.ToolTip="Toggle Favorite" Visibility="{x:Bind IsDeleted, Converter={StaticResource BoolToVisibilityInverseConverter}, Mode=OneWay}">
                                                <Button.Resources>
                                                    <SolidColorBrush x:Key="ButtonForegroundPointerOver" Color="Gold" />
                                                    <SolidColorBrush x:Key="ButtonForegroundPressed" Color="Gold" />
                                                </Button.Resources>
                                                <Grid>
                                                    <FontIcon Glyph="&#xE735;" FontFamily="{ThemeResource SymbolThemeFontFamily}" FontSize="14" Visibility="{x:Bind IsFavorite, Converter={StaticResource BoolToVisibilityConverter}, Mode=OneWay}" />
                                                    <FontIcon Glyph="&#xE734;" FontFamily="{ThemeResource SymbolThemeFontFamily}" FontSize="14" Visibility="{x:Bind IsFavorite, Converter={StaticResource BoolToVisibilityInverseConverter}, Mode=OneWay}" />
                                                </Grid>
                                            </Button>
                                            <!-- Delete Button -->
                                            <Button Click="DeleteListButton_Click" Tag="DeleteButton" Opacity="0" IsHitTestVisible="False" Foreground="{ThemeResource TextFillColorSecondaryBrush}" Background="Transparent" BorderThickness="0" Padding="0" Width="26" Height="26" CornerRadius="13" ToolTipService.ToolTip="Move to Trash" Visibility="{x:Bind IsDeleted, Converter={StaticResource BoolToVisibilityInverseConverter}, Mode=OneWay}">
                                                <Button.Resources>
                                                    <SolidColorBrush x:Key="ButtonForegroundPointerOver" Color="Red" />
                                                    <SolidColorBrush x:Key="ButtonForegroundPressed" Color="Red" />
                                                </Button.Resources>
                                                <FontIcon Glyph="&#xE74D;" FontFamily="{ThemeResource SymbolThemeFontFamily}" FontSize="14" />
                                            </Button>
                                            
                                            <!-- Trash Mode Buttons -->
                                            <Button Click="RestoreListButton_Click" Foreground="{ThemeResource TextFillColorSecondaryBrush}" Background="Transparent" BorderThickness="0" Padding="0" Width="26" Height="26" CornerRadius="13" ToolTipService.ToolTip="Restore Entry" Visibility="{x:Bind IsDeleted, Converter={StaticResource BoolToVisibilityConverter}, Mode=OneWay}">
                                                <Button.Resources>
                                                    <SolidColorBrush x:Key="ButtonForegroundPointerOver" Color="{ThemeResource SystemAccentColor}" />
                                                    <SolidColorBrush x:Key="ButtonForegroundPressed" Color="{ThemeResource SystemAccentColor}" />
                                                </Button.Resources>
                                                <FontIcon Glyph="&#xE7A6;" FontFamily="{ThemeResource SymbolThemeFontFamily}" FontSize="14" />
                                            </Button>
                                            <Button Click="PermanentlyDeleteListButton_Click" Tag="DeleteButton" Opacity="0" IsHitTestVisible="False" Foreground="{ThemeResource TextFillColorSecondaryBrush}" Background="Transparent" BorderThickness="0" Padding="0" Width="26" Height="26" CornerRadius="13" ToolTipService.ToolTip="Delete Permanently" Visibility="{x:Bind IsDeleted, Converter={StaticResource BoolToVisibilityConverter}, Mode=OneWay}">
                                                <Button.Resources>
                                                    <SolidColorBrush x:Key="ButtonForegroundPointerOver" Color="Red" />
                                                    <SolidColorBrush x:Key="ButtonForegroundPressed" Color="Red" />
                                                </Button.Resources>
                                                <FontIcon Glyph="&#xE74D;" FontFamily="{ThemeResource SymbolThemeFontFamily}" FontSize="14" />
                                            </Button>
                                        </StackPanel>
                                    </Grid>
                                    
                                    <!-- Bottom Divider Line -->
                                    <Border Grid.Row="1" 
                                            Height="1" 
                                            Background="{ThemeResource DividerStrokeColorDefaultBrush}" 
                                            Visibility="{x:Bind IsBottomDividerVisible, Converter={StaticResource BoolToVisibilityConverter}, Mode=OneWay}" />
                                </Grid>
                            </DataTemplate>
                        </ListView.ItemTemplate>
                    </ListView>
                </Grid>

                <!-- Divider Line & Splitter -->
                <Border Grid.Column="1" 
                        x:Name="ColumnSplitter"
                        Width="8" 
                        Background="Transparent" 
                        HorizontalAlignment="Center" 
                        VerticalAlignment="Stretch"
                        PointerPressed="ColumnSplitter_PointerPressed"
                        PointerMoved="ColumnSplitter_PointerMoved"
                        PointerReleased="ColumnSplitter_PointerReleased"
                        PointerEntered="ColumnSplitter_PointerEntered"
                        PointerExited="ColumnSplitter_PointerExited"
                        Canvas.ZIndex="10">
                    <Border Width="1" 
                            HorizontalAlignment="Center" 
                            VerticalAlignment="Stretch" 
                            BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}" 
                            BorderThickness="1,0,0,0" />
                </Border>

                <!-- Active Note Editor (Grid.Column="2") -->
                <Grid Grid.Column="2" Background="Transparent">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="*" />
                        <RowDefinition Height="Auto" />
                    </Grid.RowDefinitions>

                    <!-- Editor Toolbar -->
                    <Grid x:Name="EditorToolbar" Grid.Row="0" Background="Transparent" Padding="16,8" BorderThickness="0,0,0,1" BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}" Visibility="Collapsed">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="Auto" />
                        </Grid.ColumnDefinitions>
                        <!-- Formatting Controls -->
                        <StackPanel Grid.Column="0" Orientation="Horizontal" Spacing="6" VerticalAlignment="Center">
                            <Button ToolTipService.ToolTip="Bold (Ctrl+B)" Click="BoldButton_Click" Width="36" Height="32" Padding="0">
                                <Button.Content>
                                    <FontIcon Glyph="&#xE8DD;" FontFamily="{ThemeResource SymbolThemeFontFamily}" FontSize="14" />
                                </Button.Content>
                            </Button>
                            <Button ToolTipService.ToolTip="Italic (Ctrl+I)" Click="ItalicButton_Click" Width="36" Height="32" Padding="0">
                                <Button.Content>
                                    <FontIcon Glyph="&#xE8DB;" FontFamily="{ThemeResource SymbolThemeFontFamily}" FontSize="14" />
                                </Button.Content>
                            </Button>
                            <Button ToolTipService.ToolTip="Underline (Ctrl+U)" Click="UnderlineButton_Click" Width="36" Height="32" Padding="0">
                                <Button.Content>
                                    <FontIcon Glyph="&#xE8DC;" FontFamily="{ThemeResource SymbolThemeFontFamily}" FontSize="14" />
                                </Button.Content>
                            </Button>

                            <AppBarSeparator />

                            <Button ToolTipService.ToolTip="Align Left" Click="AlignLeftButton_Click" Width="36" Height="32" Padding="0">
                                <Button.Content>
                                    <FontIcon Glyph="&#xE8E4;" FontFamily="{ThemeResource SymbolThemeFontFamily}" FontSize="14" />
                                </Button.Content>
                            </Button>
                            <Button ToolTipService.ToolTip="Align Center" Click="AlignCenterButton_Click" Width="36" Height="32" Padding="0">
                                <Button.Content>
                                    <FontIcon Glyph="&#xE8E3;" FontFamily="{ThemeResource SymbolThemeFontFamily}" FontSize="14" />
                                </Button.Content>
                            </Button>
                            <Button ToolTipService.ToolTip="Align Right" Click="AlignRightButton_Click" Width="36" Height="32" Padding="0">
                                <Button.Content>
                                    <FontIcon Glyph="&#xE8E2;" FontFamily="{ThemeResource SymbolThemeFontFamily}" FontSize="14" />
                                </Button.Content>
                            </Button>
                             <Button ToolTipService.ToolTip="Justify" Click="AlignJustifyButton_Click" Width="36" Height="32" Padding="0">
                                 <Button.Content>
                                     <FontIcon Glyph="&#xE700;" FontFamily="{ThemeResource SymbolThemeFontFamily}" FontSize="14" />
                                 </Button.Content>
                             </Button>

                            <AppBarSeparator />

                            <Button ToolTipService.ToolTip="Bulleted List" Click="BulletListButton_Click" Width="36" Height="32" Padding="0">
                                <Button.Content>
                                    <FontIcon Glyph="&#xE8FD;" FontFamily="{ThemeResource SymbolThemeFontFamily}" FontSize="14" />
                                </Button.Content>
                            </Button>

                            <AppBarSeparator />

                            <!-- Insert Image Menu -->
                            <Button ToolTipService.ToolTip="Insert Inline Image" Width="44" Height="32" Padding="0">
                                <Button.Content>
                                    <StackPanel Orientation="Horizontal" Spacing="4" Padding="6,0">
                                        <FontIcon Glyph="&#xE722;" FontFamily="{ThemeResource SymbolThemeFontFamily}" FontSize="14" />
                                        <FontIcon Glyph="&#xE0E5;" FontFamily="{ThemeResource SymbolThemeFontFamily}" FontSize="8" VerticalAlignment="Center" />
                                    </StackPanel>
                                </Button.Content>
                                <Button.Flyout>
                                    <MenuFlyout>
                                        <MenuFlyoutItem Text="From File..." Click="InsertLocalImage_Click">
                                            <MenuFlyoutItem.Icon>
                                                <FontIcon Glyph="&#xE114;" FontFamily="{ThemeResource SymbolThemeFontFamily}" />
                                            </MenuFlyoutItem.Icon>
                                        </MenuFlyoutItem>
                                        <MenuFlyoutItem Text="From URL..." Click="InsertUrlImage_Click">
                                            <MenuFlyoutItem.Icon>
                                                <FontIcon Glyph="&#xE71B;" FontFamily="{ThemeResource SymbolThemeFontFamily}" />
                                            </MenuFlyoutItem.Icon>
                                        </MenuFlyoutItem>
                                    </MenuFlyout>
                                </Button.Flyout>
                            </Button>

                            <!-- Font Family Selector in Toolbar -->
                            <ComboBox x:Name="ToolbarFontComboBox" Width="130" Height="32" SelectionChanged="ToolbarFontComboBox_SelectionChanged" PlaceholderText="Font" ToolTipService.ToolTip="Text Font Family">
                                <ComboBoxItem Content="Segoe UI" Tag="Segoe UI" />
                                <ComboBoxItem Content="Inter" Tag="Inter" />
                                <ComboBoxItem Content="Roboto" Tag="Roboto" />
                                <ComboBoxItem Content="Outfit" Tag="Outfit" />
                                <ComboBoxItem Content="Courier New" Tag="Courier New" />
                                <ComboBoxItem Content="Georgia" Tag="Georgia" />
                                <ComboBoxItem Content="Consolas" Tag="Consolas" />
                            </ComboBox>

                            <!-- Editor Layout Width Dropdown -->
                            <Button x:Name="EditorWidthButton" ToolTipService.ToolTip="Editor Layout Width" Width="44" Height="32" Padding="0">
                                <Button.Content>
                                    <StackPanel Orientation="Horizontal" Spacing="4" Padding="6,0">
                                        <FontIcon Glyph="&#xE740;" FontFamily="{ThemeResource SymbolThemeFontFamily}" FontSize="14" />
                                        <FontIcon Glyph="&#xE0E5;" FontFamily="{ThemeResource SymbolThemeFontFamily}" FontSize="8" VerticalAlignment="Center" />
                                    </StackPanel>
                                </Button.Content>
                                <Button.Flyout>
                                    <MenuFlyout>
                                        <MenuFlyoutItem Text="Narrow (600px)" Click="EditorWidth_Click" Tag="Narrow" />
                                        <MenuFlyoutItem Text="Medium (800px)" Click="EditorWidth_Click" Tag="Medium" />
                                        <MenuFlyoutItem Text="Wide (1000px)" Click="EditorWidth_Click" Tag="Wide" />
                                        <MenuFlyoutItem Text="Full Width" Click="EditorWidth_Click" Tag="Full" />
                                    </MenuFlyout>
                                </Button.Flyout>
                            </Button>

                            <!-- Markdown Preview Toggle -->
                            <ToggleButton x:Name="MarkdownPreviewToggle" ToolTipService.ToolTip="Markdown Preview" Checked="MarkdownPreviewToggle_Checked" Unchecked="MarkdownPreviewToggle_Unchecked" Width="36" Height="32" Padding="0">
                                <ToggleButton.Content>
                                    <FontIcon Glyph="&#xE929;" FontFamily="{ThemeResource SymbolThemeFontFamily}" FontSize="14" />
                                </ToggleButton.Content>
                            </ToggleButton>

                            <!-- Print Note Button -->
                            <Button x:Name="PrintNoteButton" ToolTipService.ToolTip="Print Entry" Click="PrintNoteButton_Click" Width="36" Height="32" Padding="0">
                                <Button.Content>
                                    <FontIcon Glyph="&#xE749;" FontFamily="{ThemeResource SymbolThemeFontFamily}" FontSize="14" />
                                </Button.Content>
                            </Button>
                        </StackPanel>

                        <!-- Actions Controls -->
                        <StackPanel Grid.Column="1" Orientation="Horizontal" Spacing="6" VerticalAlignment="Center">
                            <ToggleButton x:Name="PinToggle" ToolTipService.ToolTip="Pin to Top" Checked="PinToggle_Checked" Unchecked="PinToggle_Unchecked" Width="36" Height="32" Padding="0">
                                <ToggleButton.Content>
                                    <FontIcon Glyph="&#xE718;" FontFamily="{ThemeResource SymbolThemeFontFamily}" FontSize="14" />
                                </ToggleButton.Content>
                            </ToggleButton>
                            <ToggleButton x:Name="FavoriteToggle" ToolTipService.ToolTip="Favorite" Checked="FavoriteToggle_Checked" Unchecked="FavoriteToggle_Unchecked" Width="36" Height="32" Padding="0">
                                <ToggleButton.Content>
                                    <FontIcon Glyph="&#xE734;" FontFamily="{ThemeResource SymbolThemeFontFamily}" FontSize="14" />
                                </ToggleButton.Content>
                            </ToggleButton>
                            
                            <!-- Move Note Category Menu -->
                            <Button x:Name="MoveCategoryButton" ToolTipService.ToolTip="Move Category" Width="36" Height="32" Padding="0">
                                <Button.Content>
                                    <FontIcon Glyph="&#xE8DE;" FontFamily="{ThemeResource SymbolThemeFontFamily}" FontSize="14" />
                                </Button.Content>
                                <Button.Flyout>
                                    <MenuFlyout x:Name="MoveCategoryMenu" Opening="MoveCategoryMenu_Opening">
                                        <!-- Populated dynamically -->
                                    </MenuFlyout>
                                </Button.Flyout>
                            </Button>
                            
                            <Button x:Name="DeleteNoteButton" ToolTipService.ToolTip="Move to Trash" Click="DeleteNoteButton_Click" Width="36" Height="32" Padding="0">
                                <Button.Content>
                                    <FontIcon Glyph="&#xE74D;" FontFamily="{ThemeResource SymbolThemeFontFamily}" FontSize="14" Foreground="Red" />
                                </Button.Content>
                            </Button>

                            <Button x:Name="RestoreNoteButton" ToolTipService.ToolTip="Restore Entry" Click="RestoreNoteButton_Click" Width="36" Height="32" Padding="0" Visibility="Collapsed">
                                <Button.Content>
                                    <FontIcon Glyph="&#xE7A6;" FontFamily="{ThemeResource SymbolThemeFontFamily}" FontSize="14" Foreground="{ThemeResource SystemControlHighlightAccentBrush}" />
                                </Button.Content>
                            </Button>

                            <Button x:Name="PermanentlyDeleteNoteButton" ToolTipService.ToolTip="Delete Permanently" Click="PermanentlyDeleteNoteButton_Click" Width="36" Height="32" Padding="0" Visibility="Collapsed">
                                <Button.Content>
                                    <FontIcon Glyph="&#xE74D;" FontFamily="{ThemeResource SymbolThemeFontFamily}" FontSize="14" Foreground="Red" />
                                </Button.Content>
                            </Button>
                        </StackPanel>
                    </Grid>

                    <!-- Find & Replace Bar (Ctrl+F) -->
                    <Grid x:Name="FindReplaceBar" Grid.Row="1" Visibility="Collapsed"
                          Background="{ThemeResource CardBackgroundFillColorDefaultBrush}"
                          BorderThickness="0,1,0,1" BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}"
                          Padding="12,6">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="Auto" />
                        </Grid.ColumnDefinitions>
                        <StackPanel Orientation="Horizontal" Spacing="6" VerticalAlignment="Center">
                            <TextBox x:Name="FindTextBox" PlaceholderText="Find..." Width="180" Height="28"
                                     FontSize="12" TextChanged="FindTextBox_TextChanged"
                                     KeyDown="FindTextBox_KeyDown" />
                            <TextBox x:Name="ReplaceTextBox" PlaceholderText="Replace with..." Width="180" Height="28"
                                     FontSize="12" />
                            <Button x:Name="PrevMatchBtn" Content="&#xE972;" FontFamily="{ThemeResource SymbolThemeFontFamily}"
                                    Width="28" Height="28" Padding="0" FontSize="12"
                                    ToolTipService.ToolTip="Previous match" Click="PrevMatchBtn_Click" />
                            <Button x:Name="NextMatchBtn" Content="&#xE971;" FontFamily="{ThemeResource SymbolThemeFontFamily}"
                                    Width="28" Height="28" Padding="0" FontSize="12"
                                    ToolTipService.ToolTip="Next match" Click="NextMatchBtn_Click" />
                            <Button x:Name="ReplaceOneBtn" Content="Replace" Height="28" Padding="8,0" FontSize="12"
                                    ToolTipService.ToolTip="Replace current match" Click="ReplaceOneBtn_Click" />
                            <Button x:Name="ReplaceAllBtn" Content="Replace All" Height="28" Padding="8,0" FontSize="12"
                                    ToolTipService.ToolTip="Replace all matches" Click="ReplaceAllBtn_Click" />
                            <TextBlock x:Name="MatchCountText" Text="" FontSize="11"
                                       Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                                       VerticalAlignment="Center" Margin="4,0" />
                        </StackPanel>
                        <Button x:Name="CloseFindBarBtn" Grid.Column="1" Content="&#xE711;"
                                FontFamily="{ThemeResource SymbolThemeFontFamily}"
                                Width="28" Height="28" Padding="0" FontSize="12"
                                ToolTipService.ToolTip="Close (Escape)" Click="CloseFindBarBtn_Click" />
                    </Grid>

                    <!-- Editor Pane ScrollViewer -->
                    <ScrollViewer x:Name="EditorScrollViewer" Grid.Row="2" Padding="0" VerticalScrollBarVisibility="Auto" Background="Transparent">
                        <!-- Redesigned Editor Grid (flush edge-to-edge container) -->
                        <Grid x:Name="EditorStackPanel" 
                              HorizontalAlignment="Stretch" 
                              VerticalAlignment="Top"
                              Visibility="Collapsed">
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto" />
                                <RowDefinition Height="*" />
                            </Grid.RowDefinitions>

                            <!-- Tint Overlay for Editor Content behind everything else in Row 1 -->
                            <Border x:Name="EditorTintOverlay" Grid.Row="1" IsHitTestVisible="False" Opacity="0">
                                <Border.Background>
                                    <LinearGradientBrush StartPoint="0,0" EndPoint="0,1">
                                        <GradientStop x:Name="EditorTintStop1" Offset="0.0" Color="Transparent" />
                                        <GradientStop x:Name="EditorTintStop2" Offset="0.8" Color="Transparent" />
                                    </LinearGradientBrush>
                                </Border.Background>
                            </Border>
                            
                            <!-- Hero Image Banner (Stretches full width, overlay cover actions) -->
                            <Grid x:Name="HeroImageContainer" Grid.Row="0" Height="300" Background="{ThemeResource CardStrokeColorDefaultBrush}" Visibility="Collapsed" HorizontalAlignment="Stretch" CornerRadius="0.1" SizeChanged="HeroImageContainer_SizeChanged">
                                <!-- Clipped container for image positioning -->
                                <Grid HorizontalAlignment="Stretch" VerticalAlignment="Stretch" CornerRadius="0.1">
                                    <Image x:Name="HeroImage" Height="600" Stretch="UniformToFill" HorizontalAlignment="Stretch" VerticalAlignment="Center">
                                        <Image.RenderTransform>
                                            <TranslateTransform x:Name="HeroImageTranslate" Y="0" />
                                        </Image.RenderTransform>
                                    </Image>
                                    
                                    <!-- Brightness/Dimming Overlay -->
                                    <Border x:Name="CoverBrightnessOverlay" Background="Black" Opacity="0" HorizontalAlignment="Stretch" VerticalAlignment="Stretch" IsHitTestVisible="False" />
                                </Grid>

                                <!-- Attribution Badge (Bottom Left) -->
                                <Border x:Name="CoverAttributionBorder" VerticalAlignment="Bottom" HorizontalAlignment="Left" Margin="16" Background="#99000000" CornerRadius="12" Padding="8,4" Visibility="Collapsed">
                                    <StackPanel Orientation="Horizontal" Spacing="6">
                                        <FontIcon Glyph="&#xE9A1;" FontFamily="{ThemeResource SymbolThemeFontFamily}" FontSize="10" Foreground="White" VerticalAlignment="Center" />
                                        <RichTextBlock FontSize="10" Foreground="White" VerticalAlignment="Center">
                                            <Paragraph>
                                                <Run Text="Photo by " />
                                                <Hyperlink x:Name="PhotographerHyperlink" Foreground="#FF4A90E2" UnderlineStyle="None">
                                                    <Run x:Name="PhotographerNameRun" Text="Photographer" />
                                                </Hyperlink>
                                                <Run Text=" on " />
                                                <Hyperlink NavigateUri="https://unsplash.com/?utm_source=JournalApp&amp;utm_medium=referral" Foreground="#FF4A90E2" UnderlineStyle="None">
                                                    <Run Text="Unsplash" />
                                                </Hyperlink>
                                            </Paragraph>
                                        </RichTextBlock>
                                    </StackPanel>
                                </Border>
                                
                                 <!-- Overlay Actions on Hero Image (Top Right) -->
                                 <StackPanel Orientation="Horizontal" Spacing="8" VerticalAlignment="Top" HorizontalAlignment="Right" Margin="16">
                                     <!-- Change Banner Button -->
                                     <Button x:Name="ChangeHeroButton" CornerRadius="16" Padding="12,6" Background="#99000000" BorderThickness="0" ToolTipService.ToolTip="Change Cover Banner">
                                         <Button.Content>
                                             <StackPanel Orientation="Horizontal" Spacing="6">
                                                 <FontIcon Glyph="&#xE722;" FontFamily="{ThemeResource SymbolThemeFontFamily}" FontSize="12" Foreground="White" />
                                                 <TextBlock Text="Change Cover" FontSize="11" Foreground="White" FontWeight="Medium" />
                                             </StackPanel>
                                         </Button.Content>
                                         <Button.Flyout>
                                             <MenuFlyout>
                                                 <MenuFlyoutItem Text="Select Local Image..." Click="SetLocalHeroImage_Click">
                                                     <MenuFlyoutItem.Icon>
                                                         <FontIcon Glyph="&#xE114;" FontFamily="{ThemeResource SymbolThemeFontFamily}" />
                                                     </MenuFlyoutItem.Icon>
                                                 </MenuFlyoutItem>
                                                 <MenuFlyoutItem Text="Search Unsplash..." Click="SearchUnsplashHeroImage_Click">
                                                     <MenuFlyoutItem.Icon>
                                                         <FontIcon Glyph="&#xE128;" FontFamily="{ThemeResource SymbolThemeFontFamily}" />
                                                     </MenuFlyoutItem.Icon>
                                                 </MenuFlyoutItem>
                                                 <MenuFlyoutItem Text="Set Web URL..." Click="SetUrlHeroImage_Click">
                                                     <MenuFlyoutItem.Icon>
                                                         <FontIcon Glyph="&#xE71B;" FontFamily="{ThemeResource SymbolThemeFontFamily}" />
                                                     </MenuFlyoutItem.Icon>
                                                 </MenuFlyoutItem>
                                                 <MenuFlyoutSeparator />
                                                 <MenuFlyoutItem Text="Reset to Default" Click="ResetHeroImage_Click">
                                                     <MenuFlyoutItem.Icon>
                                                         <FontIcon Glyph="&#xE777;" FontFamily="{ThemeResource SymbolThemeFontFamily}" />
                                                     </MenuFlyoutItem.Icon>
                                                 </MenuFlyoutItem>
                                             </MenuFlyout>
                                         </Button.Flyout>
                                     </Button>

                                     <!-- Adjust Cover Button -->
                                     <Button x:Name="AdjustHeroButton" CornerRadius="16" Width="32" Height="32" Padding="0" Background="#99000000" BorderThickness="0" ToolTipService.ToolTip="Adjust Cover Effects">
                                         <Button.Content>
                                             <FontIcon Glyph="&#xE7AC;" FontFamily="{ThemeResource SymbolThemeFontFamily}" FontSize="12" Foreground="White" />
                                         </Button.Content>
                                         <Button.Flyout>
                                             <Flyout x:Name="AdjustHeroFlyout" Placement="BottomEdgeAlignedRight">
                                                 <Flyout.FlyoutPresenterStyle>
                                                     <Style TargetType="FlyoutPresenter">
                                                         <Setter Property="Padding" Value="0" />
                                                         <Setter Property="CornerRadius" Value="12" />
                                                         <Setter Property="Background" Value="#1E1E1E" />
                                                         <Setter Property="BorderBrush" Value="#3A3A3A" />
                                                         <Setter Property="BorderThickness" Value="1" />
                                                     </Style>
                                                 </Flyout.FlyoutPresenterStyle>
                                                 <StackPanel Spacing="0" Width="300">
                                                     <!-- Header -->
                                                     <StackPanel Padding="20,16,20,14">
                                                         <TextBlock Text="Adjust Cover Banner" FontSize="14" FontWeight="SemiBold" Foreground="White" />
                                                     </StackPanel>
                                                     <Border Height="1" Background="#333333" />

                                                     <!-- Sliders -->
                                                     <StackPanel Spacing="0" Padding="20,12,20,12">
                                                         <!-- Vertical Position -->
                                                         <Grid Margin="0,0,0,2">
                                                             <TextBlock Text="Vertical Position" FontSize="12" FontWeight="Medium" Foreground="#E0E0E0" VerticalAlignment="Center" />
                                                             <TextBlock x:Name="OffsetYValueText" Text="150px" FontSize="11" Foreground="#888888" HorizontalAlignment="Right" VerticalAlignment="Center" />
                                                         </Grid>
                                                         <Slider x:Name="CoverOffsetYSlider" Minimum="-150" Maximum="150" Value="0" StepFrequency="1" ValueChanged="CoverOffsetYSlider_ValueChanged" Foreground="#0078D4" Margin="0,0,0,14" />

                                                         <!-- Brightness -->
                                                         <Grid Margin="0,0,0,2">
                                                             <TextBlock Text="Brightness" FontSize="12" FontWeight="Medium" Foreground="#E0E0E0" VerticalAlignment="Center" />
                                                             <TextBlock x:Name="BrightnessValueText" Text="100%" FontSize="11" Foreground="#888888" HorizontalAlignment="Right" VerticalAlignment="Center" />
                                                         </Grid>
                                                         <Slider x:Name="CoverBrightnessSlider" Minimum="30" Maximum="100" Value="100" StepFrequency="1" ValueChanged="CoverBrightnessSlider_ValueChanged" Foreground="#0078D4" Margin="0,0,0,14" />

                                                         <!-- Blur -->
                                                         <Grid Margin="0,0,0,2">
                                                             <TextBlock Text="Blur" FontSize="12" FontWeight="Medium" Foreground="#E0E0E0" VerticalAlignment="Center" />
                                                             <TextBlock x:Name="BlurValueText" Text="0%" FontSize="11" Foreground="#888888" HorizontalAlignment="Right" VerticalAlignment="Center" />
                                                         </Grid>
                                                         <Slider x:Name="CoverBlurSlider" Minimum="0" Maximum="100" Value="0" StepFrequency="1" ValueChanged="CoverBlurSlider_ValueChanged" Foreground="#0078D4" />
                                                     </StackPanel>

                                                     <Border Height="1" Background="#333333" />

                                                     <!-- Reset Button -->
                                                     <StackPanel Padding="20,12">
                                                         <Button x:Name="ResetEffectsButton" Content="Reset to Default" Click="ResetEffectsButton_Click"
                                                                 HorizontalAlignment="Stretch" Padding="0,10"
                                                                 CornerRadius="8" FontSize="12"
                                                                 Background="#2A2A2A" Foreground="#E0E0E0"
                                                                 BorderBrush="#444444" BorderThickness="1" />
                                                     </StackPanel>
                                                 </StackPanel>
                                             </Flyout>
                                         </Button.Flyout>
                                     </Button>

                                     <!-- Remove/Hide Banner Button -->
                                     <Button Click="RemoveHeroImage_Click" CornerRadius="16" Width="32" Height="32" Padding="0" Background="#99000000" BorderThickness="0" ToolTipService.ToolTip="Hide Cover Banner">
                                         <Button.Content>
                                             <FontIcon Glyph="&#xE711;" FontFamily="{ThemeResource SymbolThemeFontFamily}" FontSize="12" Foreground="White" />
                                         </Button.Content>
                                     </Button>
                                 </StackPanel>
                            </Grid>

                            <!-- Centered Editor Content (Text wrapper up to MaxWidth 800) -->
                            <StackPanel x:Name="EditorContentStackPanel" Grid.Row="1" MaxWidth="800" HorizontalAlignment="Stretch" Padding="40,32,40,40" Spacing="20">
                                <!-- Date and Category Header (Side-by-side Grid) -->
                                <Grid ColumnSpacing="24" HorizontalAlignment="Stretch" Margin="0,0,0,8">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="Auto" />
                                        <ColumnDefinition Width="*" />
                                        <ColumnDefinition Width="Auto" />
                                    </Grid.ColumnDefinitions>

                                    <!-- Left: Date Button -->
                                    <Button x:Name="EditDateButton" Grid.Column="0" Background="Transparent" BorderThickness="0" Padding="4" HorizontalContentAlignment="Left" CornerRadius="8" ToolTipService.ToolTip="Edit Date and Time">
                                        <Button.Content>
                                            <Grid ColumnSpacing="32" VerticalAlignment="Center">
                                                <Grid.ColumnDefinitions>
                                                    <ColumnDefinition Width="Auto" />
                                                    <ColumnDefinition Width="*" />
                                                </Grid.ColumnDefinitions>
                                                
                                                <!-- Big Day Number -->
                                                <TextBlock x:Name="DateDayTextBlock" Grid.Column="0" Text="12" FontSize="56" FontWeight="Bold" Foreground="{ThemeResource TextFillColorPrimaryBrush}" VerticalAlignment="Center" Margin="0,-8,0,0"/>
                                                
                                                <!-- Month/Year and Time details stack -->
                                                <StackPanel Grid.Column="1" VerticalAlignment="Center" Spacing="2">
                                                    <TextBlock x:Name="DateMonthYearTextBlock" Text="May 2026" FontSize="18" FontWeight="SemiBold" Foreground="{ThemeResource TextFillColorPrimaryBrush}" />
                                                    <TextBlock x:Name="DateTimeTextBlock" Text="Tue, 11:35 PM" FontSize="13" Foreground="{ThemeResource TextFillColorSecondaryBrush}" />
                                                </StackPanel>
                                            </Grid>
                                        </Button.Content>
                                        <Button.Flyout>
                                            <Flyout x:Name="DateEditFlyout">
                                                <StackPanel Spacing="16" Width="300" Padding="4">
                                                    <TextBlock Text="Edit Entry Date &amp; Time" FontSize="16" FontWeight="SemiBold" Foreground="{ThemeResource TextFillColorPrimaryBrush}" />
                                                    
                                                    <!-- Calendar View -->
                                                    <CalendarView x:Name="EditDateCalendarView" SelectionMode="Single" HorizontalAlignment="Stretch" />
                                                    
                                                    <!-- Time Toggle -->
                                                    <ToggleSwitch x:Name="IncludeTimeToggle" Header="Include Time" IsOn="True" Toggled="IncludeTimeToggle_Toggled" OnContent="Yes" OffContent="No" />
                                                    
                                                    <!-- Time Picker -->
                                                    <TimePicker x:Name="EditTimePicker" ClockIdentifier="12HourClock" HorizontalAlignment="Stretch" Margin="0,-4,0,0" />
                                                    
                                                    <!-- Action Buttons -->
                                                    <Grid ColumnSpacing="12" Margin="0,8,0,0">
                                                        <Grid.ColumnDefinitions>
                                                            <ColumnDefinition Width="*" />
                                                            <ColumnDefinition Width="*" />
                                                        </Grid.ColumnDefinitions>
                                                        <Button x:Name="ApplyDateButton" Grid.Column="0" Content="Apply" Click="ApplyDateButton_Click" Style="{StaticResource AccentButtonStyle}" HorizontalAlignment="Stretch" />
                                                        <Button x:Name="CancelDateButton" Grid.Column="1" Content="Cancel" Click="CancelDateButton_Click" HorizontalAlignment="Stretch" />
                                                    </Grid>
                                                </StackPanel>
                                            </Flyout>
                                        </Button.Flyout>
                                    </Button>

                                    <!-- Right: Add Cover Button & Category Badge Button -->
                                    <StackPanel Grid.Column="2" Orientation="Horizontal" Spacing="12" VerticalAlignment="Center" HorizontalAlignment="Right">
                                        <!-- Add Cover Button (Visible only when cover is hidden) -->
                                        <Button x:Name="AddCoverButton" CornerRadius="12" Padding="10,4" Background="Transparent" BorderThickness="1" BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}" Visibility="Collapsed" ToolTipService.ToolTip="Add Cover Banner">
                                            <Button.Content>
                                                <StackPanel Orientation="Horizontal" Spacing="6">
                                                    <FontIcon Glyph="&#xE722;" FontFamily="{ThemeResource SymbolThemeFontFamily}" FontSize="12" />
                                                    <TextBlock Text="Add Cover" FontSize="11" FontWeight="Medium" />
                                                </StackPanel>
                                            </Button.Content>
                                            <Button.Flyout>
                                                <MenuFlyout>
                                                    <MenuFlyoutItem Text="Select Local Image..." Click="SetLocalHeroImage_Click">
                                                        <MenuFlyoutItem.Icon>
                                                            <FontIcon Glyph="&#xE114;" FontFamily="{ThemeResource SymbolThemeFontFamily}" />
                                                        </MenuFlyoutItem.Icon>
                                                    </MenuFlyoutItem>
                                                    <MenuFlyoutItem Text="Search Unsplash..." Click="SearchUnsplashHeroImage_Click">
                                                        <MenuFlyoutItem.Icon>
                                                            <FontIcon Glyph="&#xE128;" FontFamily="{ThemeResource SymbolThemeFontFamily}" />
                                                        </MenuFlyoutItem.Icon>
                                                    </MenuFlyoutItem>
                                                    <MenuFlyoutItem Text="Set Web URL..." Click="SetUrlHeroImage_Click">
                                                        <MenuFlyoutItem.Icon>
                                                            <FontIcon Glyph="&#xE71B;" FontFamily="{ThemeResource SymbolThemeFontFamily}" />
                                                        </MenuFlyoutItem.Icon>
                                                    </MenuFlyoutItem>
                                                    <MenuFlyoutSeparator />
                                                    <MenuFlyoutItem Text="Reset to Default" Click="ResetHeroImage_Click">
                                                        <MenuFlyoutItem.Icon>
                                                            <FontIcon Glyph="&#xE777;" FontFamily="{ThemeResource SymbolThemeFontFamily}" />
                                                        </MenuFlyoutItem.Icon>
                                                    </MenuFlyoutItem>
                                                </MenuFlyout>
                                            </Button.Flyout>
                                        </Button>

                                        <!-- Mood Selector Button -->
                                        <Button x:Name="NoteMoodButton" Background="Transparent" BorderThickness="1" BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}" Padding="10,6" CornerRadius="12" ToolTipService.ToolTip="How are you feeling?">
                                            <Button.Content>
                                                <StackPanel Orientation="Horizontal" Spacing="8" VerticalAlignment="Center">
                                                    <TextBlock x:Name="NoteMoodIcon" Text="😐" FontSize="14" />
                                                    <TextBlock x:Name="NoteMoodText" Text="Neutral" FontSize="12" FontWeight="SemiBold" Foreground="{ThemeResource TextFillColorSecondaryBrush}" />
                                                    <FontIcon Glyph="&#xE972;" FontFamily="{ThemeResource SymbolThemeFontFamily}" FontSize="8" Foreground="{ThemeResource TextFillColorTertiaryBrush}" Margin="2,0,0,0" />
                                                </StackPanel>
                                            </Button.Content>
                                            <Button.Flyout>
                                                <MenuFlyout>
                                                    <MenuFlyoutItem Text="😊 Happy" Click="MoodItem_Click" Tag="😊 Happy" />
                                                    <MenuFlyoutItem Text="😐 Neutral" Click="MoodItem_Click" Tag="😐 Neutral" />
                                                    <MenuFlyoutItem Text="😢 Sad" Click="MoodItem_Click" Tag="😢 Sad" />
                                                    <MenuFlyoutItem Text="😫 Stressed" Click="MoodItem_Click" Tag="😫 Stressed" />
                                                    <MenuFlyoutItem Text="😡 Angry" Click="MoodItem_Click" Tag="😡 Angry" />
                                                    <MenuFlyoutSeparator />
                                                    <MenuFlyoutItem Text="None (Clear)" Click="MoodItem_Click" Tag="None" />
                                                </MenuFlyout>
                                            </Button.Flyout>
                                        </Button>

                                        <!-- Category Badge Button -->
                                        <Button x:Name="ChangeCategoryButton" Background="Transparent" BorderThickness="1" BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}" Padding="10,6" CornerRadius="12" ToolTipService.ToolTip="Change Category">
                                            <Button.Content>
                                                <StackPanel Orientation="Horizontal" Spacing="8" VerticalAlignment="Center">
                                                    <FontIcon x:Name="CategoryBadgeIcon" Glyph="&#xE8B7;" FontFamily="{ThemeResource SymbolThemeFontFamily}" FontSize="14" />
                                                    <TextBlock x:Name="CategoryBadgeText" Text="Personal" FontSize="12" FontWeight="SemiBold" Foreground="{ThemeResource TextFillColorSecondaryBrush}" />
                                                    <FontIcon Glyph="&#xE972;" FontFamily="{ThemeResource SymbolThemeFontFamily}" FontSize="8" Foreground="{ThemeResource TextFillColorTertiaryBrush}" Margin="2,0,0,0" />
                                                </StackPanel>
                                            </Button.Content>
                                            <Button.Flyout>
                                                <MenuFlyout x:Name="ChangeCategoryMenu" Opening="MoveCategoryMenu_Opening" />
                                            </Button.Flyout>
                                        </Button>
                                    </StackPanel>
                                </Grid>

                                <!-- Divider line -->
                                <Border Height="1" Background="{ThemeResource CardStrokeColorDefaultBrush}" HorizontalAlignment="Stretch" />

                                <!-- Title Input (Borderless) -->
                                <TextBox x:Name="TitleTextBox" TextChanged="TitleTextBox_TextChanged" PlaceholderText="Untitled Journal Entry" FontSize="32" FontWeight="Bold" Background="Transparent" BorderThickness="0" Padding="0" Margin="0,0,0,4" SelectionHighlightColor="{ThemeResource SystemAccentColor}">
                                    <TextBox.Resources>
                                        <Thickness x:Key="TextControlBorderThemeThickness">0</Thickness>
                                        <Thickness x:Key="TextControlBorderThemeThicknessFocused">0</Thickness>
                                        <Thickness x:Key="TextControlBorderThemeThicknessPointerOver">0</Thickness>
                                        <SolidColorBrush x:Key="TextControlBackground" Color="Transparent" />
                                        <SolidColorBrush x:Key="TextControlBackgroundPointerOver" Color="Transparent" />
                                        <SolidColorBrush x:Key="TextControlBackgroundFocused" Color="Transparent" />
                                        <SolidColorBrush x:Key="TextControlBackgroundDisabled" Color="Transparent" />
                                        <SolidColorBrush x:Key="TextControlBorderBrush" Color="Transparent" />
                                        <SolidColorBrush x:Key="TextControlBorderBrushPointerOver" Color="Transparent" />
                                        <SolidColorBrush x:Key="TextControlBorderBrushFocused" Color="Transparent" />
                                        <SolidColorBrush x:Key="TextControlBorderBrushDisabled" Color="Transparent" />
                                    </TextBox.Resources>
                                </TextBox>

                                 <!-- Content Editor Grid (Supports side-by-side live markdown preview) -->
                                 <Grid x:Name="EditorSplitGrid" HorizontalAlignment="Stretch" VerticalAlignment="Stretch">
                                     <Grid.ColumnDefinitions>
                                         <ColumnDefinition x:Name="EditorColumn" Width="*" />
                                         <ColumnDefinition x:Name="PreviewColumn" Width="0" />
                                     </Grid.ColumnDefinitions>

                                     <!-- Left: NoteRichEditBox -->
                                     <RichEditBox x:Name="NoteRichEditBox" Grid.Column="0" Foreground="{ThemeResource TextFillColorPrimaryBrush}" TextChanged="NoteRichEditBox_TextChanged" SelectionChanged="NoteRichEditBox_SelectionChanged" PlaceholderText="Start writing your thoughts here..." MinHeight="500" Background="Transparent" BorderThickness="0" Padding="0" FontSize="16" VerticalAlignment="Stretch" HorizontalAlignment="Stretch" ScrollViewer.VerticalScrollBarVisibility="Disabled" DoubleTapped="NoteRichEditBox_DoubleTapped" CanDrag="True" AllowDrop="True">
                                         <RichEditBox.ContextFlyout>
                                             <MenuFlyout x:Name="EditorContextFlyout" Opening="EditorContextFlyout_Opening">
                                                 <MenuFlyoutItem Text="Cut" Click="ContextCut_Click">
                                                     <MenuFlyoutItem.Icon>
                                                         <FontIcon Glyph="&#xE8C6;" FontFamily="{ThemeResource SymbolThemeFontFamily}" />
                                                     </MenuFlyoutItem.Icon>
                                                 </MenuFlyoutItem>
                                                 <MenuFlyoutItem Text="Copy" Click="ContextCopy_Click">
                                                     <MenuFlyoutItem.Icon>
                                                         <FontIcon Glyph="&#xE8C8;" FontFamily="{ThemeResource SymbolThemeFontFamily}" />
                                                     </MenuFlyoutItem.Icon>
                                                 </MenuFlyoutItem>
                                                 <MenuFlyoutItem Text="Paste" Click="ContextPaste_Click">
                                                     <MenuFlyoutItem.Icon>
                                                         <FontIcon Glyph="&#xE77F;" FontFamily="{ThemeResource SymbolThemeFontFamily}" />
                                                     </MenuFlyoutItem.Icon>
                                                 </MenuFlyoutItem>
                                                 <MenuFlyoutSeparator x:Name="EditorContextSeparator" />
                                                 <MenuFlyoutItem x:Name="ContextResizeImage" Text="Resize Image..." Click="ContextResizeImage_Click">
                                                     <MenuFlyoutItem.Icon>
                                                         <FontIcon Glyph="&#xE7AD;" FontFamily="{ThemeResource SymbolThemeFontFamily}" />
                                                     </MenuFlyoutItem.Icon>
                                                 </MenuFlyoutItem>
                                             </MenuFlyout>
                                         </RichEditBox.ContextFlyout>
                                         <RichEditBox.Resources>
                                             <Thickness x:Key="TextControlBorderThemeThickness">0</Thickness>
                                             <Thickness x:Key="TextControlBorderThemeThicknessFocused">0</Thickness>
                                             <Thickness x:Key="TextControlBorderThemeThicknessPointerOver">0</Thickness>
                                             <SolidColorBrush x:Key="TextControlBackground" Color="Transparent" />
                                             <SolidColorBrush x:Key="TextControlBackgroundPointerOver" Color="Transparent" />
                                             <SolidColorBrush x:Key="TextControlBackgroundFocused" Color="Transparent" />
                                             <SolidColorBrush x:Key="TextControlBackgroundDisabled" Color="Transparent" />
                                             <SolidColorBrush x:Key="TextControlBorderBrush" Color="Transparent" />
                                             <SolidColorBrush x:Key="TextControlBorderBrushPointerOver" Color="Transparent" />
                                             <SolidColorBrush x:Key="TextControlBorderBrushFocused" Color="Transparent" />
                                             <SolidColorBrush x:Key="TextControlBorderBrushDisabled" Color="Transparent" />
                                         </RichEditBox.Resources>
                                     </RichEditBox>

                                     <!-- Vertical Divider Line -->
                                     <Border x:Name="EditorPreviewDivider" Grid.Column="0" HorizontalAlignment="Right" Width="1" Background="{ThemeResource CardStrokeColorDefaultBrush}" Margin="10,0" Visibility="Collapsed" />

                                     <!-- Right: Live Markdown Preview -->
                                     <RichTextBlock x:Name="MarkdownPreviewTextBlock" Grid.Column="1" Visibility="Collapsed" MinHeight="500" FontSize="16" HorizontalAlignment="Stretch" VerticalAlignment="Stretch" Padding="20,0,0,0" IsTextSelectionEnabled="True" />
                                 </Grid>
                            </StackPanel>
                        </Grid>
                    </ScrollViewer>

                    <!-- Placeholder panel when no note is selected -->
                    <Grid x:Name="NoNotePlaceholder" Grid.Row="1" HorizontalAlignment="Center" VerticalAlignment="Center">
                        <StackPanel Spacing="16" HorizontalAlignment="Center">
                            <Image Source="ms-appx:///Assets/Square150x150Logo.scale-200.png" Width="96" Height="96" HorizontalAlignment="Center" Margin="0,0,0,8" />
                            <TextBlock Text="No Journal Entry Selected" FontSize="18" FontWeight="SemiBold" Foreground="{ThemeResource TextFillColorSecondaryBrush}" HorizontalAlignment="Center" />
                            <Button x:Name="PlaceholderNewNoteButton" Content="Create New Entry" Click="NewNoteButton_Click" HorizontalAlignment="Center" Style="{StaticResource AccentButtonStyle}" CornerRadius="16" Padding="16,8" />
                        </StackPanel>
                    </Grid>

                    <!-- Status Bar (Only in Editor) -->
                    <Grid x:Name="EditorStatusBar" Grid.Row="3" Background="Transparent" Height="28" BorderThickness="0,1,0,0" BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}" Padding="16,0" VerticalAlignment="Bottom" Visibility="Collapsed">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="Auto" />
                            <ColumnDefinition Width="*" />
                        </Grid.ColumnDefinitions>
                        
                        <!-- Left Status Message -->
                        <StackPanel Grid.Column="0" Orientation="Horizontal" Spacing="8" VerticalAlignment="Center">
                            <FontIcon Glyph="&#xE73E;" FontFamily="{ThemeResource SymbolThemeFontFamily}" FontSize="10" Foreground="{ThemeResource TextFillColorSecondaryBrush}" />
                            <TextBlock x:Name="StatusMessageTextBlock" Text="All changes saved locally" FontSize="11" Foreground="{ThemeResource TextFillColorSecondaryBrush}" VerticalAlignment="Center" />
                        </StackPanel>

                        <!-- Center Note Count -->
                        <TextBlock x:Name="EntryCountTextBlock" Grid.Column="1" Text="0 entries" FontSize="11" FontWeight="SemiBold" Foreground="{ThemeResource TextFillColorSecondaryBrush}" HorizontalAlignment="Center" VerticalAlignment="Center" />

                        <!-- Right Word / Character Count -->
                        <TextBlock x:Name="WordCountTextBlock" Grid.Column="2" Text="Word Count: 0 | Characters: 0" FontSize="11" Foreground="{ThemeResource TextFillColorSecondaryBrush}" HorizontalAlignment="Right" VerticalAlignment="Center" />
                    </Grid>
                </Grid>

                <!-- Undo Trash InfoBar overlay (bottom of editor column) -->
                <InfoBar x:Name="UndoTrashInfoBar"
                         Grid.Column="2"
                         IsOpen="False"
                         Severity="Informational"
                         Title=""
                         Message="Moved to Trash"
                         IsClosable="True"
                         VerticalAlignment="Bottom"
                         HorizontalAlignment="Stretch"
                         Margin="16,0,16,40"
                         CornerRadius="8">
                    <InfoBar.ActionButton>
                        <Button x:Name="UndoTrashButton" Content="Undo" Click="UndoTrashButton_Click"
                                Style="{StaticResource AccentButtonStyle}" Padding="12,4" />
                    </InfoBar.ActionButton>
                </InfoBar>
            </Grid>
            
            <!-- Settings Grid -->
            <Grid x:Name="SettingsGrid" Visibility="Collapsed" Padding="0,24,0,0">
                <!-- Scrollable Settings Content -->
                <ScrollViewer VerticalScrollBarVisibility="Auto" HorizontalAlignment="Stretch">
                    <StackPanel MaxWidth="900"
                                HorizontalAlignment="Center"
                                Padding="40,40,40,40"
                                Spacing="8">
                        
                        <!-- Settings Header -->
                        <TextBlock Text="Settings" FontSize="28" FontWeight="Bold" Margin="0,0,0,16" />

                        <!-- ── Appearance & behavior ── -->
                        <StackPanel Spacing="4" HorizontalAlignment="Stretch">
                            <TextBlock Text="Appearance &amp; behavior" FontSize="12" FontWeight="SemiBold"
                                       Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                                       Margin="4,0,0,8" CharacterSpacing="50" />

                            <!-- App Theme -->
                            <Border Background="{ThemeResource CardBackgroundFillColorDefaultBrush}" BorderThickness="1" BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}" CornerRadius="8" Padding="16,12">
                                <Grid ColumnSpacing="32">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="Auto" />
                                        <ColumnDefinition Width="*" />
                                        <ColumnDefinition Width="Auto" />
                                    </Grid.ColumnDefinitions>
                                    <FontIcon Grid.Column="0" Glyph="&#xE790;" FontFamily="{ThemeResource SymbolThemeFontFamily}" FontSize="18" VerticalAlignment="Center" Width="24" />
                                    <StackPanel Grid.Column="1" VerticalAlignment="Center" Spacing="2">
                                        <TextBlock Text="App theme" FontSize="14" FontWeight="Medium" />
                                        <TextBlock Text="Select which app theme to display" FontSize="12" Foreground="{ThemeResource TextFillColorSecondaryBrush}" />
                                    </StackPanel>
                                    <ComboBox x:Name="ThemeComboBox" Grid.Column="2" Width="150" VerticalAlignment="Center" SelectionChanged="ThemeComboBox_SelectionChanged">
                                        <ComboBoxItem Content="Default" Tag="Default" IsSelected="True" />
                                        <ComboBoxItem Content="Light" Tag="Light" />
                                        <ComboBoxItem Content="Dark" Tag="Dark" />
                                    </ComboBox>
                                </Grid>
                            </Border>

                            <!-- Window Backdrop -->
                            <Border Background="{ThemeResource CardBackgroundFillColorDefaultBrush}" BorderThickness="1" BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}" CornerRadius="8" Padding="16,12">
                                <Grid ColumnSpacing="32">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="Auto" />
                                        <ColumnDefinition Width="*" />
                                        <ColumnDefinition Width="Auto" />
                                    </Grid.ColumnDefinitions>
                                    <FontIcon Grid.Column="0" Glyph="&#xE7F4;" FontFamily="{ThemeResource SymbolThemeFontFamily}" FontSize="18" VerticalAlignment="Center" Width="24" />
                                    <StackPanel Grid.Column="1" VerticalAlignment="Center" Spacing="2">
                                        <TextBlock Text="Window backdrop" FontSize="14" FontWeight="Medium" />
                                        <TextBlock Text="Select the material type for the app backdrop" FontSize="12" Foreground="{ThemeResource TextFillColorSecondaryBrush}" />
                                    </StackPanel>
                                    <ComboBox x:Name="BackdropComboBox" Grid.Column="2" Width="150" VerticalAlignment="Center" SelectionChanged="BackdropComboBox_SelectionChanged">
                                        <ComboBoxItem Content="Mica Alt" Tag="MicaAlt" />
                                        <ComboBoxItem Content="Mica" Tag="Mica" />
                                        <ComboBoxItem Content="Acrylic" Tag="Acrylic" />
                                    </ComboBox>
                                </Grid>
                            </Border>

                            <!-- Editor Default Font -->
                            <Border Background="{ThemeResource CardBackgroundFillColorDefaultBrush}" BorderThickness="1" BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}" CornerRadius="8" Padding="16,12">
                                <Grid ColumnSpacing="32">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="Auto" />
                                        <ColumnDefinition Width="*" />
                                        <ColumnDefinition Width="Auto" />
                                    </Grid.ColumnDefinitions>
                                    <FontIcon Grid.Column="0" Glyph="&#xE70F;" FontFamily="{ThemeResource SymbolThemeFontFamily}" FontSize="18" VerticalAlignment="Center" Width="24" />
                                    <StackPanel Grid.Column="1" VerticalAlignment="Center" Spacing="2">
                                        <TextBlock Text="Editor Default Font" FontSize="14" FontWeight="Medium" />
                                        <TextBlock Text="Select the default typeface for writing journal titles and entries" FontSize="12" Foreground="{ThemeResource TextFillColorSecondaryBrush}" />
                                    </StackPanel>
                                    <ComboBox x:Name="EditorFontComboBox" Grid.Column="2" Width="150" VerticalAlignment="Center" SelectionChanged="EditorFontComboBox_SelectionChanged">
                                        <ComboBoxItem Content="Segoe UI" Tag="Segoe UI" IsSelected="True" />
                                        <ComboBoxItem Content="Inter" Tag="Inter" />
                                        <ComboBoxItem Content="Roboto" Tag="Roboto" />
                                        <ComboBoxItem Content="Outfit" Tag="Outfit" />
                                        <ComboBoxItem Content="Courier New" Tag="Courier New" />
                                        <ComboBoxItem Content="Georgia" Tag="Georgia" />
                                        <ComboBoxItem Content="Consolas" Tag="Consolas" />
                                    </ComboBox>
                                </Grid>
                            </Border>

                            <!-- Editor Default Font Size -->
                            <Border Background="{ThemeResource CardBackgroundFillColorDefaultBrush}" BorderThickness="1" BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}" CornerRadius="8" Padding="16,12">
                                <Grid ColumnSpacing="32">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="Auto" />
                                        <ColumnDefinition Width="*" />
                                        <ColumnDefinition Width="Auto" />
                                    </Grid.ColumnDefinitions>
                                    <FontIcon Grid.Column="0" Glyph="&#xE8E9;" FontFamily="{ThemeResource SymbolThemeFontFamily}" FontSize="18" VerticalAlignment="Center" Width="24" />
                                    <StackPanel Grid.Column="1" VerticalAlignment="Center" Spacing="2">
                                        <TextBlock Text="Editor Default Font Size" FontSize="14" FontWeight="Medium" />
                                        <TextBlock Text="Select the default font size (px) for writing journal entries" FontSize="12" Foreground="{ThemeResource TextFillColorSecondaryBrush}" />
                                    </StackPanel>
                                    <Slider x:Name="EditorFontSizeSlider" Grid.Column="2" Width="180" VerticalAlignment="Center" Minimum="10" Maximum="28" Value="14.0" StepFrequency="1" ValueChanged="EditorFontSizeSlider_ValueChanged" />
                                </Grid>
                            </Border>

                            <!-- Auto-Save Interval -->
                            <Border Background="{ThemeResource CardBackgroundFillColorDefaultBrush}" BorderThickness="1" BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}" CornerRadius="8" Padding="16,12">
                                <Grid ColumnSpacing="32">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="Auto" />
                                        <ColumnDefinition Width="*" />
                                        <ColumnDefinition Width="Auto" />
                                    </Grid.ColumnDefinitions>
                                    <FontIcon Grid.Column="0" Glyph="&#xE916;" FontFamily="{ThemeResource SymbolThemeFontFamily}" FontSize="18" VerticalAlignment="Center" Width="24" />
                                    <StackPanel Grid.Column="1" VerticalAlignment="Center" Spacing="2">
                                        <TextBlock Text="Auto-Save Interval" FontSize="14" FontWeight="Medium" />
                                        <TextBlock Text="Adjust the background auto-save delay (seconds)" FontSize="12" Foreground="{ThemeResource TextFillColorSecondaryBrush}" />
                                    </StackPanel>
                                    <Slider x:Name="AutoSaveSlider" Grid.Column="2" Width="180" VerticalAlignment="Center" Minimum="1" Maximum="10" Value="5.0" StepFrequency="0.5" ValueChanged="AutoSaveSlider_ValueChanged" />
                                </Grid>
                            </Border>
                        </StackPanel>

                        <!-- ── Services & Sync ── -->
                        <StackPanel Spacing="4">
                            <TextBlock Text="Services &amp; Sync" FontSize="12" FontWeight="SemiBold"
                                       Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                                       Margin="4,8,0,8" CharacterSpacing="50" />

                            <!-- Unsplash API Integration -->
                            <Expander IsExpanded="False" ExpandDirection="Down" HorizontalAlignment="Stretch" HorizontalContentAlignment="Stretch">
                                <Expander.Header>
                                    <Grid ColumnSpacing="32" Padding="4,8">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="Auto" />
                                            <ColumnDefinition Width="*" />
                                            <ColumnDefinition Width="Auto" />
                                        </Grid.ColumnDefinitions>
                                        <FontIcon Grid.Column="0" Glyph="&#xEB9F;" FontFamily="{ThemeResource SymbolThemeFontFamily}" FontSize="18" VerticalAlignment="Center" Width="24" />
                                        <StackPanel Grid.Column="1" VerticalAlignment="Center" Spacing="2">
                                            <TextBlock Text="Unsplash API Integration" FontSize="14" FontWeight="Medium" />
                                            <TextBlock Text="Configure a custom Unsplash Access Key for cover banners" FontSize="12" Foreground="{ThemeResource TextFillColorSecondaryBrush}" />
                                        </StackPanel>
                                        <Button x:Name="UnsplashKeyButton" Content="Get Key" Grid.Column="2" Click="GetUnsplashKeyButton_Click" VerticalAlignment="Center" Style="{StaticResource AccentButtonStyle}" />
                                    </Grid>
                                </Expander.Header>
                                <PasswordBox x:Name="UnsplashTokenPasswordBox" Margin="40,0,0,8" PasswordChanged="UnsplashTokenPasswordBox_PasswordChanged" PlaceholderText="Paste your access key here..." PasswordRevealMode="Hidden" Header="Unsplash Access Key" HorizontalAlignment="Stretch" />
                            </Expander>

                            <!-- GitHub Sync & Backup -->
                            <Expander IsExpanded="False" ExpandDirection="Down" HorizontalAlignment="Stretch" HorizontalContentAlignment="Stretch">
                                <Expander.Header>
                                    <Grid ColumnSpacing="32" Padding="4,8">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="Auto" />
                                            <ColumnDefinition Width="*" />
                                            <ColumnDefinition Width="Auto" />
                                        </Grid.ColumnDefinitions>
                                        <FontIcon Grid.Column="0" Glyph="&#xE895;" FontFamily="{ThemeResource SymbolThemeFontFamily}" FontSize="18" VerticalAlignment="Center" Width="24" />
                                        <StackPanel Grid.Column="1" VerticalAlignment="Center" Spacing="2">
                                            <TextBlock Text="GitHub Sync &amp; Backup" FontSize="14" FontWeight="Medium" />
                                            <TextBlock Text="Backup and sync your journal entries to a private GitHub repository" FontSize="12" Foreground="{ThemeResource TextFillColorSecondaryBrush}" />
                                        </StackPanel>
                                        <StackPanel Grid.Column="2" Orientation="Horizontal" Spacing="8" VerticalAlignment="Center">
                                            <Button x:Name="GitHubSyncButton" Content="Sync" Click="GitHubSyncButton_Click" Style="{StaticResource AccentButtonStyle}" />
                                            <Button x:Name="GitHubDisconnectButton" Content="Disconnect" Click="GitHubDisconnectButton_Click" Visibility="Collapsed" />
                                        </StackPanel>
                                    </Grid>
                                </Expander.Header>
                                <StackPanel Spacing="12" Margin="40,0,0,8">
                                    <Grid ColumnSpacing="12">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="*" />
                                            <ColumnDefinition Width="*" />
                                        </Grid.ColumnDefinitions>
                                        <PasswordBox x:Name="GitHubTokenPasswordBox" Header="GitHub Personal Access Token (PAT)" PlaceholderText="ghp_..." PasswordRevealMode="Hidden" Grid.Column="0" PasswordChanged="GitHubTokenPasswordBox_PasswordChanged" />
                                        <TextBox x:Name="GitHubRepoTextBox" Header="Repository Name" Text="My-JournalApp-Backup" Grid.Column="1" TextChanged="GitHubRepoTextBox_TextChanged" />
                                    </Grid>
                                    <StackPanel x:Name="GitHubStatusPanel" Spacing="4" Visibility="Collapsed">
                                        <TextBlock x:Name="GitHubStatusTitle" Text="Status: Connected" FontSize="13" FontWeight="Medium" />
                                        <TextBlock x:Name="GitHubStatusDetails" Text="Last synced: Never" FontSize="11" Foreground="{ThemeResource TextFillColorSecondaryBrush}" />
                                        <ProgressBar x:Name="GitHubSyncProgressBar" IsIndeterminate="False" Height="4" Value="0" Margin="0,4,0,0" Visibility="Collapsed" />
                                    </StackPanel>
                                </StackPanel>
                            </Expander>
                        </StackPanel>

                        <!-- ── Security & Privacy ── -->
                        <StackPanel Spacing="4">
                            <TextBlock Text="Security &amp; Privacy" FontSize="12" FontWeight="SemiBold"
                                       Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                                       Margin="4,8,0,8" CharacterSpacing="50" />

                            <!-- Master Password & Category Locking -->
                            <Expander IsExpanded="False" ExpandDirection="Down" HorizontalAlignment="Stretch" HorizontalContentAlignment="Stretch">
                                <Expander.Header>
                                    <Grid ColumnSpacing="32" Padding="4,8">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="Auto" />
                                            <ColumnDefinition Width="*" />
                                        </Grid.ColumnDefinitions>
                                        <FontIcon Grid.Column="0" Glyph="&#xE727;" FontFamily="{ThemeResource SymbolThemeFontFamily}" FontSize="18" VerticalAlignment="Center" Width="24" />
                                        <StackPanel Grid.Column="1" VerticalAlignment="Center" Spacing="2">
                                            <TextBlock Text="Category Encryption &amp; Password Locking" FontSize="14" FontWeight="Medium" />
                                            <TextBlock Text="Secure private journal categories using AES-256 password protection" FontSize="12" Foreground="{ThemeResource TextFillColorSecondaryBrush}" />
                                        </StackPanel>
                                    </Grid>
                                </Expander.Header>
                                <StackPanel Spacing="12" Margin="40,0,0,8">
                                    <PasswordBox x:Name="MasterPasswordBox" Header="Set Master Password" PlaceholderText="Enter password..." PasswordRevealMode="Hidden" PasswordChanged="MasterPasswordBox_PasswordChanged" />
                                    
                                    <TextBlock Text="Select categories to encrypt and lock:" FontSize="13" FontWeight="Medium" Margin="0,4,0,0" />
                                    <StackPanel x:Name="LockedCategoriesStackPanel" Spacing="6">
                                        <!-- Checkboxes will be dynamically loaded here in C# -->
                                    </StackPanel>
                                </StackPanel>
                            </Expander>
                        </StackPanel>

                        <!-- ── Maintenance & Data ── -->
                        <StackPanel Spacing="4">
                            <TextBlock Text="Maintenance &amp; Data" FontSize="12" FontWeight="SemiBold"
                                       Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                                       Margin="4,8,0,8" CharacterSpacing="50" />

                            <!-- Data Management -->
                            <Expander IsExpanded="False" ExpandDirection="Down" HorizontalAlignment="Stretch" HorizontalContentAlignment="Stretch">
                                <Expander.Header>
                                    <Grid ColumnSpacing="32" Padding="4,8">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="Auto" />
                                            <ColumnDefinition Width="*" />
                                        </Grid.ColumnDefinitions>
                                        <FontIcon Grid.Column="0" Glyph="&#xE909;" FontFamily="{ThemeResource SymbolThemeFontFamily}" FontSize="18" VerticalAlignment="Center" Width="24" />
                                        <StackPanel Grid.Column="1" VerticalAlignment="Center" Spacing="2">
                                            <TextBlock Text="Data Management" FontSize="14" FontWeight="Medium" />
                                            <TextBlock Text="Clear local files, reset preferences, or export your entries" FontSize="12" Foreground="{ThemeResource TextFillColorSecondaryBrush}" />
                                        </StackPanel>
                                    </Grid>
                                </Expander.Header>
                                <StackPanel Orientation="Horizontal" Spacing="8" Margin="40,0,0,8">
                                    <Button Content="Clear All Data" Click="ClearAllDataButton_Click" Background="#FF3B30" BorderBrush="#FF3B30" Foreground="White" />
                                    <Button Content="Restore to Default" Click="RestoreToDefaultButton_Click" />
                                    <Button Content="Export Journal Data" Click="ExportDataButton_Click" />
                                </StackPanel>
                            </Expander>

                            <!-- Updates -->
                            <Border Background="{ThemeResource CardBackgroundFillColorDefaultBrush}" BorderThickness="1" BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}" CornerRadius="8" Padding="16,12">
                                <Grid ColumnSpacing="32">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="Auto" />
                                        <ColumnDefinition Width="*" />
                                        <ColumnDefinition Width="Auto" />
                                    </Grid.ColumnDefinitions>
                                    <FontIcon Grid.Column="0" Glyph="&#xE896;" FontFamily="{ThemeResource SymbolThemeFontFamily}" FontSize="18" VerticalAlignment="Center" Width="24" />
                                    <StackPanel Grid.Column="1" VerticalAlignment="Center" Spacing="2">
                                        <TextBlock x:Name="UpdateStatusTextBlock" Text="You're up to date!" FontSize="14" FontWeight="Medium" />
                                        <TextBlock x:Name="LastCheckedTextBlock" Text="Last checked: Just now" FontSize="12" Foreground="{ThemeResource TextFillColorSecondaryBrush}" />
                                    </StackPanel>
                                    <Button x:Name="CheckUpdatesButton" Grid.Column="2" Click="CheckUpdatesButton_Click" VerticalAlignment="Center" Style="{StaticResource AccentButtonStyle}" MinWidth="110">
                                        <Button.Content>
                                            <StackPanel x:Name="CheckNowContent" Orientation="Horizontal" Spacing="8">
                                                <TextBlock Text="Check Now" VerticalAlignment="Center" />
                                            </StackPanel>
                                        </Button.Content>
                                    </Button>
                                </Grid>
                            </Border>
                        </StackPanel>

                        <!-- ── About ── -->
                        <StackPanel Spacing="4">
                            <TextBlock Text="About" FontSize="12" FontWeight="SemiBold"
                                       Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                                       Margin="4,8,0,8" CharacterSpacing="50" />

                            <!-- About Card -->
                            <Expander x:Name="AboutCardBorder" IsExpanded="False" ExpandDirection="Down" HorizontalAlignment="Stretch" HorizontalContentAlignment="Stretch">
                                <Expander.Header>
                                    <Grid ColumnSpacing="32" Padding="4,8">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="Auto" />
                                            <ColumnDefinition Width="*" />
                                            <ColumnDefinition Width="Auto" />
                                        </Grid.ColumnDefinitions>
                                        <Image Grid.Column="0" Source="ms-appx:///Assets/AppIcon.ico" Width="28" Height="28" VerticalAlignment="Center" />
                                        <StackPanel Grid.Column="1" VerticalAlignment="Center" Spacing="2">
                                            <TextBlock Text="JournalApp" FontSize="14" FontWeight="Medium" />
                                            <TextBlock Text="© 2026 JournalApp. All rights reserved." FontSize="12" Foreground="{ThemeResource TextFillColorSecondaryBrush}" />
                                        </StackPanel>
                                        <TextBlock x:Name="AboutVersionTextBlock" Grid.Column="2" Text="1.0.5.0" FontSize="13" VerticalAlignment="Center" Foreground="{ThemeResource TextFillColorSecondaryBrush}" />
                                    </Grid>
                                </Expander.Header>
                                <StackPanel x:Name="AboutDetailsPanel" Spacing="8" Margin="44,0,0,8">
                                    <TextBlock Text="JournalApp is a premium, distraction-free journaling application built using WinUI 3 and the Windows App SDK. It helps you keep track of your thoughts, ideas, and reflections with rich text editing, auto-saving, visual cover banners, and custom categories." FontSize="13" TextWrapping="Wrap" LineHeight="18" Foreground="{ThemeResource TextFillColorPrimaryBrush}" />
                                    <TextBlock Text="Designed, Developed and Published by Amitendu Bikash Dhusiya." FontSize="12" Foreground="{ThemeResource TextFillColorSecondaryBrush}" />
                                </StackPanel>
                            </Expander>
                        </StackPanel>

                        <!-- Save Settings Button -->
                        <Border Background="{ThemeResource CardBackgroundFillColorDefaultBrush}" BorderThickness="1" BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}" CornerRadius="8" Padding="16,14">
                            <Grid>
                                <StackPanel VerticalAlignment="Center" Spacing="2">
                                    <TextBlock Text="Save Settings" FontSize="14" FontWeight="Medium" />
                                    <TextBlock Text="Apply and persist all your current setting preferences" FontSize="12" Foreground="{ThemeResource TextFillColorSecondaryBrush}" />
                                </StackPanel>
                                <Button x:Name="SaveSettingsButton" IsEnabled="False" Grid.Column="1" Click="SaveSettingsButton_Click"
                                        HorizontalAlignment="Right" VerticalAlignment="Center"
                                        Style="{StaticResource AccentButtonStyle}" MinWidth="120">
                                    <StackPanel Orientation="Horizontal" Spacing="8">
                                        <FontIcon x:Name="SaveSettingsIcon" Glyph="&#xE74E;" FontFamily="{ThemeResource SymbolThemeFontFamily}" FontSize="13" />
                                        <TextBlock x:Name="SaveSettingsText" Text="Save Settings" />
                                    </StackPanel>
                                </Button>
                            </Grid>
                        </Border>
                        <Border Height="32" />
                    </StackPanel>
                </ScrollViewer>
            </Grid>

            <!-- GitHub Commit History Grid -->
            <Grid x:Name="GitHubGrid" Visibility="Collapsed" Padding="0,24,0,0">
                <!-- Scrollable Content -->
                <ScrollViewer VerticalScrollBarVisibility="Auto" HorizontalAlignment="Stretch">
                    <StackPanel MaxWidth="900"
                                HorizontalAlignment="Center"
                                Padding="40,40,40,40"
                                Spacing="8">
                        
                        <!-- Header inside the scroll stack -->
                        <Grid Margin="0,0,0,16" HorizontalAlignment="Stretch">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="Auto" />
                            </Grid.ColumnDefinitions>
                            <TextBlock Text="GitHub Sync History" FontSize="28" FontWeight="Bold" VerticalAlignment="Center" />
                            <Button x:Name="RefreshGitHubHistoryBtn" Grid.Column="1" Click="RefreshGitHubHistoryBtn_Click" Style="{StaticResource AccentButtonStyle}" Padding="12,6" CornerRadius="4">
                                <StackPanel Orientation="Horizontal" Spacing="8">
                                    <FontIcon Glyph="&#xE72C;" FontSize="13" />
                                    <TextBlock Text="Refresh History" />
                                </StackPanel>
                            </Button>
                        </Grid>

                        <StackPanel Spacing="24" HorizontalAlignment="Stretch">
                        
                        <!-- Commit Graph Card -->
                        <Border Background="{ThemeResource CardBackgroundFillColorDefaultBrush}" BorderThickness="1" BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}" CornerRadius="8" Padding="20">
                            <StackPanel Spacing="16">
                                <TextBlock Text="Commit Activity (Last 7 Days with commits)" FontSize="16" FontWeight="SemiBold" />
                                
                                <!-- Bar Chart Container -->
                                <Grid Height="150" HorizontalAlignment="Stretch">
                                    <Grid.RowDefinitions>
                                        <RowDefinition Height="*" />
                                        <RowDefinition Height="Auto" />
                                    </Grid.RowDefinitions>
                                    
                                    <!-- Y Axis line & bars -->
                                    <Border Grid.Row="0" BorderThickness="0,0,0,1" BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}" Margin="0,0,0,8" VerticalAlignment="Stretch">
                                        <StackPanel x:Name="CommitChartContainer" Orientation="Horizontal" Spacing="24" HorizontalAlignment="Center" Height="130" VerticalAlignment="Bottom" />
                                    </Border>
                                </Grid>
                            </StackPanel>
                        </Border>

                        <!-- Commits List -->
                        <TextBlock Text="Recent Commits" FontSize="18" FontWeight="SemiBold" Margin="0,12,0,0" />
                        
                        <ProgressBar x:Name="GitHubHistoryProgressBar" IsIndeterminate="True" Visibility="Collapsed" />
                        <TextBlock x:Name="GitHubHistoryErrorText" Foreground="Red" Visibility="Collapsed" TextWrapping="Wrap" />

                        <ListView x:Name="GitHubCommitsListView" SelectionMode="None" Background="Transparent" IsItemClickEnabled="False">
                            <ListView.ItemTemplate>
                                <DataTemplate>
                                    <Border Background="{ThemeResource CardBackgroundFillColorDefaultBrush}" BorderThickness="1" BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}" CornerRadius="8" Margin="0,0,0,8" Padding="16,12" HorizontalAlignment="Stretch">
                                        <Grid ColumnSpacing="16">
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="Auto" />
                                                <ColumnDefinition Width="*" />
                                                <ColumnDefinition Width="Auto" />
                                            </Grid.ColumnDefinitions>
                                            
                                            <!-- Left: Avatar or commit icon -->
                                            <Border Width="36" Height="36" Background="{ThemeResource AccentFillColorDefaultBrush}" CornerRadius="18" VerticalAlignment="Center">
                                                <FontIcon Glyph="&#xEC27;" Foreground="White" FontSize="16" />
                                            </Border>

                                            <!-- Middle: Commit message, author, SHA -->
                                            <StackPanel Grid.Column="1" Spacing="4" VerticalAlignment="Center">
                                                <TextBlock Text="{Binding Message}" FontSize="14" FontWeight="SemiBold" TextWrapping="Wrap" />
                                                <StackPanel Orientation="Horizontal" Spacing="8">
                                                    <TextBlock Text="{Binding Author}" FontSize="12" Foreground="{ThemeResource TextFillColorSecondaryBrush}" />
                                                    <TextBlock Text="•" FontSize="12" Foreground="{ThemeResource TextFillColorSecondaryBrush}" />
                                                    <TextBlock Text="{Binding DateFormatted}" FontSize="12" Foreground="{ThemeResource TextFillColorSecondaryBrush}" />
                                                </StackPanel>
                                            </StackPanel>

                                            <!-- Right: SHA badge -->
                                            <Border Grid.Column="2" Background="{ThemeResource ControlFillColorDefaultBrush}" CornerRadius="4" Padding="6,2" VerticalAlignment="Center">
                                                <TextBlock Text="{Binding ShortSha}" FontSize="11" FontFamily="Consolas" Foreground="{ThemeResource TextFillColorSecondaryBrush}" />
                                            </Border>
                                        </Grid>
                                    </Border>
                                </DataTemplate>
                            </ListView.ItemTemplate>
                        </ListView>
                    </StackPanel>
                </StackPanel>
            </ScrollViewer>
        </Grid>

            <!-- Stats Grid -->
            <Grid x:Name="StatsGrid" Visibility="Collapsed" Padding="0,24,0,0">
                <!-- Scrollable Content -->
                <ScrollViewer VerticalScrollBarVisibility="Auto" HorizontalAlignment="Stretch">
                    <StackPanel MaxWidth="900"
                                HorizontalAlignment="Center"
                                Padding="40,40,40,40"
                                Spacing="8">
                        
                        <!-- Header inside scroll stack -->
                        <TextBlock Text="Writing Stats &amp; Insights" FontSize="28" FontWeight="Bold" Margin="0,0,0,16" />

                        <StackPanel Spacing="24" HorizontalAlignment="Stretch">
                        <!-- Contribution Graph Card -->
                        <Border Background="{ThemeResource CardBackgroundFillColorDefaultBrush}" BorderThickness="1" BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}" CornerRadius="8" Padding="20">
                            <StackPanel Spacing="16">
                                <TextBlock Text="Writing Activity" FontSize="16" FontWeight="SemiBold" />
                                <ScrollViewer HorizontalScrollBarVisibility="Auto" VerticalScrollBarVisibility="Disabled" Padding="0,0,0,8">
                                    <Grid x:Name="ContributionGrid" ColumnSpacing="3" RowSpacing="3" HorizontalAlignment="Left" />
                                </ScrollViewer>
                                <!-- Legend and Streaks -->
                                <Grid ColumnSpacing="20">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="Auto" />
                                        <ColumnDefinition Width="*" />
                                    </Grid.ColumnDefinitions>
                                    <StackPanel Grid.Column="0" Orientation="Horizontal" Spacing="6" VerticalAlignment="Center">
                                        <TextBlock Text="Less" FontSize="12" Foreground="{ThemeResource TextFillColorSecondaryBrush}" VerticalAlignment="Center" />
                                        <Rectangle Width="10" Height="10" Fill="#15FFFFFF" RadiusX="2" RadiusY="2" />
                                        <Rectangle Width="10" Height="10" Fill="#FF1b4c2b" RadiusX="2" RadiusY="2" />
                                        <Rectangle Width="10" Height="10" Fill="#FF2e6930" RadiusX="2" RadiusY="2" />
                                        <Rectangle Width="10" Height="10" Fill="#FF398b3f" RadiusX="2" RadiusY="2" />
                                        <Rectangle Width="10" Height="10" Fill="#FF4dca57" RadiusX="2" RadiusY="2" />
                                        <TextBlock Text="More" FontSize="12" Foreground="{ThemeResource TextFillColorSecondaryBrush}" VerticalAlignment="Center" />
                                    </StackPanel>
                                    
                                    <StackPanel Grid.Column="1" Orientation="Horizontal" Spacing="24" HorizontalAlignment="Right">
                                        <StackPanel Orientation="Horizontal" Spacing="6">
                                            <TextBlock Text="🔥" FontSize="16" />
                                            <TextBlock Text="Current Streak:" FontSize="13" Foreground="{ThemeResource TextFillColorSecondaryBrush}" VerticalAlignment="Center" />
                                            <TextBlock x:Name="CurrentStreakStatsText" Text="0 days" FontSize="13" FontWeight="SemiBold" VerticalAlignment="Center" />
                                        </StackPanel>
                                        <StackPanel Orientation="Horizontal" Spacing="6">
                                            <TextBlock Text="⚡" FontSize="16" />
                                            <TextBlock Text="Longest Streak:" FontSize="13" Foreground="{ThemeResource TextFillColorSecondaryBrush}" VerticalAlignment="Center" />
                                            <TextBlock x:Name="LongestStreakStatsText" Text="0 days" FontSize="13" FontWeight="SemiBold" VerticalAlignment="Center" />
                                        </StackPanel>
                                        <StackPanel Orientation="Horizontal" Spacing="6">
                                            <TextBlock Text="✍️" FontSize="16" />
                                            <TextBlock Text="Total Entries:" FontSize="13" Foreground="{ThemeResource TextFillColorSecondaryBrush}" VerticalAlignment="Center" />
                                            <TextBlock x:Name="TotalEntriesStatsText" Text="0" FontSize="13" FontWeight="SemiBold" VerticalAlignment="Center" />
                                        </StackPanel>
                                    </StackPanel>
                                </Grid>
                            </StackPanel>
                        </Border>

                        <!-- Mood Statistics Card -->
                        <Border Background="{ThemeResource CardBackgroundFillColorDefaultBrush}" BorderThickness="1" BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}" CornerRadius="8" Padding="20">
                            <StackPanel Spacing="16">
                                <TextBlock Text="Mood Distribution" FontSize="16" FontWeight="SemiBold" />
                                <Grid ColumnSpacing="24" RowSpacing="12">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*" />
                                        <ColumnDefinition Width="*" />
                                    </Grid.ColumnDefinitions>
                                    
                                    <!-- Left Column: Happy, Neutral, Sad -->
                                    <StackPanel Grid.Column="0" Spacing="12">
                                        <StackPanel Spacing="4">
                                            <Grid>
                                                <TextBlock Text="😊 Happy" FontSize="13" FontWeight="Medium" />
                                                <TextBlock x:Name="MoodHappyCountText" Text="0 entries (0%)" FontSize="12" Foreground="{ThemeResource TextFillColorSecondaryBrush}" HorizontalAlignment="Right" />
                                            </Grid>
                                            <ProgressBar x:Name="MoodHappyProgress" Minimum="0" Maximum="100" Value="0" Foreground="#FFD700" Height="8" CornerRadius="4" />
                                        </StackPanel>
                                        <StackPanel Spacing="4">
                                            <Grid>
                                                <TextBlock Text="😐 Neutral" FontSize="13" FontWeight="Medium" />
                                                <TextBlock x:Name="MoodNeutralCountText" Text="0 entries (0%)" FontSize="12" Foreground="{ThemeResource TextFillColorSecondaryBrush}" HorizontalAlignment="Right" />
                                            </Grid>
                                            <ProgressBar x:Name="MoodNeutralProgress" Minimum="0" Maximum="100" Value="0" Foreground="#808080" Height="8" CornerRadius="4" />
                                        </StackPanel>
                                        <StackPanel Spacing="4">
                                            <Grid>
                                                <TextBlock Text="😢 Sad" FontSize="13" FontWeight="Medium" />
                                                <TextBlock x:Name="MoodSadCountText" Text="0 entries (0%)" FontSize="12" Foreground="{ThemeResource TextFillColorSecondaryBrush}" HorizontalAlignment="Right" />
                                            </Grid>
                                            <ProgressBar x:Name="MoodSadProgress" Minimum="0" Maximum="100" Value="0" Foreground="#1E90FF" Height="8" CornerRadius="4" />
                                        </StackPanel>
                                    </StackPanel>

                                    <!-- Right Column: Stressed, Angry, Unspecified -->
                                    <StackPanel Grid.Column="1" Spacing="12">
                                        <StackPanel Spacing="4">
                                            <Grid>
                                                <TextBlock Text="😫 Stressed" FontSize="13" FontWeight="Medium" />
                                                <TextBlock x:Name="MoodStressedCountText" Text="0 entries (0%)" FontSize="12" Foreground="{ThemeResource TextFillColorSecondaryBrush}" HorizontalAlignment="Right" />
                                            </Grid>
                                            <ProgressBar x:Name="MoodStressedProgress" Minimum="0" Maximum="100" Value="0" Foreground="#9370DB" Height="8" CornerRadius="4" />
                                        </StackPanel>
                                        <StackPanel Spacing="4">
                                            <Grid>
                                                <TextBlock Text="😡 Angry" FontSize="13" FontWeight="Medium" />
                                                <TextBlock x:Name="MoodAngryCountText" Text="0 entries (0%)" FontSize="12" Foreground="{ThemeResource TextFillColorSecondaryBrush}" HorizontalAlignment="Right" />
                                            </Grid>
                                            <ProgressBar x:Name="MoodAngryProgress" Minimum="0" Maximum="100" Value="0" Foreground="#FF4500" Height="8" CornerRadius="4" />
                                        </StackPanel>
                                        <StackPanel Spacing="4">
                                            <Grid>
                                                <TextBlock Text="📝 Unspecified" FontSize="13" FontWeight="Medium" />
                                                <TextBlock x:Name="MoodNoneCountText" Text="0 entries (0%)" FontSize="12" Foreground="{ThemeResource TextFillColorSecondaryBrush}" HorizontalAlignment="Right" />
                                            </Grid>
                                            <ProgressBar x:Name="MoodNoneProgress" Minimum="0" Maximum="100" Value="0" Foreground="#A9A9A9" Height="8" CornerRadius="4" />
                                        </StackPanel>
                                    </StackPanel>
                                </Grid>
                            </StackPanel>
                        </Border>
                    </StackPanel>
                </StackPanel>
            </ScrollViewer>
        </Grid>

            <!-- Gallery Grid -->
            <Grid x:Name="GalleryGrid" Visibility="Collapsed" Padding="0,24,0,0">
                <!-- Scrollable Content -->
                <ScrollViewer VerticalScrollBarVisibility="Auto" HorizontalAlignment="Stretch">
                    <StackPanel MaxWidth="900"
                                HorizontalAlignment="Center"
                                Padding="40,40,40,40"
                                Spacing="8">
                        
                        <!-- Header inside scroll stack -->
                        <TextBlock Text="Photo Gallery" FontSize="28" FontWeight="Bold" Margin="0,0,0,16" />

                        <GridView x:Name="GalleryGridView"
                              SelectionMode="None"
                              IsItemClickEnabled="True"
                              ItemClick="GalleryGridView_ItemClick">
                        <GridView.ItemTemplate>
                            <DataTemplate x:DataType="local:JournalNote">
                                <Grid Width="220" Height="160" CornerRadius="8" BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}" BorderThickness="1" Background="{ThemeResource CardBackgroundFillColorDefaultBrush}" Margin="6">
                                    <!-- Cover Image -->
                                    <Image Source="{x:Bind HeroImagePath, Converter={StaticResource ImagePathConverter}, Mode=OneWay}" Stretch="UniformToFill" HorizontalAlignment="Center" VerticalAlignment="Center" />
                                    <!-- Bottom text overlay -->
                                    <Border VerticalAlignment="Bottom" Height="50" Background="#AA000000" CornerRadius="0,0,8,8" Padding="8,6">
                                        <StackPanel Spacing="2">
                                            <TextBlock Text="{x:Bind Title}" Foreground="White" FontSize="12" FontWeight="SemiBold" TextTrimming="CharacterEllipsis" />
                                            <TextBlock Text="{x:Bind DateModifiedFormatted}" Foreground="#CCCCCC" FontSize="10" />
                                        </StackPanel>
                                    </Border>
                                </Grid>
                            </DataTemplate>
                        </GridView.ItemTemplate>
                    </GridView>
                </StackPanel>
            </ScrollViewer>
        </Grid>
        </Grid>
    </NavigationView>

        <!-- Edit Category Dialog (Placed in visual tree to fix WinUI 3 overlay bugs) -->
        <ContentDialog x:Name="EditCategoryDialog" Title="Edit Category" PrimaryButtonText="Save" CloseButtonText="Cancel" DefaultButton="Primary">
            <StackPanel Spacing="12" Width="280">
                <TextBlock Text="Select Icon" FontSize="12" Foreground="{ThemeResource TextFillColorSecondaryBrush}" />
                <GridView x:Name="EditIconSelectionGridView" SelectionMode="Single" Height="100" Padding="4" Background="{ThemeResource CardBackgroundFillColorDefaultBrush}" BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}" BorderThickness="1" CornerRadius="4">
                    <GridView.ItemTemplate>
                        <DataTemplate x:DataType="local:IconOption">
                            <FontIcon Glyph="{x:Bind Glyph}" FontFamily="{ThemeResource SymbolThemeFontFamily}" FontSize="18" Margin="8" ToolTipService.ToolTip="{x:Bind Name}" />
                        </DataTemplate>
                    </GridView.ItemTemplate>
                </GridView>

                <TextBlock Text="Select Color" FontSize="12" Foreground="{ThemeResource TextFillColorSecondaryBrush}" />
                <GridView x:Name="EditColorSelectionGridView" SelectionMode="Single" Height="70" Padding="4" Background="{ThemeResource CardBackgroundFillColorDefaultBrush}" BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}" BorderThickness="1" CornerRadius="4">
                    <GridView.ItemTemplate>
                        <DataTemplate x:DataType="local:ColorOption">
                            <Ellipse Width="20" Height="20" Fill="{x:Bind Hex, Converter={StaticResource HexToBrushConverter}}" Margin="6" ToolTipService.ToolTip="{x:Bind Name}" />
                        </DataTemplate>
                    </GridView.ItemTemplate>
                </GridView>
            </StackPanel>
        </ContentDialog>

        <!-- New Category Dialog (Placed in visual tree to fix WinUI 3 overlay bugs) -->
        <ContentDialog x:Name="NewCategoryDialog" Title="Create Category" PrimaryButtonText="Create" CloseButtonText="Cancel" DefaultButton="Primary">
            <StackPanel Spacing="12" Width="280">
                <TextBox x:Name="NewCategoryTextBox" PlaceholderText="Category Name" Header="Name" />
                
                <TextBlock Text="Select Icon" FontSize="12" Foreground="{ThemeResource TextFillColorSecondaryBrush}" />
                <GridView x:Name="IconSelectionGridView" SelectionMode="Single" Height="100" Padding="4" Background="{ThemeResource CardBackgroundFillColorDefaultBrush}" BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}" BorderThickness="1" CornerRadius="4">
                    <GridView.ItemTemplate>
                        <DataTemplate x:DataType="local:IconOption">
                            <FontIcon Glyph="{x:Bind Glyph}" FontFamily="{ThemeResource SymbolThemeFontFamily}" FontSize="18" Margin="8" ToolTipService.ToolTip="{x:Bind Name}" />
                        </DataTemplate>
                    </GridView.ItemTemplate>
                </GridView>

                <TextBlock Text="Select Color" FontSize="12" Foreground="{ThemeResource TextFillColorSecondaryBrush}" />
                <GridView x:Name="ColorSelectionGridView" SelectionMode="Single" Height="70" Padding="4" Background="{ThemeResource CardBackgroundFillColorDefaultBrush}" BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}" BorderThickness="1" CornerRadius="4">
                    <GridView.ItemTemplate>
                        <DataTemplate x:DataType="local:ColorOption">
                            <Ellipse Width="20" Height="20" Fill="{x:Bind Hex, Converter={StaticResource HexToBrushConverter}}" Margin="6" ToolTipService.ToolTip="{x:Bind Name}" />
                        </DataTemplate>
                    </GridView.ItemTemplate>
                </GridView>
            </StackPanel>
        </ContentDialog>

        <!-- Unsplash Search ContentDialog (Placed in visual tree to fix WinUI 3 overlay bugs) -->
        <ContentDialog x:Name="UnsplashSearchDialog" 
                       Title="Search Unsplash Banners"
                       PrimaryButtonText="Close"
                       DefaultButton="Primary">
            <ContentDialog.Resources>
                <Style x:Key="UnsplashImageCardStyle" TargetType="GridViewItem">
                    <Setter Property="Margin" Value="6" />
                    <Setter Property="Padding" Value="0" />
                </Style>
            </ContentDialog.Resources>
            
            <Grid Width="500" Height="400" RowSpacing="12">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="*" />
                </Grid.RowDefinitions>
                
                <Grid Grid.Row="0" ColumnSpacing="8">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="Auto" />
                    </Grid.ColumnDefinitions>
                    <TextBox x:Name="UnsplashSearchTextBox" PlaceholderText="Type search keywords (e.g. mountains, workspace)..." KeyDown="UnsplashSearchTextBox_KeyDown" Grid.Column="0" />
                    <Button x:Name="UnsplashSearchButton" Click="UnsplashSearchButton_Click" Grid.Column="1" Width="36" Height="32" Padding="0">
                        <Button.Content>
                            <FontIcon Glyph="&#xE721;" FontFamily="{ThemeResource SymbolThemeFontFamily}" FontSize="14" />
                        </Button.Content>
                    </Button>
                </Grid>
                
                <StackPanel Grid.Row="1" HorizontalAlignment="Center" VerticalAlignment="Center">
                    <ProgressRing x:Name="UnsplashProgressRing" IsActive="False" Visibility="Collapsed" Width="32" Height="32" Margin="0,6" />
                    <TextBlock x:Name="UnsplashErrorTextBlock" Foreground="Red" FontSize="12" HorizontalAlignment="Center" TextAlignment="Center" Visibility="Collapsed" TextWrapping="Wrap" MaxWidth="400" Margin="0,6" />
                </StackPanel>
                
                <ScrollViewer Grid.Row="2" VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Disabled">
                    <GridView x:Name="UnsplashResultsGridView" 
                               SelectionMode="None" 
                               ItemContainerStyle="{StaticResource UnsplashImageCardStyle}" 
                               IsItemClickEnabled="True" 
                               ItemClick="UnsplashResultsGridView_ItemClick">
                        <GridView.ItemTemplate>
                            <DataTemplate>
                                <Grid Width="144" Height="96" CornerRadius="8" BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}" BorderThickness="1" Background="{ThemeResource CardBackgroundFillColorDefaultBrush}">
                                    <Image Source="{Binding ThumbUrl}" Stretch="UniformToFill" HorizontalAlignment="Center" VerticalAlignment="Center" />
                                    <Border VerticalAlignment="Bottom" Height="24" Background="#AA000000" CornerRadius="0,0,8,8">
                                        <TextBlock Text="{Binding Photographer}" Foreground="White" FontSize="9" FontWeight="Medium" VerticalAlignment="Center" HorizontalAlignment="Left" Margin="8,0" TextTrimming="CharacterEllipsis" />
                                    </Border>
                                </Grid>
                            </DataTemplate>
                        </GridView.ItemTemplate>
                    </GridView>
                </ScrollViewer>
            </Grid>
        </ContentDialog>
    </Grid>
</Page>
