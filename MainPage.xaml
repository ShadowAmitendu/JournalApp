<?xml version="1.0" encoding="utf-8" ?>
<Page
    x:Class="JournalApp.MainPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:local="using:JournalApp"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    mc:Ignorable="d"
    NavigationCacheMode="Enabled"
    KeyDown="Page_KeyDown">

    <Page.Resources>
        <ThemeShadow x:Key="SharedShadow" />
        <local:BoolToVisibilityConverter x:Key="BoolToVisibilityConverter" />
        <local:BoolToVisibilityInverseConverter x:Key="BoolToVisibilityInverseConverter" />
        <local:BoolToOpacityConverter x:Key="BoolToOpacityConverter" />
        <local:StringToVisibilityConverter x:Key="StringToVisibilityConverter" />
        <local:ImagePathConverter x:Key="ImagePathConverter" />
        <local:HexToBrushConverter x:Key="HexToBrushConverter" />
        <local:BoolInverseConverter x:Key="BoolInverseConverter" />

        <!-- MarkdownEditorBox: transparent background/border on all states -->
        <Style TargetType="local:MarkdownEditorBox" BasedOn="{StaticResource DefaultRichEditBoxStyle}">
            <Setter Property="Background"       Value="Transparent" />
            <Setter Property="BorderThickness"  Value="0" />
        </Style>

        <!-- Shimmer gradient brush for skeleton loaders -->
        <LinearGradientBrush x:Key="ShimmerBrush" StartPoint="0,0.5" EndPoint="1,0.5">
            <GradientStop Color="#1AFFFFFF" Offset="0" />
            <GradientStop Color="#33FFFFFF" Offset="0.4" />
            <GradientStop Color="#55FFFFFF" Offset="0.5" />
            <GradientStop Color="#33FFFFFF" Offset="0.6" />
            <GradientStop Color="#1AFFFFFF" Offset="1" />
        </LinearGradientBrush>
        
        <!-- Notes List Item Grouping Source -->
        <CollectionViewSource x:Key="NotesCVS" x:Name="NotesCVS" IsSourceGrouped="True"/>

        <!-- Notes List Item Context Menu -->
        <MenuFlyout x:Key="NotesListContextFlyout" x:Name="NotesListContextFlyout" Opening="NotesListContextFlyout_Opening">
            <MenuFlyoutItem x:Name="ContextMenuDelete" Text="Move to Trash" Click="DeleteNoteButton_Click">
                <MenuFlyoutItem.Icon>
                    <FontIcon Glyph="&#xE74D;" FontFamily="{ThemeResource SymbolThemeFontFamily}" />
                </MenuFlyoutItem.Icon>
            </MenuFlyoutItem>
            
            <MenuFlyoutSubItem x:Name="ContextMenuMoveToCategorySubItem" Text="Move to Category">
                <MenuFlyoutSubItem.Icon>
                    <FontIcon Glyph="&#xE8DE;" FontFamily="{ThemeResource SymbolThemeFontFamily}" />
                </MenuFlyoutSubItem.Icon>
            </MenuFlyoutSubItem>
            
            <MenuFlyoutSeparator />
            
            <MenuFlyoutSubItem Text="Export &amp; Print">
                <MenuFlyoutSubItem.Icon>
                    <FontIcon Glyph="&#xEDE1;" FontFamily="{ThemeResource SymbolThemeFontFamily}" />
                </MenuFlyoutSubItem.Icon>
                <MenuFlyoutItem Text="Export as HTML..." Click="ContextMenuExportHtml_Click">
                    <MenuFlyoutItem.Icon>
                        <FontIcon Glyph="&#xE943;" FontFamily="{ThemeResource SymbolThemeFontFamily}" />
                    </MenuFlyoutItem.Icon>
                </MenuFlyoutItem>
                <MenuFlyoutItem Text="Export as Markdown (.md)..." Click="ContextMenuExportMarkdown_Click">
                    <MenuFlyoutItem.Icon>
                        <FontIcon Glyph="&#xE70F;" FontFamily="{ThemeResource SymbolThemeFontFamily}" />
                    </MenuFlyoutItem.Icon>
                </MenuFlyoutItem>
                <MenuFlyoutItem Text="Print or Save as PDF..." Click="ContextMenuPrint_Click">
                    <MenuFlyoutItem.Icon>
                        <FontIcon Glyph="&#xE749;" FontFamily="{ThemeResource SymbolThemeFontFamily}" />
                    </MenuFlyoutItem.Icon>
                </MenuFlyoutItem>
            </MenuFlyoutSubItem>
            
            <MenuFlyoutSeparator />
            
            <MenuFlyoutItem Text="Add Unsplash Cover..." Click="SearchUnsplashHeroImage_Click">
                <MenuFlyoutItem.Icon>
                    <FontIcon Glyph="&#xEB9F;" FontFamily="{ThemeResource SymbolThemeFontFamily}" />
                </MenuFlyoutItem.Icon>
            </MenuFlyoutItem>
        </MenuFlyout>
    </Page.Resources>

    <Grid>
        <!-- NavigationView replacing manual Sidebar Grid -->
        <NavigationView x:Name="CategoriesNavView"
                        PaneDisplayMode="Left"
                        IsSettingsVisible="False"
                        IsBackButtonVisible="Collapsed"
                        IsPaneToggleButtonVisible="True"
                        OpenPaneLength="240"
                        SelectionChanged="CategoriesNavView_SelectionChanged"
                        Background="Transparent">

            <NavigationView.PaneHeader>
                <Grid Padding="16,8" VerticalAlignment="Center">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="Auto" />
                    </Grid.RowDefinitions>
                    <TextBlock Text="Categories" FontWeight="SemiBold" FontSize="15" VerticalAlignment="Center" />
                    <TextBlock x:Name="StreakBadgeText" Grid.Row="1" Text="" FontSize="11"
                               Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                               Visibility="Collapsed" Margin="0,2,0,0" />
                </Grid>
            </NavigationView.PaneHeader>



            <NavigationView.FooterMenuItems>
                <NavigationViewItem x:Name="FavoritesNavItem" Content="Favorites" ToolTipService.ToolTip="Favorites">
                    <NavigationViewItem.Icon>
                        <FontIcon Glyph="&#xE734;" FontFamily="{ThemeResource SymbolThemeFontFamily}" />
                    </NavigationViewItem.Icon>
                </NavigationViewItem>
                <NavigationViewItem x:Name="TrashNavItem" Content="Trash" ToolTipService.ToolTip="Trash">
                    <NavigationViewItem.Icon>
                        <FontIcon Glyph="&#xE74D;" FontFamily="{ThemeResource SymbolThemeFontFamily}" />
                    </NavigationViewItem.Icon>
                    <NavigationViewItem.InfoBadge>
                        <InfoBadge x:Name="TrashInfoBadge" Value="0" Visibility="Collapsed" />
                    </NavigationViewItem.InfoBadge>
                </NavigationViewItem>
                <NavigationViewItem x:Name="GitHubNavItem" Content="GitHub History" ToolTipService.ToolTip="GitHub History" Visibility="Collapsed">
                    <NavigationViewItem.Icon>
                        <FontIcon Glyph="&#xE150;" FontFamily="{ThemeResource SymbolThemeFontFamily}" />
                    </NavigationViewItem.Icon>
                </NavigationViewItem>
                <NavigationViewItem x:Name="StatsNavItem" Content="Stats" ToolTipService.ToolTip="Writing Stats &amp; Insights">
                    <NavigationViewItem.Icon>
                        <FontIcon Glyph="&#xE9D2;" FontFamily="{ThemeResource SymbolThemeFontFamily}" />
                    </NavigationViewItem.Icon>
                </NavigationViewItem>
                <NavigationViewItem x:Name="GalleryNavItem" Content="Gallery" ToolTipService.ToolTip="Photo Diary Gallery">
                    <NavigationViewItem.Icon>
                        <FontIcon Glyph="&#xEB9F;" FontFamily="{ThemeResource SymbolThemeFontFamily}" />
                    </NavigationViewItem.Icon>
                </NavigationViewItem>
                <NavigationViewItem x:Name="BlogPageNavItem" Content="Blog" ToolTipService.ToolTip="GitHub Pages Blog Publisher">
                    <NavigationViewItem.Icon>
                        <FontIcon Glyph="&#xE774;" FontFamily="{ThemeResource SymbolThemeFontFamily}" />
                    </NavigationViewItem.Icon>
                </NavigationViewItem>
                <NavigationViewItem x:Name="MapNavItem" Content="Map View" ToolTipService.ToolTip="Interactive Journal Map">
                    <NavigationViewItem.Icon>
                        <FontIcon Glyph="&#xE707;" FontFamily="{ThemeResource SymbolThemeFontFamily}" />
                    </NavigationViewItem.Icon>
                </NavigationViewItem>
                <NavigationViewItem x:Name="ShortcutsNavItem" Content="Shortcuts" ToolTipService.ToolTip="Keyboard Shortcuts">
                    <NavigationViewItem.Icon>
                        <FontIcon Glyph="&#xE765;" FontFamily="{ThemeResource SymbolThemeFontFamily}" />
                    </NavigationViewItem.Icon>
                </NavigationViewItem>
                <NavigationViewItem x:Name="SettingsNavItem" Content="Settings" ToolTipService.ToolTip="Settings">
                    <NavigationViewItem.Icon>
                        <FontIcon Glyph="&#xE713;" FontFamily="{ThemeResource SymbolThemeFontFamily}" />
                    </NavigationViewItem.Icon>
                </NavigationViewItem>
            </NavigationView.FooterMenuItems>

            <!-- Main Content Container Grid -->
            <Grid>
                <Grid.ChildrenTransitions>
                    <TransitionCollection>
                        <EntranceThemeTransition FromHorizontalOffset="24" FromVerticalOffset="0" />
                    </TransitionCollection>
                </Grid.ChildrenTransitions>
                <!-- Main Layout Content Pane (split into Notes List and Editor) -->
                <Grid x:Name="MainEditorGrid" Visibility="Visible">
                <Grid.ColumnDefinitions>
                    <!-- Left: Notes List -->
                    <ColumnDefinition x:Name="NotesListColumn" Width="370" MinWidth="200" MaxWidth="500" />
                    <!-- Middle: Resizable Column Splitter -->
                    <ColumnDefinition Width="Auto" />
                    <!-- Right: Editor -->
                    <ColumnDefinition Width="*" />
                </Grid.ColumnDefinitions>

                <!-- Notes List (Grid.Column="0") -->
                <Grid x:Name="NotesListGrid" Grid.Column="0" Background="Transparent" Padding="16">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="*" />
                    </Grid.RowDefinitions>

                    <!-- Tint Overlay behind everything else -->
                    <Border x:Name="NotesListTintOverlay" Grid.RowSpan="2" Margin="-16" IsHitTestVisible="False" Opacity="0">
                        <Border.Background>
                            <LinearGradientBrush StartPoint="0,0" EndPoint="0,1">
                                <GradientStop x:Name="NotesListTintStop1" Offset="0.0" Color="Transparent" />
                                <GradientStop x:Name="NotesListTintStop2" Offset="0.8" Color="Transparent" />
                            </LinearGradientBrush>
                        </Border.Background>
                    </Border>
 
                    <!-- Top Actions -->
                    <Grid Grid.Row="0" Margin="0,0,0,12">
                        <TextBlock x:Name="SelectedCategoryTitle" Text="All Entries" FontSize="18" FontWeight="Bold" Foreground="{ThemeResource TextFillColorPrimaryBrush}" VerticalAlignment="Center" Margin="4,0,0,0" />
                        <StackPanel Orientation="Horizontal" Spacing="8" HorizontalAlignment="Right">
                            <!-- Sort Button -->
                            <Button x:Name="SortNoteButton" ToolTipService.ToolTip="Sort Entries" Width="32" Height="32" CornerRadius="16" Padding="0">
                                <Button.Content>
                                    <FontIcon Glyph="&#xE8CB;" FontFamily="{ThemeResource SymbolThemeFontFamily}" FontSize="14" />
                                </Button.Content>
                                <Button.Flyout>
                                    <MenuFlyout>
                                        <MenuFlyoutItem Text="Date Created (Newest First)" Click="SortOption_Click" Tag="DateCreatedDesc" />
                                        <MenuFlyoutItem Text="Date Created (Oldest First)" Click="SortOption_Click" Tag="DateCreatedAsc" />
                                        <MenuFlyoutItem Text="Date Modified (Newest First)" Click="SortOption_Click" Tag="DateModifiedDesc" />
                                        <MenuFlyoutItem Text="Title (A-Z)" Click="SortOption_Click" Tag="TitleAsc" />
                                        <MenuFlyoutItem Text="Title (Z-A)" Click="SortOption_Click" Tag="TitleDesc" />
                                    </MenuFlyout>
                                </Button.Flyout>
                            </Button>
                            
                            <!-- Empty Trash Button -->
                            <Button x:Name="EmptyTrashButton" ToolTipService.ToolTip="Empty Trash" Click="EmptyTrashButton_Click" Height="32" CornerRadius="16" Padding="8,0" Visibility="Collapsed" Background="#FF3B30" BorderBrush="#FF3B30" Foreground="White">
                                <Button.Resources>
                                    <SolidColorBrush x:Key="ButtonBackgroundPointerOver" Color="#D32F2F" />
                                    <SolidColorBrush x:Key="ButtonForegroundPointerOver" Color="White" />
                                    <SolidColorBrush x:Key="ButtonBorderBrushPointerOver" Color="#D32F2F" />
                                    <SolidColorBrush x:Key="ButtonBackgroundPressed" Color="#B71C1C" />
                                    <SolidColorBrush x:Key="ButtonForegroundPressed" Color="White" />
                                    <SolidColorBrush x:Key="ButtonBorderBrushPressed" Color="#B71C1C" />
                                </Button.Resources>
                                <Button.Content>
                                    <StackPanel Orientation="Horizontal" Spacing="6">
                                        <FontIcon Glyph="&#xE74D;" FontFamily="{ThemeResource SymbolThemeFontFamily}" FontSize="12" />
                                        <TextBlock Text="Empty Trash" FontSize="11" FontWeight="Medium" VerticalAlignment="Center"/>
                                    </StackPanel>
                                </Button.Content>
                            </Button>
                            
                            <!-- Import Entry Button -->
                            <Button x:Name="ImportNoteButton" ToolTipService.ToolTip="Import Entry (.md, .rtf, .txt)" Click="ImportNoteButton_Click" Width="32" Height="32" CornerRadius="16" Padding="0">
                                <Button.Content>
                                    <FontIcon Glyph="&#xE8B5;" FontFamily="{ThemeResource SymbolThemeFontFamily}" FontSize="14" />
                                </Button.Content>
                            </Button>
                            
                            <!-- New Entry Button -->
                            <Button x:Name="NewNoteButton" ToolTipService.ToolTip="New Entry" Click="NewNoteButton_Click" Width="32" Height="32" CornerRadius="16" Padding="0">
                                <Button.Content>
                                    <FontIcon Glyph="&#xE710;" FontFamily="{ThemeResource SymbolThemeFontFamily}" FontSize="14" />
                                </Button.Content>
                            </Button>
                        </StackPanel>
                    </Grid>
 
                    <!-- Notes List -->
                    <ListView x:Name="NotesListView" Grid.Row="1" 
                              ItemsSource="{x:Bind NotesCVS.View, Mode=OneWay}"
                              SelectionMode="Single" SelectionChanged="NotesListView_SelectionChanged" Padding="0,2"
                              ContainerContentChanging="NotesListView_ContainerContentChanging">
                        <ListView.ItemContainerTransitions>
                            <TransitionCollection>
                                <AddDeleteThemeTransition />
                                <ReorderThemeTransition />
                            </TransitionCollection>
                        </ListView.ItemContainerTransitions>
                        <ListView.ItemsPanel>
                            <ItemsPanelTemplate>
                                <ItemsStackPanel AreStickyGroupHeadersEnabled="True"/>
                            </ItemsPanelTemplate>
                        </ListView.ItemsPanel>
                        <ListView.GroupStyle>
                            <GroupStyle>
                                <GroupStyle.HeaderTemplate>
                                    <DataTemplate x:DataType="local:NotesGroup">
                                        <Border Visibility="{x:Bind IsHeaderVisible, Converter={StaticResource BoolToVisibilityConverter}, Mode=OneTime}"
                                                Padding="16,16,16,8" 
                                                Background="Transparent"
                                                HorizontalAlignment="Stretch">
                                            <Grid HorizontalAlignment="Stretch">
                                                <Grid.ColumnDefinitions>
                                                    <ColumnDefinition Width="Auto" />
                                                    <ColumnDefinition Width="Auto" />
                                                    <ColumnDefinition Width="*" />
                                                </Grid.ColumnDefinitions>
                                                
                                                <FontIcon Grid.Column="0" 
                                                          Glyph="{x:Bind CategoryIcon, Mode=OneTime}" 
                                                          Foreground="{x:Bind CategoryColor, Converter={StaticResource HexToBrushConverter}, Mode=OneTime}" 
                                                          FontFamily="{ThemeResource SymbolThemeFontFamily}" 
                                                          FontSize="18" 
                                                          Margin="0,0,8,0" 
                                                          VerticalAlignment="Center" />
                                                
                                                <TextBlock Grid.Column="1" 
                                                           Text="{x:Bind Key, Mode=OneTime}" 
                                                           Style="{ThemeResource BodyLargeTextBlockStyle}"
                                                           VerticalAlignment="Center" />
                                                
                                                <Border Grid.Column="2" 
                                                        Height="1" 
                                                        Background="{ThemeResource DividerStrokeColorDefaultBrush}" 
                                                        Margin="16,0,0,0" 
                                                        VerticalAlignment="Center" />
                                            </Grid>
                                        </Border>
                                    </DataTemplate>
                                </GroupStyle.HeaderTemplate>
                            </GroupStyle>
                        </ListView.GroupStyle>
                        <ListView.ItemTemplate>
                            <DataTemplate x:DataType="local:JournalNote">
                                <!-- Note Item Grid -->
                                <Grid ContextFlyout="{StaticResource NotesListContextFlyout}"
                                      RightTapped="NotesListItem_RightTapped"
                                      PointerEntered="NotesListItem_PointerEntered"
                                      PointerExited="NotesListItem_PointerExited"
                                      HorizontalAlignment="Stretch">
                                    <Grid.RowDefinitions>
                                        <RowDefinition Height="*" />
                                        <RowDefinition Height="Auto" />
                                    </Grid.RowDefinitions>
                                    
                                    <!-- Inner Content Grid (with padding) -->
                                    <Grid Grid.Row="0" Padding="12,14" Background="Transparent">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="Auto" />
                                            <ColumnDefinition Width="*" />
                                            <ColumnDefinition Width="Auto" />
                                            <ColumnDefinition Width="Auto" />
                                        </Grid.ColumnDefinitions>
                                        
                                        <!-- Left: Rounded-Square cover thumbnail (Column 0) -->
                                        <Grid Grid.Column="0" Width="48" Height="48" CornerRadius="8" Background="{ThemeResource CardBackgroundFillColorDefaultBrush}" BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}" BorderThickness="1" Margin="0,0,12,0" VerticalAlignment="Center">
                                            <!-- Fallback Image Icon -->
                                            <FontIcon Glyph="&#xE722;" FontFamily="{ThemeResource SymbolThemeFontFamily}" FontSize="16" Foreground="{ThemeResource TextFillColorSecondaryBrush}" VerticalAlignment="Center" HorizontalAlignment="Center" />
                                            <!-- Thumbnail Image -->
                                            <Image Source="{x:Bind AvatarImagePath, Converter={StaticResource ImagePathConverter}, Mode=OneTime}" Stretch="UniformToFill" />
                                        </Grid>
                                        
                                        <!-- Middle: Content Info (Column 1) -->
                                        <StackPanel Grid.Column="1" Spacing="2" VerticalAlignment="Center">
                                            <StackPanel Orientation="Horizontal" Spacing="6">
                                                <TextBlock Text="{x:Bind Title}" FontSize="14" FontWeight="SemiBold" TextTrimming="CharacterEllipsis" Foreground="{ThemeResource TextFillColorPrimaryBrush}" MaxWidth="120" />
                                                <FontIcon Glyph="&#xE735;" FontFamily="{ThemeResource SymbolThemeFontFamily}" FontSize="14" Foreground="Gold" Visibility="{x:Bind IsFavorite, Converter={StaticResource BoolToVisibilityConverter}, Mode=OneTime}" VerticalAlignment="Center" />
                                                <FontIcon Glyph="&#xE840;" FontFamily="{ThemeResource SymbolThemeFontFamily}" FontSize="14" Foreground="{ThemeResource SystemControlHighlightAccentBrush}" Visibility="{x:Bind IsPinned, Converter={StaticResource BoolToVisibilityConverter}, Mode=OneTime}" VerticalAlignment="Center" />
                                            </StackPanel>
                                            <TextBlock x:Name="SnippetTextBlock" Text="{x:Bind Snippet}" FontSize="12" Foreground="{ThemeResource TextFillColorSecondaryBrush}" TextTrimming="CharacterEllipsis" TextWrapping="NoWrap" Tag="SnippetRow" />
                                        </StackPanel>
                                        
                                        <!-- Right: Date Card (Column 2) -->
                                        <StackPanel Grid.Column="2" VerticalAlignment="Center" HorizontalAlignment="Center" Spacing="2" Margin="8,0,0,0" Width="56">
                                            <TextBlock Text="{x:Bind DateDayOfWeek, Mode=OneTime}" FontSize="9" FontWeight="Bold" HorizontalAlignment="Center" Foreground="{ThemeResource SystemControlHighlightAccentBrush}" />
                                            <TextBlock Text="{x:Bind DateDayNumber, Mode=OneTime}" FontSize="22" FontWeight="Bold" HorizontalAlignment="Center" Foreground="{ThemeResource TextFillColorPrimaryBrush}" Margin="0,-4" />
                                            <TextBlock Text="{x:Bind DateMonthYear, Mode=OneTime}" FontSize="9" FontWeight="Medium" HorizontalAlignment="Center" Foreground="{ThemeResource TextFillColorSecondaryBrush}" />
                                        </StackPanel>
             
                                         <!-- Rightmost: Vertical Actions Column (Column 3) -->
                                        <StackPanel Grid.Column="3" Orientation="Vertical" Spacing="4" VerticalAlignment="Center" Margin="8,0,0,0">
                                            <!-- Pin Button -->
                                            <Button Click="PinListButton_Click" Tag="ActionButton" Opacity="0" IsHitTestVisible="False" Foreground="{ThemeResource TextFillColorSecondaryBrush}" Background="Transparent" BorderThickness="0" Padding="0" Width="26" Height="26" CornerRadius="13" ToolTipService.ToolTip="Pin to Top" Visibility="{x:Bind IsDeleted, Converter={StaticResource BoolToVisibilityInverseConverter}, Mode=OneTime}">
                                                <Button.Resources>
                                                    <SolidColorBrush x:Key="ButtonForegroundPointerOver" Color="{ThemeResource SystemAccentColor}" />
                                                    <SolidColorBrush x:Key="ButtonForegroundPressed" Color="{ThemeResource SystemAccentColor}" />
                                                </Button.Resources>
                                                <Grid>
                                                    <FontIcon Glyph="&#xE840;" FontFamily="{ThemeResource SymbolThemeFontFamily}" FontSize="14" Visibility="{x:Bind IsPinned, Converter={StaticResource BoolToVisibilityConverter}, Mode=OneTime}" />
                                                    <FontIcon Glyph="&#xE718;" FontFamily="{ThemeResource SymbolThemeFontFamily}" FontSize="14" Visibility="{x:Bind IsPinned, Converter={StaticResource BoolToVisibilityInverseConverter}, Mode=OneTime}" />
                                                </Grid>
                                            </Button>
                                            <!-- Star Button -->
                                            <Button Click="FavoriteListButton_Click" Tag="ActionButton" Opacity="0" IsHitTestVisible="False" Foreground="{ThemeResource TextFillColorSecondaryBrush}" Background="Transparent" BorderThickness="0" Padding="0" Width="26" Height="26" CornerRadius="13" ToolTipService.ToolTip="Toggle Favorite" Visibility="{x:Bind IsDeleted, Converter={StaticResource BoolToVisibilityInverseConverter}, Mode=OneTime}">
                                                <Button.Resources>
                                                    <SolidColorBrush x:Key="ButtonForegroundPointerOver" Color="Gold" />
                                                    <SolidColorBrush x:Key="ButtonForegroundPressed" Color="Gold" />
                                                </Button.Resources>
                                                <Grid>
                                                    <FontIcon Glyph="&#xE735;" FontFamily="{ThemeResource SymbolThemeFontFamily}" FontSize="14" Visibility="{x:Bind IsFavorite, Converter={StaticResource BoolToVisibilityConverter}, Mode=OneTime}" />
                                                    <FontIcon Glyph="&#xE734;" FontFamily="{ThemeResource SymbolThemeFontFamily}" FontSize="14" Visibility="{x:Bind IsFavorite, Converter={StaticResource BoolToVisibilityInverseConverter}, Mode=OneTime}" />
                                                </Grid>
                                            </Button>
                                            <!-- Delete Button -->
                                            <Button Click="DeleteListButton_Click" Tag="DeleteButton" Opacity="0" IsHitTestVisible="False" Foreground="{ThemeResource TextFillColorSecondaryBrush}" Background="Transparent" BorderThickness="0" Padding="0" Width="26" Height="26" CornerRadius="13" ToolTipService.ToolTip="Move to Trash" Visibility="{x:Bind IsDeleted, Converter={StaticResource BoolToVisibilityInverseConverter}, Mode=OneTime}">
                                                <Button.Resources>
                                                    <SolidColorBrush x:Key="ButtonForegroundPointerOver" Color="Red" />
                                                    <SolidColorBrush x:Key="ButtonForegroundPressed" Color="Red" />
                                                </Button.Resources>
                                                <FontIcon Glyph="&#xE74D;" FontFamily="{ThemeResource SymbolThemeFontFamily}" FontSize="14" />
                                            </Button>
                                            
                                            <!-- Trash Mode Buttons -->
                                            <Button Click="RestoreListButton_Click" Foreground="{ThemeResource TextFillColorSecondaryBrush}" Background="Transparent" BorderThickness="0" Padding="0" Width="26" Height="26" CornerRadius="13" ToolTipService.ToolTip="Restore Entry" Visibility="{x:Bind IsDeleted, Converter={StaticResource BoolToVisibilityConverter}, Mode=OneTime}">
                                                <Button.Resources>
                                                    <SolidColorBrush x:Key="ButtonForegroundPointerOver" Color="{ThemeResource SystemAccentColor}" />
                                                    <SolidColorBrush x:Key="ButtonForegroundPressed" Color="{ThemeResource SystemAccentColor}" />
                                                </Button.Resources>
                                                <FontIcon Glyph="&#xE7A6;" FontFamily="{ThemeResource SymbolThemeFontFamily}" FontSize="14" />
                                            </Button>
                                            <Button Click="PermanentlyDeleteListButton_Click" Tag="DeleteButton" Opacity="0" IsHitTestVisible="False" Foreground="{ThemeResource TextFillColorSecondaryBrush}" Background="Transparent" BorderThickness="0" Padding="0" Width="26" Height="26" CornerRadius="13" ToolTipService.ToolTip="Delete Permanently" Visibility="{x:Bind IsDeleted, Converter={StaticResource BoolToVisibilityConverter}, Mode=OneTime}">
                                                <Button.Resources>
                                                    <SolidColorBrush x:Key="ButtonForegroundPointerOver" Color="Red" />
                                                    <SolidColorBrush x:Key="ButtonForegroundPressed" Color="Red" />
                                                </Button.Resources>
                                                <FontIcon Glyph="&#xE74D;" FontFamily="{ThemeResource SymbolThemeFontFamily}" FontSize="14" />
                                            </Button>
                                        </StackPanel>
                                    </Grid>
                                    
                                    <!-- Bottom Divider Line -->
                                    <Border Grid.Row="1" 
                                            Height="1" 
                                            Background="{ThemeResource DividerStrokeColorDefaultBrush}" 
                                            Visibility="{x:Bind IsBottomDividerVisible, Converter={StaticResource BoolToVisibilityConverter}, Mode=OneTime}" />
                                </Grid>
                            </DataTemplate>
                        </ListView.ItemTemplate>
                    </ListView>
                </Grid>

                <!-- Divider Line & Splitter -->
                <Border Grid.Column="1" 
                        x:Name="ColumnSplitter"
                        Width="8" 
                        Background="Transparent" 
                        HorizontalAlignment="Center" 
                        VerticalAlignment="Stretch"
                        PointerPressed="ColumnSplitter_PointerPressed"
                        PointerMoved="ColumnSplitter_PointerMoved"
                        PointerReleased="ColumnSplitter_PointerReleased"
                        PointerEntered="ColumnSplitter_PointerEntered"
                        PointerExited="ColumnSplitter_PointerExited"
                        Canvas.ZIndex="10">
                    <Border Width="1" 
                            HorizontalAlignment="Center" 
                            VerticalAlignment="Stretch" 
                            BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}" 
                            BorderThickness="1,0,0,0" />
                </Border>

                <!-- Active Note Editor (Grid.Column="2") -->
                <Grid Grid.Column="2" Background="Transparent">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="*" />
                        <RowDefinition Height="Auto" />
                    </Grid.RowDefinitions>

                    <!-- Editor Toolbar -->
                    <Grid x:Name="EditorToolbar" Grid.Row="0" Background="Transparent" Padding="16,8" BorderThickness="0,0,0,1" BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}" Visibility="Collapsed">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="Auto" />
                        </Grid.ColumnDefinitions>
                        <!-- Formatting Controls -->
                        <StackPanel Grid.Column="0" Orientation="Horizontal" Spacing="6" VerticalAlignment="Center">
                            <Button ToolTipService.ToolTip="Bold (Ctrl+B)" Click="BoldButton_Click" Width="36" Height="32" Padding="0">
                                <Button.Content>
                                    <FontIcon Glyph="&#xE8DD;" FontFamily="{ThemeResource SymbolThemeFontFamily}" FontSize="14" />
                                </Button.Content>
                            </Button>
                            <Button ToolTipService.ToolTip="Italic (Ctrl+I)" Click="ItalicButton_Click" Width="36" Height="32" Padding="0">
                                <Button.Content>
                                    <FontIcon Glyph="&#xE8DB;" FontFamily="{ThemeResource SymbolThemeFontFamily}" FontSize="14" />
                                </Button.Content>
                            </Button>
                            <Button ToolTipService.ToolTip="Underline (Ctrl+U)" Click="UnderlineButton_Click" Width="36" Height="32" Padding="0">
                                <Button.Content>
                                    <FontIcon Glyph="&#xE8DC;" FontFamily="{ThemeResource SymbolThemeFontFamily}" FontSize="14" />
                                </Button.Content>
                            </Button>

                             <Button ToolTipService.ToolTip="Highlight Text" Width="44" Height="32" Padding="0">
                                 <Button.Content>
                                     <StackPanel Orientation="Horizontal" Spacing="4" Padding="6,0">
                                         <FontIcon Glyph="&#xE7E6;" FontFamily="{ThemeResource SymbolThemeFontFamily}" FontSize="14" />
                                         <FontIcon Glyph="&#xE96E;" FontFamily="{ThemeResource SymbolThemeFontFamily}" FontSize="8" VerticalAlignment="Center" />
                                     </StackPanel>
                                 </Button.Content>
                                 <Button.Flyout>
                                     <MenuFlyout>
                                         <MenuFlyoutItem Text="Yellow" Tag="#FFFF00" Click="HighlightColor_Click" />
                                         <MenuFlyoutItem Text="Green" Tag="#00FF00" Click="HighlightColor_Click" />
                                         <MenuFlyoutItem Text="Blue" Tag="#00FFFF" Click="HighlightColor_Click" />
                                         <MenuFlyoutItem Text="Pink" Tag="#FF00FF" Click="HighlightColor_Click" />
                                         <MenuFlyoutItem Text="Clear" Tag="Clear" Click="HighlightColor_Click" />
                                     </MenuFlyout>
                                 </Button.Flyout>
                             </Button>

                             <!-- Text Color -->
                             <Button ToolTipService.ToolTip="Text Color" Width="44" Height="32" Padding="0">
                                 <Button.Content>
                                     <StackPanel Orientation="Horizontal" Spacing="4" Padding="6,0">
                                         <FontIcon Glyph="&#xE706;" FontFamily="{ThemeResource SymbolThemeFontFamily}" FontSize="14" />
                                         <FontIcon Glyph="&#xE0E5;" FontFamily="{ThemeResource SymbolThemeFontFamily}" FontSize="8" VerticalAlignment="Center" />
                                     </StackPanel>
                                 </Button.Content>
                                 <Button.Flyout>
                                     <MenuFlyout>
                                         <MenuFlyoutItem Text="Default" Tag="Default" Click="TextColorButton_Click" />
                                         <MenuFlyoutItem Text="Red" Tag="#FF0000" Click="TextColorButton_Click" />
                                         <MenuFlyoutItem Text="Blue" Tag="#0000FF" Click="TextColorButton_Click" />
                                         <MenuFlyoutItem Text="Green" Tag="#008000" Click="TextColorButton_Click" />
                                         <MenuFlyoutItem Text="Orange" Tag="#FFA500" Click="TextColorButton_Click" />
                                         <MenuFlyoutItem Text="Purple" Tag="#800080" Click="TextColorButton_Click" />
                                         <MenuFlyoutItem Text="Gray" Tag="#808080" Click="TextColorButton_Click" />
                                     </MenuFlyout>
                                 </Button.Flyout>
                             </Button>

                            <AppBarSeparator />

                            <Button ToolTipService.ToolTip="Align Left" Click="AlignLeftButton_Click" Width="36" Height="32" Padding="0">
                                <Button.Content>
                                    <FontIcon Glyph="&#xE8E4;" FontFamily="{ThemeResource SymbolThemeFontFamily}" FontSize="14" />
                                </Button.Content>
                            </Button>
                            <Button ToolTipService.ToolTip="Align Center" Click="AlignCenterButton_Click" Width="36" Height="32" Padding="0">
                                <Button.Content>
                                    <FontIcon Glyph="&#xE8E3;" FontFamily="{ThemeResource SymbolThemeFontFamily}" FontSize="14" />
                                </Button.Content>
                            </Button>
                            <Button ToolTipService.ToolTip="Align Right" Click="AlignRightButton_Click" Width="36" Height="32" Padding="0">
                                <Button.Content>
                                    <FontIcon Glyph="&#xE8E2;" FontFamily="{ThemeResource SymbolThemeFontFamily}" FontSize="14" />
                                </Button.Content>
                            </Button>
                             <Button ToolTipService.ToolTip="Justify" Click="AlignJustifyButton_Click" Width="36" Height="32" Padding="0">
                                 <Button.Content>
                                     <FontIcon Glyph="&#xE700;" FontFamily="{ThemeResource SymbolThemeFontFamily}" FontSize="14" />
                                 </Button.Content>
                             </Button>

                            <AppBarSeparator />

                            <!-- Lists Dropdown -->
                            <Button ToolTipService.ToolTip="Lists" Width="44" Height="32" Padding="0">
                                <Button.Content>
                                    <StackPanel Orientation="Horizontal" Spacing="4" Padding="6,0">
                                        <FontIcon Glyph="&#xE8FD;" FontFamily="{ThemeResource SymbolThemeFontFamily}" FontSize="14" />
                                        <FontIcon Glyph="&#xE0E5;" FontFamily="{ThemeResource SymbolThemeFontFamily}" FontSize="8" VerticalAlignment="Center" />
                                    </StackPanel>
                                </Button.Content>
                                <Button.Flyout>
                                    <MenuFlyout>
                                        <MenuFlyoutItem Text="Bulleted List" Click="BulletListButton_Click">
                                            <MenuFlyoutItem.Icon>
                                                <FontIcon Glyph="&#xE8FD;" FontFamily="{ThemeResource SymbolThemeFontFamily}" />
                                            </MenuFlyoutItem.Icon>
                                        </MenuFlyoutItem>
                                        <MenuFlyoutItem Text="Numbered List" Click="NumberedListButton_Click">
                                            <MenuFlyoutItem.Icon>
                                                <FontIcon Glyph="&#xE179;" FontFamily="{ThemeResource SymbolThemeFontFamily}" />
                                            </MenuFlyoutItem.Icon>
                                        </MenuFlyoutItem>
                                    </MenuFlyout>
                                </Button.Flyout>
                            </Button>

                            <AppBarSeparator />

                            <!-- Insert Image Menu -->
                            <Button ToolTipService.ToolTip="Insert Inline Image" Width="44" Height="32" Padding="0">
                                <Button.Content>
                                    <StackPanel Orientation="Horizontal" Spacing="4" Padding="6,0">
                                        <FontIcon Glyph="&#xE722;" FontFamily="{ThemeResource SymbolThemeFontFamily}" FontSize="14" />
                                        <FontIcon Glyph="&#xE0E5;" FontFamily="{ThemeResource SymbolThemeFontFamily}" FontSize="8" VerticalAlignment="Center" />
                                    </StackPanel>
                                </Button.Content>
                                <Button.Flyout>
                                    <MenuFlyout>
                                        <MenuFlyoutItem Text="From File..." Click="InsertLocalImage_Click">
                                            <MenuFlyoutItem.Icon>
                                                <FontIcon Glyph="&#xE114;" FontFamily="{ThemeResource SymbolThemeFontFamily}" />
                                            </MenuFlyoutItem.Icon>
                                        </MenuFlyoutItem>
                                        <MenuFlyoutItem Text="From URL..." Click="InsertUrlImage_Click">
                                            <MenuFlyoutItem.Icon>
                                                <FontIcon Glyph="&#xE71B;" FontFamily="{ThemeResource SymbolThemeFontFamily}" />
                                            </MenuFlyoutItem.Icon>
                                        </MenuFlyoutItem>
                                    </MenuFlyout>
                                </Button.Flyout>
                            </Button>

                             <!-- Inspiration (Daily Prompts) -->
                             <Button x:Name="InspirationButton" ToolTipService.ToolTip="Writing Inspiration" Width="36" Height="32" Padding="0">
                                 <Button.Content>
                                     <FontIcon Glyph="&#xE710;" FontFamily="{ThemeResource SymbolThemeFontFamily}" FontSize="14" />
                                 </Button.Content>
                                 <Button.Flyout>
                                     <Flyout x:Name="InspirationFlyout" Placement="Bottom" Opening="InspirationFlyout_Opening">
                                         <StackPanel Width="260" Spacing="8">
                                             <TextBlock Text="Writing Prompt" FontWeight="SemiBold" FontSize="13" />
                                             <TextBlock x:Name="PromptDisplayTextBlock" Text="Loading prompt..." FontSize="12" TextWrapping="Wrap" Foreground="{ThemeResource TextFillColorSecondaryBrush}" />
                                             <StackPanel Orientation="Horizontal" Spacing="6" HorizontalAlignment="Right" Margin="0,4,0,0">
                                                 <Button Content="New" Click="NewPrompt_Click" FontSize="11" Padding="8,4" />
                                                 <Button Content="Insert" Click="InsertPrompt_Click" FontSize="11" Padding="8,4" Style="{StaticResource AccentButtonStyle}" />
                                             </StackPanel>
                                         </StackPanel>
                                     </Flyout>
                                 </Button.Flyout>
                             </Button>

                            <!-- Font Family Selector in Toolbar -->
                            <ComboBox x:Name="ToolbarFontComboBox" Width="130" Height="32" SelectionChanged="ToolbarFontComboBox_SelectionChanged" PlaceholderText="Font" ToolTipService.ToolTip="Text Font Family">
                                <ComboBoxItem Content="Segoe UI" Tag="Segoe UI" />
                                <ComboBoxItem Content="Inter" Tag="Inter" />
                                <ComboBoxItem Content="Roboto" Tag="Roboto" />
                                <ComboBoxItem Content="Outfit" Tag="Outfit" />
                                <ComboBoxItem Content="Courier New" Tag="Courier New" />
                                <ComboBoxItem Content="Georgia" Tag="Georgia" />
                                <ComboBoxItem Content="Consolas" Tag="Consolas" />
                            </ComboBox>

                            <!-- Editor Layout Width Dropdown -->
                            <Button x:Name="EditorWidthButton" ToolTipService.ToolTip="Editor Layout Width" Width="44" Height="32" Padding="0">
                                <Button.Content>
                                    <StackPanel Orientation="Horizontal" Spacing="4" Padding="6,0">
                                        <FontIcon Glyph="&#xE740;" FontFamily="{ThemeResource SymbolThemeFontFamily}" FontSize="14" />
                                        <FontIcon Glyph="&#xE0E5;" FontFamily="{ThemeResource SymbolThemeFontFamily}" FontSize="8" VerticalAlignment="Center" />
                                    </StackPanel>
                                </Button.Content>
                                <Button.Flyout>
                                    <MenuFlyout>
                                        <MenuFlyoutItem Text="Narrow (600px)" Click="EditorWidth_Click" Tag="Narrow" />
                                        <MenuFlyoutItem Text="Medium (800px)" Click="EditorWidth_Click" Tag="Medium" />
                                        <MenuFlyoutItem Text="Wide (1000px)" Click="EditorWidth_Click" Tag="Wide" />
                                        <MenuFlyoutItem Text="Full Width" Click="EditorWidth_Click" Tag="Full" />
                                    </MenuFlyout>
                                </Button.Flyout>
                            </Button>

                            <!-- Markdown Preview Toggle -->
                            <ToggleButton x:Name="MarkdownPreviewToggle" ToolTipService.ToolTip="Markdown Preview" Checked="MarkdownPreviewToggle_Checked" Unchecked="MarkdownPreviewToggle_Unchecked" Width="36" Height="32" Padding="0">
                                <ToggleButton.Content>
                                    <FontIcon Glyph="&#xE929;" FontFamily="{ThemeResource SymbolThemeFontFamily}" FontSize="14" />
                                </ToggleButton.Content>
                            </ToggleButton>

                            <!-- Print Note Button -->
                            <Button x:Name="PrintNoteButton" ToolTipService.ToolTip="Print Entry" Click="PrintNoteButton_Click" Width="36" Height="32" Padding="0">
                                <Button.Content>
                                    <FontIcon Glyph="&#xE749;" FontFamily="{ThemeResource SymbolThemeFontFamily}" FontSize="14" />
                                </Button.Content>
                            </Button>

                            <!-- Zen Focus Mode -->
                            <Button x:Name="ZenModeButton" ToolTipService.ToolTip="Zen Focus Mode" Width="44" Height="32" Padding="0">
                                <Button.Content>
                                    <StackPanel Orientation="Horizontal" Spacing="4" Padding="6,0">
                                        <FontIcon Glyph="&#xE71A;" FontFamily="{ThemeResource SymbolThemeFontFamily}" FontSize="14" />
                                        <FontIcon Glyph="&#xE0E5;" FontFamily="{ThemeResource SymbolThemeFontFamily}" FontSize="8" VerticalAlignment="Center" />
                                    </StackPanel>
                                </Button.Content>
                                <Button.Flyout>
                                    <Flyout x:Name="ZenModeFlyout" Placement="Bottom">
                                        <StackPanel Width="240" Spacing="12" Padding="4">
                                            <TextBlock Text="Zen Focus Mode" FontWeight="SemiBold" FontSize="14" />
                                            
                                            <ToggleSwitch x:Name="ZenModeToggle" Header="Fullscreen Focus" IsOn="False" Toggled="ZenModeToggle_Toggled" OnContent="Active" OffContent="Inactive" />
                                            
                                            <MenuFlyoutSeparator />
                                            
                                            <ToggleSwitch x:Name="TypewriterSoundToggle" Header="Typewriter Key Clicks" IsOn="True" Toggled="TypewriterSoundToggle_Toggled" OnContent="Enabled" OffContent="Disabled" />
                                            
                                            <TextBlock Text="Ambient Background" FontSize="12" Foreground="{ThemeResource TextFillColorSecondaryBrush}" Margin="0,4,0,0" />
                                            <ComboBox x:Name="AmbientSoundComboBox" HorizontalAlignment="Stretch" SelectionChanged="AmbientSoundComboBox_SelectionChanged">
                                                <ComboBoxItem Content="None" Tag="none" IsSelected="True" />
                                                <ComboBoxItem Content="Gentle Rain" Tag="rain" />
                                                <ComboBoxItem Content="Lo-Fi Writing Beats" Tag="lofi" />
                                                <ComboBoxItem Content="Ocean Waves" Tag="waves" />
                                            </ComboBox>
                                            
                                            <TextBlock Text="Ambient Volume" FontSize="11" Foreground="{ThemeResource TextFillColorSecondaryBrush}" />
                                            <Slider x:Name="AmbientVolumeSlider" Minimum="0" Maximum="100" Value="50" ValueChanged="AmbientVolumeSlider_ValueChanged" />
                                        </StackPanel>
                                    </Flyout>
                                </Button.Flyout>
                            </Button>
                        </StackPanel>

                        <!-- Actions Controls -->
                        <StackPanel Grid.Column="1" Orientation="Horizontal" Spacing="6" VerticalAlignment="Center">
                            <ToggleButton x:Name="PinToggle" ToolTipService.ToolTip="Pin to Top" Checked="PinToggle_Checked" Unchecked="PinToggle_Unchecked" Width="36" Height="32" Padding="0">
                                <ToggleButton.Content>
                                    <FontIcon Glyph="&#xE718;" FontFamily="{ThemeResource SymbolThemeFontFamily}" FontSize="14" />
                                </ToggleButton.Content>
                            </ToggleButton>
                            <ToggleButton x:Name="FavoriteToggle" ToolTipService.ToolTip="Favorite" Checked="FavoriteToggle_Checked" Unchecked="FavoriteToggle_Unchecked" Width="36" Height="32" Padding="0">
                                <ToggleButton.Content>
                                    <FontIcon Glyph="&#xE734;" FontFamily="{ThemeResource SymbolThemeFontFamily}" FontSize="14" />
                                </ToggleButton.Content>
                            </ToggleButton>
                            
                            <!-- Move Note Category Menu -->
                            <Button x:Name="MoveCategoryButton" ToolTipService.ToolTip="Move Category" Width="36" Height="32" Padding="0">
                                <Button.Content>
                                    <FontIcon Glyph="&#xE8DE;" FontFamily="{ThemeResource SymbolThemeFontFamily}" FontSize="14" />
                                </Button.Content>
                                <Button.Flyout>
                                    <MenuFlyout x:Name="MoveCategoryMenu" Opening="MoveCategoryMenu_Opening">
                                        <!-- Populated dynamically -->
                                    </MenuFlyout>
                                </Button.Flyout>
                            </Button>
                            
                            <Button x:Name="DeleteNoteButton" ToolTipService.ToolTip="Move to Trash" Click="DeleteNoteButton_Click" Width="36" Height="32" Padding="0">
                                <Button.Content>
                                    <FontIcon Glyph="&#xE74D;" FontFamily="{ThemeResource SymbolThemeFontFamily}" FontSize="14" Foreground="Red" />
                                </Button.Content>
                            </Button>

                            <Button x:Name="RestoreNoteButton" ToolTipService.ToolTip="Restore Entry" Click="RestoreNoteButton_Click" Width="36" Height="32" Padding="0" Visibility="Collapsed">
                                <Button.Content>
                                    <FontIcon Glyph="&#xE7A6;" FontFamily="{ThemeResource SymbolThemeFontFamily}" FontSize="14" Foreground="{ThemeResource SystemControlHighlightAccentBrush}" />
                                </Button.Content>
                            </Button>

                            <Button x:Name="PermanentlyDeleteNoteButton" ToolTipService.ToolTip="Delete Permanently" Click="PermanentlyDeleteNoteButton_Click" Width="36" Height="32" Padding="0" Visibility="Collapsed">
                                <Button.Content>
                                    <FontIcon Glyph="&#xE74D;" FontFamily="{ThemeResource SymbolThemeFontFamily}" FontSize="14" Foreground="Red" />
                                </Button.Content>
                            </Button>
                        </StackPanel>
                    </Grid>

                    <!-- Find & Replace Bar (Ctrl+F) -->
                    <Grid x:Name="FindReplaceBar" Grid.Row="1" Visibility="Collapsed"
                          Background="{ThemeResource CardBackgroundFillColorDefaultBrush}"
                          BorderThickness="0,1,0,1" BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}"
                          Padding="12,6">
                        <Grid.Transitions>
                            <TransitionCollection>
                                <PaneThemeTransition Edge="Top" />
                            </TransitionCollection>
                        </Grid.Transitions>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="Auto" />
                        </Grid.ColumnDefinitions>
                        <StackPanel Orientation="Horizontal" Spacing="6" VerticalAlignment="Center">
                            <TextBox x:Name="FindTextBox" PlaceholderText="Find..." Width="180" Height="28"
                                     FontSize="12" TextChanged="FindTextBox_TextChanged"
                                     KeyDown="FindTextBox_KeyDown" />
                            <TextBox x:Name="ReplaceTextBox" PlaceholderText="Replace with..." Width="180" Height="28"
                                     FontSize="12" />
                            <Button x:Name="PrevMatchBtn" Content="&#xE972;" FontFamily="{ThemeResource SymbolThemeFontFamily}"
                                    Width="28" Height="28" Padding="0" FontSize="12"
                                    ToolTipService.ToolTip="Previous match" Click="PrevMatchBtn_Click" />
                            <Button x:Name="NextMatchBtn" Content="&#xE971;" FontFamily="{ThemeResource SymbolThemeFontFamily}"
                                    Width="28" Height="28" Padding="0" FontSize="12"
                                    ToolTipService.ToolTip="Next match" Click="NextMatchBtn_Click" />
                            <Button x:Name="ReplaceOneBtn" Content="Replace" Height="28" Padding="8,0" FontSize="12"
                                    ToolTipService.ToolTip="Replace current match" Click="ReplaceOneBtn_Click" />
                            <Button x:Name="ReplaceAllBtn" Content="Replace All" Height="28" Padding="8,0" FontSize="12"
                                    ToolTipService.ToolTip="Replace all matches" Click="ReplaceAllBtn_Click" />
                            <TextBlock x:Name="MatchCountText" Text="" FontSize="11"
                                       Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                                       VerticalAlignment="Center" Margin="4,0" />
                        </StackPanel>
                        <Button x:Name="CloseFindBarBtn" Grid.Column="1" Content="&#xE711;"
                                FontFamily="{ThemeResource SymbolThemeFontFamily}"
                                Width="28" Height="28" Padding="0" FontSize="12"
                                ToolTipService.ToolTip="Close (Escape)" Click="CloseFindBarBtn_Click" />
                    </Grid>

                    <!-- Editor Grid wrapper to place editor scroll viewer and AI panel side-by-side -->
                    <Grid Grid.Row="2">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="Auto" />
                        </Grid.ColumnDefinitions>

                        <!-- Editor Pane ScrollViewer -->
                        <ScrollViewer x:Name="EditorScrollViewer" Grid.Column="0" Padding="0" VerticalScrollBarVisibility="Auto" Background="Transparent">
                        <!-- Redesigned Editor Grid (flush edge-to-edge container) -->
                        <Grid x:Name="EditorStackPanel" 
                              HorizontalAlignment="Stretch" 
                              VerticalAlignment="Top"
                              Visibility="Collapsed">
                            <Grid.Transitions>
                                <TransitionCollection>
                                    <EntranceThemeTransition FromHorizontalOffset="0" FromVerticalOffset="16" />
                                </TransitionCollection>
                            </Grid.Transitions>
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto" />
                                <RowDefinition Height="*" />
                            </Grid.RowDefinitions>

                            <!-- Tint Overlay for Editor Content behind everything else in Row 1 -->
                            <Border x:Name="EditorTintOverlay" Grid.Row="1" IsHitTestVisible="False" Opacity="0">
                                <Border.Background>
                                    <LinearGradientBrush StartPoint="0,0" EndPoint="0,1">
                                        <GradientStop x:Name="EditorTintStop1" Offset="0.0" Color="Transparent" />
                                        <GradientStop x:Name="EditorTintStop2" Offset="0.8" Color="Transparent" />
                                    </LinearGradientBrush>
                                </Border.Background>
                            </Border>
                            
                            <!-- Hero Image Banner (Stretches full width, overlay cover actions) -->
                            <Grid x:Name="HeroImageContainer" Grid.Row="0" Height="300" Background="{ThemeResource CardStrokeColorDefaultBrush}" Visibility="Collapsed" HorizontalAlignment="Stretch" SizeChanged="HeroImageContainer_SizeChanged">
                                <Grid.Transitions>
                                    <TransitionCollection>
                                        <EntranceThemeTransition FromHorizontalOffset="0" FromVerticalOffset="-20" />
                                    </TransitionCollection>
                                </Grid.Transitions>
                                <!-- Clipped container for image positioning -->
                                 <Grid HorizontalAlignment="Stretch" VerticalAlignment="Stretch"
                                       Background="Transparent"
                                       x:Name="HeroDragGrid">
                                     <Image x:Name="HeroImage" Stretch="UniformToFill" ImageOpened="HeroImage_ImageOpened" HorizontalAlignment="Center" VerticalAlignment="Center" IsHitTestVisible="False">
                                         <Image.RenderTransform>
                                             <CompositeTransform x:Name="HeroImageTransform" TranslateX="0" TranslateY="0" />
                                         </Image.RenderTransform>
                                     </Image>

                                     <!-- Brightness/Dimming Overlay -->
                                     <Border x:Name="CoverBrightnessOverlay" Background="Black" Opacity="0" HorizontalAlignment="Stretch" VerticalAlignment="Stretch" IsHitTestVisible="False" />
                                 </Grid>

                                <!-- Attribution Badge (Bottom Left) -->
                                <Border x:Name="CoverAttributionBorder" VerticalAlignment="Bottom" HorizontalAlignment="Left" Margin="16" Background="#99000000" CornerRadius="12" Padding="8,4" Visibility="Collapsed">
                                    <StackPanel Orientation="Horizontal" Spacing="6">
                                        <FontIcon Glyph="&#xE9A1;" FontFamily="{ThemeResource SymbolThemeFontFamily}" FontSize="10" Foreground="White" VerticalAlignment="Center" />
                                        <RichTextBlock FontSize="10" Foreground="White" VerticalAlignment="Center">
                                            <Paragraph>
                                                <Run Text="Photo by " />
                                                <Hyperlink x:Name="PhotographerHyperlink" Foreground="#FF4A90E2" UnderlineStyle="None">
                                                    <Run x:Name="PhotographerNameRun" Text="Photographer" />
                                                </Hyperlink>
                                                <Run Text=" on " />
                                                <Hyperlink NavigateUri="https://unsplash.com/?utm_source=JournalApp&amp;utm_medium=referral" Foreground="#FF4A90E2" UnderlineStyle="None">
                                                    <Run Text="Unsplash" />
                                                </Hyperlink>
                                            </Paragraph>
                                        </RichTextBlock>
                                    </StackPanel>
                                </Border>
                                
                                 <!-- Overlay Actions on Hero Image (Top Right) -->
                                 <StackPanel Orientation="Horizontal" Spacing="8" VerticalAlignment="Top" HorizontalAlignment="Right" Margin="16">
                                     <!-- Change Banner Button -->
                                     <Button x:Name="ChangeHeroButton" CornerRadius="16" Padding="12,6" Background="#99000000" BorderThickness="0" ToolTipService.ToolTip="Change Cover Banner">
                                         <Button.Content>
                                             <StackPanel Orientation="Horizontal" Spacing="6">
                                                 <FontIcon Glyph="&#xE722;" FontFamily="{ThemeResource SymbolThemeFontFamily}" FontSize="12" Foreground="White" />
                                                 <TextBlock Text="Change Cover" FontSize="11" Foreground="White" FontWeight="Medium" />
                                             </StackPanel>
                                         </Button.Content>
                                         <Button.Flyout>
                                             <MenuFlyout>
                                                 <MenuFlyoutItem Text="Select Local Image..." Click="SetLocalHeroImage_Click">
                                                     <MenuFlyoutItem.Icon>
                                                         <FontIcon Glyph="&#xE114;" FontFamily="{ThemeResource SymbolThemeFontFamily}" />
                                                     </MenuFlyoutItem.Icon>
                                                 </MenuFlyoutItem>
                                                 <MenuFlyoutItem Text="Search Unsplash..." Click="SearchUnsplashHeroImage_Click">
                                                     <MenuFlyoutItem.Icon>
                                                         <FontIcon Glyph="&#xE128;" FontFamily="{ThemeResource SymbolThemeFontFamily}" />
                                                     </MenuFlyoutItem.Icon>
                                                 </MenuFlyoutItem>
                                                 <MenuFlyoutItem Text="Set Web URL..." Click="SetUrlHeroImage_Click">
                                                     <MenuFlyoutItem.Icon>
                                                         <FontIcon Glyph="&#xE71B;" FontFamily="{ThemeResource SymbolThemeFontFamily}" />
                                                     </MenuFlyoutItem.Icon>
                                                 </MenuFlyoutItem>
                                                 <MenuFlyoutSeparator />
                                                 <MenuFlyoutItem Text="Reset to Default" Click="ResetHeroImage_Click">
                                                     <MenuFlyoutItem.Icon>
                                                         <FontIcon Glyph="&#xE777;" FontFamily="{ThemeResource SymbolThemeFontFamily}" />
                                                     </MenuFlyoutItem.Icon>
                                                 </MenuFlyoutItem>
                                             </MenuFlyout>
                                         </Button.Flyout>
                                     </Button>

                                     <!-- Adjust Cover Button — enters drag-to-reposition mode -->
                                     <Button x:Name="AdjustHeroButton" CornerRadius="16" Width="32" Height="32" Padding="0" Background="#99000000" BorderThickness="0" ToolTipService.ToolTip="Adjust Position, Brightness &amp; Blur" Click="AdjustHeroButton_Click">
                                         <Button.Content>
                                             <FontIcon Glyph="&#xE7AC;" FontFamily="{ThemeResource SymbolThemeFontFamily}" FontSize="12" Foreground="White" />
                                         </Button.Content>
                                         <Button.Flyout>
                                             <Flyout x:Name="AdjustHeroFlyout" Placement="BottomEdgeAlignedRight">
                                                 <Flyout.FlyoutPresenterStyle>
                                                     <Style TargetType="FlyoutPresenter">
                                                         <Setter Property="Padding" Value="0" />
                                                         <Setter Property="CornerRadius" Value="12" />
                                                         <Setter Property="Background" Value="#1E1E1E" />
                                                         <Setter Property="BorderBrush" Value="#3A3A3A" />
                                                         <Setter Property="BorderThickness" Value="1" />
                                                     </Style>
                                                 </Flyout.FlyoutPresenterStyle>
                                                 <StackPanel Spacing="0" Width="300">
                                                     <!-- Header -->
                                                     <StackPanel Padding="20,16,20,14">
                                                         <TextBlock Text="Adjust Cover Banner" FontSize="14" FontWeight="SemiBold" Foreground="White" />
                                                         <TextBlock Text="Adjust the brightness and blur of the cover banner below." FontSize="11" Foreground="#888888" TextWrapping="Wrap" Margin="0,4,0,0" />
                                                     </StackPanel>

                                                     <Border Height="1" Background="#333333" />

                                                     <!-- Sliders -->
                                                     <StackPanel Spacing="0" Padding="20,12,20,12">
                                                         <!-- Brightness -->
                                                         <Grid Margin="0,0,0,2">
                                                             <TextBlock Text="Brightness" FontSize="12" FontWeight="Medium" Foreground="#E0E0E0" VerticalAlignment="Center" />
                                                             <TextBlock x:Name="BrightnessValueText" Text="100%" FontSize="11" Foreground="#888888" HorizontalAlignment="Right" VerticalAlignment="Center" />
                                                         </Grid>
                                                         <Slider x:Name="CoverBrightnessSlider" Minimum="30" Maximum="100" Value="100" StepFrequency="1" ValueChanged="CoverBrightnessSlider_ValueChanged" Foreground="#0078D4" Margin="0,0,0,14" />

                                                         <!-- Blur -->
                                                         <Grid Margin="0,0,0,2">
                                                             <TextBlock Text="Blur" FontSize="12" FontWeight="Medium" Foreground="#E0E0E0" VerticalAlignment="Center" />
                                                             <TextBlock x:Name="BlurValueText" Text="0%" FontSize="11" Foreground="#888888" HorizontalAlignment="Right" VerticalAlignment="Center" />
                                                         </Grid>
                                                         <Slider x:Name="CoverBlurSlider" Minimum="0" Maximum="100" Value="0" StepFrequency="1" ValueChanged="CoverBlurSlider_ValueChanged" Foreground="#0078D4" />
                                                     </StackPanel>

                                                     <Border Height="1" Background="#333333" />

                                                     <!-- Reset Button -->
                                                     <StackPanel Padding="20,12">
                                                         <Button x:Name="ResetEffectsButton" Content="Reset to Default" Click="ResetEffectsButton_Click"
                                                                 HorizontalAlignment="Stretch" Padding="0,10"
                                                                 CornerRadius="8" FontSize="12"
                                                                 Background="#2A2A2A" Foreground="#E0E0E0"
                                                                 BorderBrush="#444444" BorderThickness="1" />
                                                     </StackPanel>
                                                 </StackPanel>
                                             </Flyout>
                                         </Button.Flyout>
                                     </Button>

                                     <!-- Remove/Hide Banner Button -->
                                     <Button Click="RemoveHeroImage_Click" CornerRadius="16" Width="32" Height="32" Padding="0" Background="#99000000" BorderThickness="0" ToolTipService.ToolTip="Hide Cover Banner">
                                         <Button.Content>
                                             <FontIcon Glyph="&#xE711;" FontFamily="{ThemeResource SymbolThemeFontFamily}" FontSize="12" Foreground="White" />
                                         </Button.Content>
                                     </Button>
                                 </StackPanel>
                            </Grid>

                            <!-- Centered Editor Content (Text wrapper up to MaxWidth 800) -->
                            <StackPanel x:Name="EditorContentStackPanel" Grid.Row="1" MaxWidth="800" HorizontalAlignment="Stretch" Padding="40,32,40,40" Spacing="20">
                                <!-- Date and Category Header (Side-by-side Grid) -->
                                <Grid ColumnSpacing="24" HorizontalAlignment="Stretch" Margin="0,0,0,8">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="Auto" />
                                        <ColumnDefinition Width="*" />
                                        <ColumnDefinition Width="Auto" />
                                    </Grid.ColumnDefinitions>

                                    <!-- Left: Date Button -->
                                    <Button x:Name="EditDateButton" Grid.Column="0" Background="Transparent" BorderThickness="0" Padding="4" HorizontalContentAlignment="Left" CornerRadius="8" ToolTipService.ToolTip="Edit Date and Time">
                                        <Button.Content>
                                            <Grid ColumnSpacing="32" VerticalAlignment="Center">
                                                <Grid.ColumnDefinitions>
                                                    <ColumnDefinition Width="Auto" />
                                                    <ColumnDefinition Width="*" />
                                                </Grid.ColumnDefinitions>
                                                
                                                <!-- Big Day Number -->
                                                <TextBlock x:Name="DateDayTextBlock" Grid.Column="0" Text="12" FontSize="56" FontWeight="Bold" Foreground="{ThemeResource TextFillColorPrimaryBrush}" VerticalAlignment="Center" Margin="0,-8,0,0"/>
                                                
                                                <!-- Month/Year and Time details stack -->
                                                <StackPanel Grid.Column="1" VerticalAlignment="Center" Spacing="2">
                                                    <TextBlock x:Name="DateMonthYearTextBlock" Text="May 2026" FontSize="18" FontWeight="SemiBold" Foreground="{ThemeResource TextFillColorPrimaryBrush}" />
                                                    <TextBlock x:Name="DateTimeTextBlock" Text="Tue, 11:35 PM" FontSize="13" Foreground="{ThemeResource TextFillColorSecondaryBrush}" />
                                                </StackPanel>
                                            </Grid>
                                        </Button.Content>
                                        <Button.Flyout>
                                            <Flyout x:Name="DateEditFlyout">
                                                <StackPanel Spacing="16" Width="300" Padding="4">
                                                    <TextBlock Text="Edit Entry Date &amp; Time" FontSize="16" FontWeight="SemiBold" Foreground="{ThemeResource TextFillColorPrimaryBrush}" />
                                                    
                                                    <!-- Calendar View -->
                                                    <CalendarView x:Name="EditDateCalendarView" SelectionMode="Single" HorizontalAlignment="Stretch" />
                                                    
                                                    <!-- Time Toggle -->
                                                    <ToggleSwitch x:Name="IncludeTimeToggle" Header="Include Time" IsOn="True" Toggled="IncludeTimeToggle_Toggled" OnContent="Yes" OffContent="No" />
                                                    
                                                    <!-- Time Picker -->
                                                    <TimePicker x:Name="EditTimePicker" ClockIdentifier="12HourClock" HorizontalAlignment="Stretch" Margin="0,-4,0,0" />
                                                    
                                                    <!-- Action Buttons -->
                                                    <Grid ColumnSpacing="12" Margin="0,8,0,0">
                                                        <Grid.ColumnDefinitions>
                                                            <ColumnDefinition Width="*" />
                                                            <ColumnDefinition Width="*" />
                                                        </Grid.ColumnDefinitions>
                                                        <Button x:Name="ApplyDateButton" Grid.Column="0" Content="Apply" Click="ApplyDateButton_Click" Style="{StaticResource AccentButtonStyle}" HorizontalAlignment="Stretch" />
                                                        <Button x:Name="CancelDateButton" Grid.Column="1" Content="Cancel" Click="CancelDateButton_Click" HorizontalAlignment="Stretch" />
                                                    </Grid>
                                                </StackPanel>
                                            </Flyout>
                                        </Button.Flyout>
                                    </Button>

                                    <!-- Right: Add Cover Button & Category Badge Button -->                                    <StackPanel Grid.Column="2" Orientation="Horizontal" Spacing="8" VerticalAlignment="Center" HorizontalAlignment="Right">
                                        <!-- Category Badge Button (standalone) -->
                                        <Button x:Name="ChangeCategoryButton" Background="Transparent" BorderThickness="1" BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}" Padding="10,6" CornerRadius="12" ToolTipService.ToolTip="Change Category">
                                            <Button.Content>
                                                <StackPanel Orientation="Horizontal" Spacing="8" VerticalAlignment="Center">
                                                    <FontIcon x:Name="CategoryBadgeIcon" Glyph="&#xE8B7;" FontFamily="{ThemeResource SymbolThemeFontFamily}" FontSize="14" />
                                                    <TextBlock x:Name="CategoryBadgeText" Text="Personal" FontSize="12" FontWeight="SemiBold" Foreground="{ThemeResource TextFillColorSecondaryBrush}" />
                                                    <FontIcon Glyph="&#xE972;" FontFamily="{ThemeResource SymbolThemeFontFamily}" FontSize="8" Foreground="{ThemeResource TextFillColorTertiaryBrush}" Margin="2,0,0,0" />
                                                </StackPanel>
                                            </Button.Content>
                                            <Button.Flyout>
                                                <MenuFlyout x:Name="ChangeCategoryMenu" Opening="MoveCategoryMenu_Opening" />
                                            </Button.Flyout>
                                        </Button>

                                        <!-- Grid for other buttons (AI Assist, Blog, Mood, Lock, Add Cover) -->
                                        <Grid ColumnSpacing="6" RowSpacing="6">
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="Auto" />
                                                <ColumnDefinition Width="Auto" />
                                                <ColumnDefinition Width="Auto" />
                                                <ColumnDefinition Width="Auto" />
                                                <ColumnDefinition Width="Auto" />
                                            </Grid.ColumnDefinitions>

                                            <!-- Column 0: AI Assistant Toggle Button -->
                                            <Button x:Name="AIAssistantButton" Grid.Column="0" CornerRadius="12" Padding="8,6" Background="Transparent" BorderThickness="1" BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}" ToolTipService.ToolTip="Toggle AI Writing Assistant (Ollama)" Click="AIAssistantButton_Click">
                                                <Button.Content>
                                                    <FontIcon Glyph="&#xE99A;" FontFamily="{ThemeResource SymbolThemeFontFamily}" FontSize="14" />
                                                </Button.Content>
                                            </Button>

                                            <!-- Column 1: Publish to Blog Toggle Button -->
                                            <ToggleButton x:Name="PublishToBlogToggle" Grid.Column="1" CornerRadius="12" Padding="8,6" Background="Transparent" BorderThickness="1" BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}" ToolTipService.ToolTip="Publish this entry to your public GitHub Pages Blog" Checked="PublishToBlogToggle_Checked" Unchecked="PublishToBlogToggle_Unchecked">
                                                <ToggleButton.Content>
                                                    <FontIcon Glyph="&#xE774;" FontFamily="{ThemeResource SymbolThemeFontFamily}" FontSize="14" />
                                                </ToggleButton.Content>
                                            </ToggleButton>

                                            <!-- Column 2: Mood Selector Button -->
                                            <Button x:Name="NoteMoodButton" Grid.Column="2" Background="Transparent" BorderThickness="1" BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}" Padding="8,6" CornerRadius="12" ToolTipService.ToolTip="How are you feeling?">
                                                <Button.Content>
                                                    <StackPanel Orientation="Horizontal" Spacing="4" VerticalAlignment="Center">
                                                        <TextBlock x:Name="NoteMoodIcon" Text="😐" FontSize="14" />
                                                        <TextBlock x:Name="NoteMoodText" Text="Neutral" FontSize="12" Visibility="Collapsed" />
                                                        <FontIcon Glyph="&#xE972;" FontFamily="{ThemeResource SymbolThemeFontFamily}" FontSize="8" Foreground="{ThemeResource TextFillColorTertiaryBrush}" Margin="2,0,0,0" />
                                                    </StackPanel>
                                                </Button.Content>
                                                <Button.Flyout>
                                                    <MenuFlyout>
                                                        <MenuFlyoutItem Text="😊 Happy" Click="MoodItem_Click" Tag="😊 Happy" />
                                                        <MenuFlyoutItem Text="😐 Neutral" Click="MoodItem_Click" Tag="😐 Neutral" />
                                                        <MenuFlyoutItem Text="😢 Sad" Click="MoodItem_Click" Tag="😢 Sad" />
                                                        <MenuFlyoutItem Text="😫 Stressed" Click="MoodItem_Click" Tag="😫 Stressed" />
                                                        <MenuFlyoutItem Text="😡 Angry" Click="MoodItem_Click" Tag="😡 Angry" />
                                                        <MenuFlyoutSeparator />
                                                        <MenuFlyoutItem Text="None (Clear)" Click="MoodItem_Click" Tag="None" />
                                                    </MenuFlyout>
                                                </Button.Flyout>
                                            </Button>

                                            <!-- Column 3: Lock Note Toggle Button -->
                                            <Button x:Name="LockNoteButton" Grid.Column="3" Background="Transparent" BorderThickness="1" BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}" Padding="8,6" CornerRadius="12" ToolTipService.ToolTip="Lock or Unlock this note" Click="LockNoteButton_Click">
                                                <Button.Content>
                                                    <StackPanel Orientation="Horizontal" Spacing="0" VerticalAlignment="Center">
                                                        <FontIcon x:Name="LockNoteIcon" Glyph="&#xE785;" FontFamily="{ThemeResource SymbolThemeFontFamily}" FontSize="14" />
                                                        <TextBlock x:Name="LockNoteText" Text="Unlocked" FontSize="12" Visibility="Collapsed" />
                                                    </StackPanel>
                                                </Button.Content>
                                            </Button>

                                            <!-- Column 4: Add Cover Button (Visible only when cover is hidden) -->
                                            <Button x:Name="AddCoverButton" Grid.Column="4" CornerRadius="12" Padding="8,6" Background="Transparent" BorderThickness="1" BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}" Visibility="Collapsed" ToolTipService.ToolTip="Add Cover Banner">
                                                <Button.Content>
                                                    <FontIcon Glyph="&#xE722;" FontFamily="{ThemeResource SymbolThemeFontFamily}" FontSize="14" />
                                                </Button.Content>
                                                <Button.Flyout>
                                                    <MenuFlyout>
                                                        <MenuFlyoutItem Text="Select Local Image..." Click="SetLocalHeroImage_Click">
                                                            <MenuFlyoutItem.Icon>
                                                                <FontIcon Glyph="&#xE114;" FontFamily="{ThemeResource SymbolThemeFontFamily}" />
                                                            </MenuFlyoutItem.Icon>
                                                        </MenuFlyoutItem>
                                                        <MenuFlyoutItem Text="Search Unsplash..." Click="SearchUnsplashHeroImage_Click">
                                                            <MenuFlyoutItem.Icon>
                                                                <FontIcon Glyph="&#xE128;" FontFamily="{ThemeResource SymbolThemeFontFamily}" />
                                                            </MenuFlyoutItem.Icon>
                                                        </MenuFlyoutItem>
                                                        <MenuFlyoutItem Text="Set Web URL..." Click="SetUrlHeroImage_Click">
                                                            <MenuFlyoutItem.Icon>
                                                                <FontIcon Glyph="&#xE71B;" FontFamily="{ThemeResource SymbolThemeFontFamily}" />
                                                            </MenuFlyoutItem.Icon>
                                                        </MenuFlyoutItem>
                                                        <MenuFlyoutSeparator />
                                                        <MenuFlyoutItem Text="Reset to Default" Click="ResetHeroImage_Click">
                                                            <MenuFlyoutItem.Icon>
                                                                <FontIcon Glyph="&#xE777;" FontFamily="{ThemeResource SymbolThemeFontFamily}" />
                                                            </MenuFlyoutItem.Icon>
                                                        </MenuFlyoutItem>
                                                    </MenuFlyout>
                                                </Button.Flyout>
                                            </Button>
                                        </Grid>
                                    </StackPanel>
                                </Grid>

                                <!-- Divider line -->
                                <Border Height="1" Background="{ThemeResource CardStrokeColorDefaultBrush}" HorizontalAlignment="Stretch" />

                                <!-- Title Input (Borderless) -->
                                <TextBox x:Name="TitleTextBox" TextChanged="TitleTextBox_TextChanged" KeyDown="TitleTextBox_KeyDown" PlaceholderText="Untitled Journal Entry" FontSize="32" FontWeight="Bold" Background="Transparent" BorderThickness="0" Padding="0" Margin="0,0,0,4" SelectionHighlightColor="{ThemeResource SystemAccentColor}">
                                    <TextBox.Resources>
                                        <Thickness x:Key="TextControlBorderThemeThickness">0</Thickness>
                                        <Thickness x:Key="TextControlBorderThemeThicknessFocused">0</Thickness>
                                        <Thickness x:Key="TextControlBorderThemeThicknessPointerOver">0</Thickness>
                                        <SolidColorBrush x:Key="TextControlBackground" Color="Transparent" />
                                        <SolidColorBrush x:Key="TextControlBackgroundPointerOver" Color="Transparent" />
                                        <SolidColorBrush x:Key="TextControlBackgroundFocused" Color="Transparent" />
                                        <SolidColorBrush x:Key="TextControlBackgroundDisabled" Color="Transparent" />
                                        <SolidColorBrush x:Key="TextControlBorderBrush" Color="Transparent" />
                                        <SolidColorBrush x:Key="TextControlBorderBrushPointerOver" Color="Transparent" />
                                        <SolidColorBrush x:Key="TextControlBorderBrushFocused" Color="Transparent" />
                                        <SolidColorBrush x:Key="TextControlBorderBrushDisabled" Color="Transparent" />
                                    </TextBox.Resources>
                                </TextBox>

                                 <!-- Content Editor Grid (Supports side-by-side live markdown preview) -->
                                 <Grid x:Name="EditorSplitGrid" HorizontalAlignment="Stretch" VerticalAlignment="Stretch">
                                     <Grid.ColumnDefinitions>
                                         <ColumnDefinition x:Name="EditorColumn" Width="*" />
                                         <ColumnDefinition x:Name="PreviewColumn" Width="0" />
                                     </Grid.ColumnDefinitions>

                                      <!-- Left: NoteRichEditBox (RTF notes) -->
                                      <RichEditBox x:Name="NoteRichEditBox" Grid.Column="0" Foreground="{ThemeResource TextFillColorPrimaryBrush}" TextChanged="NoteRichEditBox_TextChanged" SelectionChanged="NoteRichEditBox_SelectionChanged" PlaceholderText="Start writing your thoughts here..." MinHeight="500" Background="Transparent" BorderThickness="0" Padding="0" FontSize="16" VerticalAlignment="Stretch" HorizontalAlignment="Stretch" ScrollViewer.VerticalScrollBarVisibility="Disabled" DoubleTapped="NoteRichEditBox_DoubleTapped" CanDrag="True" AllowDrop="True" IsSpellCheckEnabled="True" IsTextPredictionEnabled="True">
                                          <RichEditBox.Transitions>
                                              <TransitionCollection>
                                                  <EntranceThemeTransition FromHorizontalOffset="0" FromVerticalOffset="12" />
                                              </TransitionCollection>
                                          </RichEditBox.Transitions>
                                          <RichEditBox.Resources>
                                              <Thickness x:Key="TextControlBorderThemeThickness">0</Thickness>
                                              <Thickness x:Key="TextControlBorderThemeThicknessFocused">0</Thickness>
                                              <Thickness x:Key="TextControlBorderThemeThicknessPointerOver">0</Thickness>
                                              <SolidColorBrush x:Key="TextControlBackground" Color="Transparent" />
                                              <SolidColorBrush x:Key="TextControlBackgroundPointerOver" Color="Transparent" />
                                              <SolidColorBrush x:Key="TextControlBackgroundFocused" Color="Transparent" />
                                              <SolidColorBrush x:Key="TextControlBackgroundDisabled" Color="Transparent" />
                                              <SolidColorBrush x:Key="TextControlBorderBrush" Color="Transparent" />
                                              <SolidColorBrush x:Key="TextControlBorderBrushPointerOver" Color="Transparent" />
                                              <SolidColorBrush x:Key="TextControlBorderBrushFocused" Color="Transparent" />
                                              <SolidColorBrush x:Key="TextControlBorderBrushDisabled" Color="Transparent" />
                                          </RichEditBox.Resources>
                                      </RichEditBox>

                                      <!-- Native Markdown Editor (Obsidian-style inline rendering, no WebView2) -->
                                      <local:MarkdownEditorBox x:Name="NativeBlockEditorScroll"
                                                               Grid.Column="0"
                                                               Visibility="Collapsed"
                                                               MinHeight="500"
                                                               AcceptsReturn="True"
                                                               TextWrapping="Wrap"
                                                               BorderThickness="0"
                                                               VerticalAlignment="Stretch"
                                                               HorizontalAlignment="Stretch" />

                                     <!-- Left: NoteEditorWebView (Markdown block editor for new/markdown notes) -->
                                     <WebView2 x:Name="NoteEditorWebView"
                                               Grid.Column="0"
                                               Visibility="Collapsed"
                                               MinHeight="500"
                                               VerticalAlignment="Stretch"
                                               HorizontalAlignment="Stretch"
                                               DefaultBackgroundColor="Transparent">
                                         <WebView2.Transitions>
                                             <TransitionCollection>
                                                 <EntranceThemeTransition FromHorizontalOffset="0" FromVerticalOffset="12" />
                                             </TransitionCollection>
                                         </WebView2.Transitions>
                                     </WebView2>

                                     <!-- Vertical Divider Line -->
                                     <Border x:Name="EditorPreviewDivider" Grid.Column="0" HorizontalAlignment="Right" Width="1" Background="{ThemeResource CardStrokeColorDefaultBrush}" Margin="10,0" Visibility="Collapsed" />

                                     <!-- Right: Live Markdown Preview -->
                                     <RichTextBlock x:Name="MarkdownPreviewTextBlock" Grid.Column="1" Visibility="Collapsed" MinHeight="500" FontSize="16" HorizontalAlignment="Stretch" VerticalAlignment="Stretch" Padding="20,0,0,0" IsTextSelectionEnabled="True">
                                         <RichTextBlock.Transitions>
                                             <TransitionCollection>
                                                 <EntranceThemeTransition FromHorizontalOffset="0" FromVerticalOffset="12" />
                                             </TransitionCollection>
                                         </RichTextBlock.Transitions>
                                     </RichTextBlock>
                                 </Grid>

                                  <Border Margin="0,24,0,40"
                                           Background="{ThemeResource CardBackgroundFillColorDefaultBrush}"
                                           BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}"
                                           BorderThickness="1" CornerRadius="12" Padding="20,16">
                                       <StackPanel Spacing="16">
                                           <!-- Header Row with Title and Auto-Detect Action -->
                                           <Grid>
                                               <Grid.ColumnDefinitions>
                                                   <ColumnDefinition Width="*" />
                                                   <ColumnDefinition Width="Auto" />
                                               </Grid.ColumnDefinitions>
                                               <StackPanel Orientation="Horizontal" Spacing="10" Grid.Column="0">
                                                   <FontIcon Glyph="&#xE81D;" FontFamily="{ThemeResource SymbolThemeFontFamily}"
                                                             FontSize="16" Foreground="{ThemeResource AccentTextFillColorPrimaryBrush}"
                                                             VerticalAlignment="Center" />
                                                   <TextBlock Text="Moments &amp; Attachments" FontSize="15" FontWeight="SemiBold"
                                                              VerticalAlignment="Center" />
                                               </StackPanel>
                                               <Button x:Name="AutoDetectMomentsButton" Click="AutoDetectMoments_Click" Grid.Column="1"
                                                       CornerRadius="12" Padding="10,4"
                                                       Background="{ThemeResource ControlAltFillColorSecondaryBrush}"
                                                       BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}" BorderThickness="1"
                                                       ToolTipService.ToolTip="Auto-detect location and weather">
                                                   <StackPanel Orientation="Horizontal" Spacing="6">
                                                       <FontIcon x:Name="AutoDetectMomentsIcon" Glyph="&#xE81D;" FontFamily="{ThemeResource SymbolThemeFontFamily}"
                                                                 FontSize="12" Foreground="{ThemeResource TextFillColorSecondaryBrush}" />
                                                       <ProgressRing x:Name="AutoDetectMomentsProgress" Width="12" Height="12" IsActive="False" Visibility="Collapsed" VerticalAlignment="Center" />
                                                       <TextBlock x:Name="AutoDetectMomentsText" Text="Auto-detect"
                                                                  FontSize="11" Foreground="{ThemeResource TextFillColorSecondaryBrush}" />
                                                   </StackPanel>
                                               </Button>
                                           </Grid>
                                           
                                           <Border Height="1" Background="{ThemeResource CardStrokeColorDefaultBrush}" />

                                           <!-- Metadata Chip Row -->
                                           <StackPanel Orientation="Horizontal" HorizontalAlignment="Left" Spacing="8">
                                               <!-- Location Chip -->
                                               <Button x:Name="LocationChipButton" Click="LocationChip_Click"
                                                       CornerRadius="16" Padding="12,6"
                                                       Background="{ThemeResource ControlAltFillColorSecondaryBrush}"
                                                       BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}" BorderThickness="1">
                                                   <StackPanel Orientation="Horizontal" Spacing="6">
                                                       <FontIcon Glyph="&#xE707;" FontFamily="{ThemeResource SymbolThemeFontFamily}"
                                                                 FontSize="12" Foreground="{ThemeResource TextFillColorSecondaryBrush}" />
                                                       <TextBlock x:Name="LocationChipText" Text="Add Location"
                                                                  FontSize="12" Foreground="{ThemeResource TextFillColorSecondaryBrush}" />
                                                   </StackPanel>
                                               </Button>
                                               <!-- Weather Chip -->
                                               <Button x:Name="WeatherChipButton"
                                                       CornerRadius="16" Padding="12,6"
                                                       Background="{ThemeResource ControlAltFillColorSecondaryBrush}"
                                                       BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}" BorderThickness="1">
                                                   <StackPanel Orientation="Horizontal" Spacing="6">
                                                       <FontIcon x:Name="WeatherChipIcon" Glyph="&#xE9CA;" FontFamily="{ThemeResource SymbolThemeFontFamily}"
                                                                 FontSize="12" Foreground="{ThemeResource TextFillColorSecondaryBrush}" />
                                                       <TextBlock x:Name="WeatherChipText" Text="Add Weather"
                                                                  FontSize="12" Foreground="{ThemeResource TextFillColorSecondaryBrush}" />
                                                   </StackPanel>
                                                   <Button.Flyout>
                                                       <MenuFlyout>
                                                           <MenuFlyoutItem Text="&#x2600;&#xFE0F;  Sunny" Tag="Sunny" Click="WeatherOption_Click" />
                                                           <MenuFlyoutItem Text="&#x26C5;  Partly Cloudy" Tag="PartlyCloudy" Click="WeatherOption_Click" />
                                                           <MenuFlyoutItem Text="&#x2601;&#xFE0F;  Cloudy" Tag="Cloudy" Click="WeatherOption_Click" />
                                                           <MenuFlyoutItem Text="&#x1F327;&#xFE0F;  Rainy" Tag="Rainy" Click="WeatherOption_Click" />
                                                           <MenuFlyoutItem Text="&#x26A1;  Stormy" Tag="Stormy" Click="WeatherOption_Click" />
                                                           <MenuFlyoutItem Text="&#x2744;&#xFE0F;  Snowy" Tag="Snowy" Click="WeatherOption_Click" />
                                                           <MenuFlyoutItem Text="&#x1F32B;&#xFE0F;  Foggy" Tag="Foggy" Click="WeatherOption_Click" />
                                                           <MenuFlyoutSeparator />
                                                           <MenuFlyoutItem Text="Clear" Tag="" Click="WeatherOption_Click" />
                                                       </MenuFlyout>
                                                   </Button.Flyout>
                                               </Button>
                                           </StackPanel>

                                           <!-- Two-Column Attachments Panel -->
                                           <Grid ColumnSpacing="24" RowSpacing="16" Margin="0,4,0,0">
                                               <Grid.ColumnDefinitions>
                                                   <ColumnDefinition Width="*" />
                                                   <ColumnDefinition Width="*" />
                                               </Grid.ColumnDefinitions>

                                               <!-- Column 0: Photos -->
                                               <StackPanel Grid.Column="0" Spacing="8">
                                                   <TextBlock Text="Photos" FontSize="12" FontWeight="SemiBold"
                                                              Foreground="{ThemeResource TextFillColorSecondaryBrush}" />
                                                   <ScrollViewer HorizontalScrollBarVisibility="Auto"
                                                                 VerticalScrollBarVisibility="Disabled"
                                                                 HorizontalScrollMode="Enabled">
                                                       <StackPanel x:Name="MomentPhotosPanel" Orientation="Horizontal"
                                                                   Spacing="8" Padding="0,2">
                                                           <Button x:Name="AddMomentPhotoButton" Click="AddMomentPhoto_Click"
                                                                   Width="80" Height="80" Padding="0" CornerRadius="10"
                                                                   Background="{ThemeResource ControlAltFillColorSecondaryBrush}"
                                                                   BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}" BorderThickness="1"
                                                                   ToolTipService.ToolTip="Attach a photo to this entry">
                                                               <StackPanel HorizontalAlignment="Center" VerticalAlignment="Center" Spacing="4">
                                                                   <FontIcon Glyph="&#xEB9F;" FontFamily="{ThemeResource SymbolThemeFontFamily}"
                                                                             FontSize="18" Foreground="{ThemeResource TextFillColorSecondaryBrush}" />
                                                                   <TextBlock Text="Add Photo" FontSize="10"
                                                                              Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                                                                              HorizontalAlignment="Center" />
                                                               </StackPanel>
                                                           </Button>
                                                       </StackPanel>
                                                   </ScrollViewer>
                                               </StackPanel>

                                               <!-- Column 1: Voice Memos -->
                                               <StackPanel Grid.Column="1" Spacing="8">
                                                   <TextBlock Text="Voice Memos" FontSize="12" FontWeight="SemiBold"
                                                              Foreground="{ThemeResource TextFillColorSecondaryBrush}" />
                                                   <ComboBox x:Name="MicSelectionComboBox" SelectionChanged="MicSelectionComboBox_SelectionChanged" 
                                                              HorizontalAlignment="Stretch" FontSize="11" Height="30" Padding="8,4" PlaceholderText="Select Microphone" />
                                                   <StackPanel Orientation="Horizontal" Spacing="12">
                                                       <Button x:Name="RecordAudioButton" Click="RecordAudioButton_Click"
                                                               CornerRadius="14" Padding="10,5" 
                                                               Background="{ThemeResource ControlAltFillColorSecondaryBrush}"
                                                               BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}" BorderThickness="1"
                                                               ToolTipService.ToolTip="Record a voice memo">
                                                           <StackPanel Orientation="Horizontal" Spacing="6">
                                                               <FontIcon x:Name="RecordAudioIcon" Glyph="&#xE720;" FontFamily="{ThemeResource SymbolThemeFontFamily}" FontSize="11" Foreground="Red" />
                                                               <TextBlock x:Name="RecordAudioText" Text="Record Memo" FontSize="11" FontWeight="Medium" />
                                                           </StackPanel>
                                                       </Button>
                                                       <TextBlock x:Name="RecordingTimerTextBlock" Text="00:00" FontSize="12" VerticalAlignment="Center" Visibility="Collapsed" Foreground="{ThemeResource TextFillColorSecondaryBrush}" />
                                                   </StackPanel>
                                                   <StackPanel x:Name="AttachedAudioPanel" Spacing="6" Padding="0,2" />
                                               </StackPanel>
                                           </Grid>

                                            <Border Height="1" Background="{ThemeResource CardStrokeColorDefaultBrush}" Margin="0,8" />

                                            <!-- Tags Section -->
                                            <StackPanel Spacing="8">
                                                <TextBlock Text="Tags &amp; Keywords" FontSize="12" FontWeight="SemiBold"
                                                           Foreground="{ThemeResource TextFillColorSecondaryBrush}" />
                                                <StackPanel Orientation="Horizontal" Spacing="8">
                                                    <TextBox x:Name="NewTagTextBox" PlaceholderText="Add/create tag..." 
                                                             Width="180" Height="30" FontSize="11"
                                                             KeyDown="NewTagTextBox_KeyDown" />
                                                    <Button x:Name="AddTagBtn" Content="Add Tag" Click="AddTagBtn_Click" 
                                                            CornerRadius="14" Padding="12,4" FontSize="11"
                                                            Background="{ThemeResource ControlAltFillColorSecondaryBrush}"
                                                            BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}" BorderThickness="1" />
                                                </StackPanel>
                                                <StackPanel x:Name="AttachedTagsPanel" Orientation="Horizontal" Spacing="6" Padding="0,2" />
                                            </StackPanel>
                                       </StackPanel>
                                   </Border>
                            </StackPanel>
                        </Grid>
                    </ScrollViewer>

                        <!-- ════ AI ASSISTANT SIDE PANEL ════ -->
                        <Border x:Name="AIAssistantPanel"
                                Grid.Column="1"
                                Visibility="Collapsed"
                                Width="0"
                                Margin="0"
                                VerticalAlignment="Stretch"
                                Background="{ThemeResource CardBackgroundFillColorDefaultBrush}"
                                BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}"
                                BorderThickness="1"
                                CornerRadius="12">
                            <Grid HorizontalAlignment="Stretch">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="6" />
                                    <ColumnDefinition Width="*" />
                                </Grid.ColumnDefinitions>
                                
                                <!-- Resizing Splitter handle -->
                                <Border Grid.Column="0" 
                                        x:Name="AIPanelSplitter" 
                                        Background="Transparent" 
                                        BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}"
                                        BorderThickness="0,0,1,0"
                                        VerticalAlignment="Stretch"
                                        PointerPressed="AIPanelSplitter_PointerPressed"
                                        PointerReleased="AIPanelSplitter_PointerReleased"
                                        PointerMoved="AIPanelSplitter_PointerMoved"
                                        PointerEntered="AIPanelSplitter_PointerEntered"
                                        PointerExited="AIPanelSplitter_PointerExited" />

                                <!-- Original panel content Grid, placed in Column 1 -->
                                <Grid Grid.Column="1" HorizontalAlignment="Stretch">
                                <Grid.RowDefinitions>
                                    <RowDefinition Height="Auto" />
                                    <RowDefinition Height="Auto" />
                                    <RowDefinition Height="Auto" />
                                    <RowDefinition Height="*" />
                                    <RowDefinition Height="Auto" />
                                    <RowDefinition Height="Auto" />
                                </Grid.RowDefinitions>

                                <!-- Header -->
                                <Grid Grid.Row="0" Padding="16,12,16,8">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*" />
                                        <ColumnDefinition Width="Auto" />
                                    </Grid.ColumnDefinitions>
                                    <StackPanel Grid.Column="0" Orientation="Horizontal" Spacing="8">
                                        <FontIcon Glyph="&#xE99A;" FontFamily="{ThemeResource SymbolThemeFontFamily}" FontSize="16" />
                                        <TextBlock Text="AI Assistant" FontSize="14" FontWeight="SemiBold" VerticalAlignment="Center" />
                                    </StackPanel>
                                    <StackPanel Grid.Column="1" Orientation="Horizontal" Spacing="6" VerticalAlignment="Center">
                                        <FontIcon x:Name="OllamaStatusIcon" Glyph="&#xE711;" FontFamily="{ThemeResource SymbolThemeFontFamily}" FontSize="12" />
                                        <TextBlock x:Name="OllamaStatusText" Text="—" FontSize="11" Foreground="{ThemeResource TextFillColorSecondaryBrush}" VerticalAlignment="Center" />
                                    </StackPanel>
                                </Grid>

                                <!-- Model Selector -->
                                <StackPanel Grid.Row="1" Padding="12,0,12,8" Spacing="6">
                                    <ComboBox x:Name="AIModelCombo" HorizontalAlignment="Stretch" PlaceholderText="Select model…" />
                                    <Button x:Name="AICheckConnectionButton" Content="Check Connection" HorizontalAlignment="Stretch" Click="AICheckConnectionButton_Click" Padding="8,4" />
                                    <ToggleSwitch x:Name="AIRagToggle" 
                                                  Header="Search History (Local RAG)" 
                                                  FontSize="12" 
                                                  OnContent="Enabled" 
                                                  OffContent="Disabled" 
                                                  IsOn="False" 
                                                  Margin="0,4,0,0"/>
                                </StackPanel>

                                <!-- Action Buttons grid -->
                                <Grid Grid.Row="2" Padding="12,0,12,8">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*" />
                                        <ColumnDefinition Width="*" />
                                    </Grid.ColumnDefinitions>
                                    <Grid.RowDefinitions>
                                        <RowDefinition Height="Auto" />
                                        <RowDefinition Height="Auto" />
                                        <RowDefinition Height="Auto" />
                                    </Grid.RowDefinitions>
                                    <Button x:Name="AIContinueButton" Grid.Row="0" Grid.Column="0" Content="✏️ Continue" Click="AIContinueButton_Click" Margin="0,3,3,3" HorizontalAlignment="Stretch" CornerRadius="8" />
                                    <Button x:Name="AISummarizeButton" Grid.Row="0" Grid.Column="1" Content="📝 Summarize" Click="AISummarizeButton_Click" Margin="3,3,0,3" HorizontalAlignment="Stretch" CornerRadius="8" />
                                    <Button x:Name="AIRewriteButton" Grid.Row="1" Grid.Column="0" Content="🔄 Rewrite" Click="AIRewriteButton_Click" Margin="0,3,3,3" HorizontalAlignment="Stretch" CornerRadius="8" />
                                    <Button x:Name="AIPromptButton" Grid.Row="1" Grid.Column="1" Content="💡 Prompt" Click="AIPromptButton_Click" Margin="3,3,0,3" HorizontalAlignment="Stretch" CornerRadius="8" />
                                    <Button x:Name="AIMoodButton" Grid.Row="2" Grid.Column="0" Content="😊 Mood" Click="AIMoodButton_Click" Margin="0,3,3,3" HorizontalAlignment="Stretch" CornerRadius="8" />
                                    <Button x:Name="AITranslateButton" Grid.Row="2" Grid.Column="1" Content="🌐 Translate" Click="AITranslateButton_Click" Margin="3,3,0,3" HorizontalAlignment="Stretch" CornerRadius="8" />
                                </Grid>

                                <!-- Response ScrollViewer -->
                                <Border Grid.Row="3" Margin="12,0,12,8" Background="{ThemeResource LayerFillColorDefaultBrush}" CornerRadius="8" Padding="10">
                                    <ScrollViewer x:Name="AIChatScrollViewer" VerticalScrollBarVisibility="Auto">
                                        <StackPanel x:Name="AIChatPanel" Spacing="8" VerticalAlignment="Bottom">
                                            <!-- Initial placeholder welcome bubble -->
                                            <Border x:Name="AIChatPlaceholder" Background="{ThemeResource CardBackgroundFillColorDefaultBrush}" CornerRadius="8" Padding="12" Margin="4,4,40,4" HorizontalAlignment="Left" BorderThickness="1" BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}">
                                                <TextBlock Text="Hi! I am your AI Assistant. You can choose an action button above or type a message below." 
                                                           TextWrapping="Wrap" 
                                                           FontSize="13" 
                                                           Foreground="{ThemeResource TextFillColorSecondaryBrush}" />
                                            </Border>
                                        </StackPanel>
                                    </ScrollViewer>
                                </Border>

                                <!-- Chat Input Box -->
                                <Grid Grid.Row="4" Margin="12,0,12,8" ColumnSpacing="8">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*" />
                                        <ColumnDefinition Width="Auto" />
                                    </Grid.ColumnDefinitions>
                                    <TextBox x:Name="AIChatInputBox" 
                                             Grid.Column="0" 
                                             PlaceholderText="Ask the AI anything..." 
                                             AcceptsReturn="True" 
                                             MaxHeight="80" 
                                             PreviewKeyDown="AIChatInputBox_PreviewKeyDown" 
                                             CornerRadius="8" />
                                    <Button x:Name="AIChatSendButton" 
                                            Grid.Column="1" 
                                            Content="&#xE724;" 
                                            FontFamily="{ThemeResource SymbolThemeFontFamily}" 
                                            Click="AIChatSendButton_Click" 
                                            VerticalAlignment="Bottom"
                                            Height="36"
                                            Width="36"
                                            Padding="0"
                                            CornerRadius="8" 
                                            Style="{StaticResource AccentButtonStyle}" />
                                </Grid>

                                <!-- Footer -->
                                <StackPanel Grid.Row="5" Orientation="Horizontal" Spacing="8" Padding="12,0,12,12" HorizontalAlignment="Right">
                                    <Button x:Name="AIStopButton" Content="⏹ Stop" Click="AIStopButton_Click" Visibility="Collapsed" CornerRadius="8" />
                                    <Button x:Name="AIClearButton" Content="Clear" Click="AIClearButton_Click" CornerRadius="8" />
                                    <Button x:Name="AIInsertButton" Content="⬇ Insert" Click="AIInsertButton_Click" IsEnabled="False" CornerRadius="8" Style="{StaticResource AccentButtonStyle}" />
                                </StackPanel>
                            </Grid>
                        </Grid>
                    </Border>
                        <!-- END AI ASSISTANT SIDE PANEL -->

                    </Grid>

                    <!-- Placeholder panel when no note is selected -->
                    <Grid x:Name="NoNotePlaceholder" Grid.Row="0" Grid.RowSpan="4" HorizontalAlignment="Center" VerticalAlignment="Center">
                        <Grid.Transitions>
                            <TransitionCollection>
                                <EntranceThemeTransition FromHorizontalOffset="0" FromVerticalOffset="16" />
                            </TransitionCollection>
                        </Grid.Transitions>
                        <StackPanel Spacing="16" HorizontalAlignment="Center">
                            <Image Source="ms-appx:///Assets/Square150x150Logo.scale-200.png" Width="96" Height="96" HorizontalAlignment="Center" Margin="0,0,0,8" />
                            <TextBlock Text="No Journal Entry Selected" FontSize="18" FontWeight="SemiBold" Foreground="{ThemeResource TextFillColorSecondaryBrush}" HorizontalAlignment="Center" />
                            <Button x:Name="PlaceholderNewNoteButton" Content="Create New Entry" Click="NewNoteButton_Click" HorizontalAlignment="Center" Style="{StaticResource AccentButtonStyle}" CornerRadius="16" Padding="16,8" />
                        </StackPanel>
                    </Grid>

                    <!-- Status Bar (Only in Editor) -->
                    <Grid x:Name="EditorStatusBar" Grid.Row="3" Background="Transparent" Height="28" BorderThickness="0,1,0,0" BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}" Padding="16,0" VerticalAlignment="Bottom" Visibility="Collapsed">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="Auto" />
                            <ColumnDefinition Width="*" />
                        </Grid.ColumnDefinitions>
                        
                        <!-- Left Status Message -->
                        <StackPanel Grid.Column="0" Orientation="Horizontal" Spacing="8" VerticalAlignment="Center">
                            <FontIcon Glyph="&#xE73E;" FontFamily="{ThemeResource SymbolThemeFontFamily}" FontSize="10" Foreground="{ThemeResource TextFillColorSecondaryBrush}" />
                            <TextBlock x:Name="StatusMessageTextBlock" Text="All changes saved locally" FontSize="11" Foreground="{ThemeResource TextFillColorSecondaryBrush}" VerticalAlignment="Center" />
                        </StackPanel>

                        <!-- Center Note Count -->
                        <TextBlock x:Name="EntryCountTextBlock" Grid.Column="1" Text="0 entries" FontSize="11" FontWeight="SemiBold" Foreground="{ThemeResource TextFillColorSecondaryBrush}" HorizontalAlignment="Center" VerticalAlignment="Center" />

                        <!-- Right Word / Character Count -->
                        <TextBlock x:Name="WordCountTextBlock" Grid.Column="2" Text="Word Count: 0 | Characters: 0" FontSize="11" Foreground="{ThemeResource TextFillColorSecondaryBrush}" HorizontalAlignment="Right" VerticalAlignment="Center" />
                    </Grid>



                </Grid>

                <!-- Undo Trash InfoBar overlay (bottom of editor column) -->
                <InfoBar x:Name="UndoTrashInfoBar"
                         Grid.Column="2"
                         IsOpen="False"
                         Severity="Informational"
                         Title=""
                         Message="Moved to Trash"
                         IsClosable="True"
                         VerticalAlignment="Bottom"
                         HorizontalAlignment="Stretch"
                         Margin="16,0,16,40"
                         CornerRadius="8">
                    <InfoBar.ActionButton>
                        <Button x:Name="UndoTrashButton" Content="Undo" Click="UndoTrashButton_Click"
                                Style="{StaticResource AccentButtonStyle}" Padding="12,4" />
                    </InfoBar.ActionButton>
                </InfoBar>
            </Grid>
            
            <Grid x:Name="SettingsGrid" Visibility="Collapsed" Padding="0,24,0,0">
                <Grid.RowDefinitions>
                    <RowDefinition Height="*" />
                    <RowDefinition Height="Auto" />
                </Grid.RowDefinitions>
                
                <!-- Scrollable Settings Content -->
                <ScrollViewer Grid.Row="0" VerticalScrollBarVisibility="Auto" HorizontalAlignment="Stretch">
                    <StackPanel MaxWidth="1000"
                                HorizontalAlignment="Stretch"
                                Padding="40,40,40,40"
                                Spacing="8">
                        <!-- Hidden element to force uniform 1000px layout width -->
                        <Border Width="1000" Height="0" HorizontalAlignment="Stretch" Visibility="Visible" IsHitTestVisible="False" />
                        
                        <!-- Settings Header -->
                        <TextBlock Text="Settings" FontSize="28" FontWeight="Bold" Margin="0,0,0,16" />

                        <!-- ── Appearance & behavior ── -->
                        <StackPanel Spacing="4" HorizontalAlignment="Stretch">
                            <TextBlock Text="Appearance &amp; behavior" FontSize="12" FontWeight="SemiBold"
                                       Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                                       Margin="4,0,0,8" CharacterSpacing="50" />

                            <!-- App Theme -->
                            <Border Background="{ThemeResource CardBackgroundFillColorDefaultBrush}" BorderThickness="1" BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}" CornerRadius="8" Padding="16,12">
                                <Grid ColumnSpacing="32">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="Auto" />
                                        <ColumnDefinition Width="*" />
                                        <ColumnDefinition Width="Auto" />
                                    </Grid.ColumnDefinitions>
                                    <FontIcon Grid.Column="0" Glyph="&#xE790;" FontFamily="{ThemeResource SymbolThemeFontFamily}" FontSize="18" VerticalAlignment="Center" Width="24" />
                                    <StackPanel Grid.Column="1" VerticalAlignment="Center" Spacing="2">
                                        <TextBlock Text="App theme" FontSize="14" FontWeight="Medium" />
                                        <TextBlock Text="Select which app theme to display" FontSize="12" Foreground="{ThemeResource TextFillColorSecondaryBrush}" />
                                    </StackPanel>
                                    <ComboBox x:Name="ThemeComboBox" Grid.Column="2" Width="150" VerticalAlignment="Center" SelectionChanged="ThemeComboBox_SelectionChanged">
                                        <ComboBoxItem Content="Default" Tag="Default" IsSelected="True" />
                                        <ComboBoxItem Content="Light" Tag="Light" />
                                        <ComboBoxItem Content="Dark" Tag="Dark" />
                                        <ComboBoxItem Content="Sepia" Tag="Sepia" />
                                        <ComboBoxItem Content="Nord" Tag="Nord" />
                                        <ComboBoxItem Content="Dracula" Tag="Dracula" />
                                        <ComboBoxItem Content="Forest" Tag="Forest" />
                                    </ComboBox>
                                </Grid>
                            </Border>

                            <!-- Window Backdrop -->
                            <Border Background="{ThemeResource CardBackgroundFillColorDefaultBrush}" BorderThickness="1" BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}" CornerRadius="8" Padding="16,12">
                                <Grid ColumnSpacing="32">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="Auto" />
                                        <ColumnDefinition Width="*" />
                                        <ColumnDefinition Width="Auto" />
                                    </Grid.ColumnDefinitions>
                                    <FontIcon Grid.Column="0" Glyph="&#xE7F4;" FontFamily="{ThemeResource SymbolThemeFontFamily}" FontSize="18" VerticalAlignment="Center" Width="24" />
                                    <StackPanel Grid.Column="1" VerticalAlignment="Center" Spacing="2">
                                        <TextBlock Text="Window backdrop" FontSize="14" FontWeight="Medium" />
                                        <TextBlock Text="Select the material type for the app backdrop" FontSize="12" Foreground="{ThemeResource TextFillColorSecondaryBrush}" />
                                    </StackPanel>
                                    <ComboBox x:Name="BackdropComboBox" Grid.Column="2" Width="150" VerticalAlignment="Center" SelectionChanged="BackdropComboBox_SelectionChanged">
                                        <ComboBoxItem Content="Mica Alt" Tag="MicaAlt" />
                                        <ComboBoxItem Content="Mica" Tag="Mica" />
                                        <ComboBoxItem Content="Acrylic" Tag="Acrylic" />
                                    </ComboBox>
                                </Grid>
                            </Border>

                            <!-- Markdown vs Rich Text Editor Style -->
                            <Border Background="{ThemeResource CardBackgroundFillColorDefaultBrush}" BorderThickness="1" BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}" CornerRadius="8" Padding="16,12">
                                <Grid ColumnSpacing="32">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="Auto" />
                                        <ColumnDefinition Width="*" />
                                        <ColumnDefinition Width="Auto" />
                                    </Grid.ColumnDefinitions>
                                    <FontIcon Grid.Column="0" Glyph="&#xE90A;" FontFamily="{ThemeResource SymbolThemeFontFamily}" FontSize="18" VerticalAlignment="Center" Width="24" />
                                    <StackPanel Grid.Column="1" VerticalAlignment="Center" Spacing="2">
                                        <TextBlock Text="Default Editor Format" FontSize="14" FontWeight="Medium" />
                                        <TextBlock Text="Select default text format for newly created journal entries" FontSize="12" Foreground="{ThemeResource TextFillColorSecondaryBrush}" />
                                    </StackPanel>
                                    <ComboBox x:Name="DefaultEditorStyleComboBox" Grid.Column="2" Width="150" VerticalAlignment="Center" SelectionChanged="DefaultEditorStyleComboBox_SelectionChanged">
                                        <ComboBoxItem Content="Rich Text (Recommended)" Tag="rtf" IsSelected="True" />
                                        <ComboBoxItem Content="Markdown (Beta)" Tag="markdown" />
                                    </ComboBox>
                                </Grid>
                            </Border>

                            <!-- Editor Default Font -->
                            <Border Background="{ThemeResource CardBackgroundFillColorDefaultBrush}" BorderThickness="1" BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}" CornerRadius="8" Padding="16,12">
                                <Grid ColumnSpacing="32">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="Auto" />
                                        <ColumnDefinition Width="*" />
                                        <ColumnDefinition Width="Auto" />
                                    </Grid.ColumnDefinitions>
                                    <FontIcon Grid.Column="0" Glyph="&#xE70F;" FontFamily="{ThemeResource SymbolThemeFontFamily}" FontSize="18" VerticalAlignment="Center" Width="24" />
                                    <StackPanel Grid.Column="1" VerticalAlignment="Center" Spacing="2">
                                        <TextBlock Text="Editor Default Font" FontSize="14" FontWeight="Medium" />
                                        <TextBlock Text="Select the default typeface for writing journal titles and entries" FontSize="12" Foreground="{ThemeResource TextFillColorSecondaryBrush}" />
                                    </StackPanel>
                                    <ComboBox x:Name="EditorFontComboBox" Grid.Column="2" Width="150" VerticalAlignment="Center" SelectionChanged="EditorFontComboBox_SelectionChanged">
                                        <ComboBoxItem Content="Segoe UI" Tag="Segoe UI" IsSelected="True" />
                                        <ComboBoxItem Content="Inter" Tag="Inter" />
                                        <ComboBoxItem Content="Roboto" Tag="Roboto" />
                                        <ComboBoxItem Content="Outfit" Tag="Outfit" />
                                        <ComboBoxItem Content="Courier New" Tag="Courier New" />
                                        <ComboBoxItem Content="Georgia" Tag="Georgia" />
                                        <ComboBoxItem Content="Consolas" Tag="Consolas" />
                                    </ComboBox>
                                </Grid>
                            </Border>

                            <!-- Editor Default Font Size -->
                            <Border Background="{ThemeResource CardBackgroundFillColorDefaultBrush}" BorderThickness="1" BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}" CornerRadius="8" Padding="16,12">
                                <Grid ColumnSpacing="32">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="Auto" />
                                        <ColumnDefinition Width="*" />
                                        <ColumnDefinition Width="Auto" />
                                    </Grid.ColumnDefinitions>
                                    <FontIcon Grid.Column="0" Glyph="&#xE8E9;" FontFamily="{ThemeResource SymbolThemeFontFamily}" FontSize="18" VerticalAlignment="Center" Width="24" />
                                    <StackPanel Grid.Column="1" VerticalAlignment="Center" Spacing="2">
                                        <TextBlock Text="Editor Default Font Size" FontSize="14" FontWeight="Medium" />
                                        <TextBlock Text="Select the default font size (px) for writing journal entries" FontSize="12" Foreground="{ThemeResource TextFillColorSecondaryBrush}" />
                                    </StackPanel>
                                    <Slider x:Name="EditorFontSizeSlider" Grid.Column="2" Width="180" VerticalAlignment="Center" Minimum="10" Maximum="28" Value="14.0" StepFrequency="1" ValueChanged="EditorFontSizeSlider_ValueChanged" />
                                </Grid>
                            </Border>

                            <!-- Auto-Save Interval -->
                            <Border Background="{ThemeResource CardBackgroundFillColorDefaultBrush}" BorderThickness="1" BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}" CornerRadius="8" Padding="16,12">
                                <Grid ColumnSpacing="32">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="Auto" />
                                        <ColumnDefinition Width="*" />
                                        <ColumnDefinition Width="Auto" />
                                    </Grid.ColumnDefinitions>
                                    <FontIcon Grid.Column="0" Glyph="&#xE916;" FontFamily="{ThemeResource SymbolThemeFontFamily}" FontSize="18" VerticalAlignment="Center" Width="24" />
                                    <StackPanel Grid.Column="1" VerticalAlignment="Center" Spacing="2">
                                        <TextBlock Text="Auto-Save Interval" FontSize="14" FontWeight="Medium" />
                                        <TextBlock Text="Adjust the background auto-save delay (seconds)" FontSize="12" Foreground="{ThemeResource TextFillColorSecondaryBrush}" />
                                    </StackPanel>
                                    <Slider x:Name="AutoSaveSlider" Grid.Column="2" Width="180" VerticalAlignment="Center" Minimum="1" Maximum="10" Value="5.0" StepFrequency="0.5" ValueChanged="AutoSaveSlider_ValueChanged" />
                                </Grid>
                            </Border>

                            <!-- Spell Check -->
                            <Border Background="{ThemeResource CardBackgroundFillColorDefaultBrush}" BorderThickness="1" BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}" CornerRadius="8" Padding="16,12">
                                <Grid ColumnSpacing="32">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="Auto" />
                                        <ColumnDefinition Width="*" />
                                        <ColumnDefinition Width="Auto" />
                                    </Grid.ColumnDefinitions>
                                    <FontIcon Grid.Column="0" Glyph="&#xF87B;" FontFamily="{ThemeResource SymbolThemeFontFamily}" FontSize="18" VerticalAlignment="Center" Width="24" />
                                    <StackPanel Grid.Column="1" VerticalAlignment="Center" Spacing="2">
                                        <TextBlock Text="Spell Check" FontSize="14" FontWeight="Medium" />
                                        <TextBlock Text="Underline misspelled words while writing" FontSize="12" Foreground="{ThemeResource TextFillColorSecondaryBrush}" />
                                    </StackPanel>
                                    <ToggleSwitch x:Name="SpellCheckToggle" Grid.Column="2" IsOn="True" OnContent="On" OffContent="Off" VerticalAlignment="Center" Toggled="SpellCheckToggle_Toggled" />
                                </Grid>
                            </Border>

                            <!-- Show Word Count -->
                            <Border Background="{ThemeResource CardBackgroundFillColorDefaultBrush}" BorderThickness="1" BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}" CornerRadius="8" Padding="16,12">
                                <Grid ColumnSpacing="32">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="Auto" />
                                        <ColumnDefinition Width="*" />
                                        <ColumnDefinition Width="Auto" />
                                    </Grid.ColumnDefinitions>
                                    <FontIcon Grid.Column="0" Glyph="&#xE8C1;" FontFamily="{ThemeResource SymbolThemeFontFamily}" FontSize="18" VerticalAlignment="Center" Width="24" />
                                    <StackPanel Grid.Column="1" VerticalAlignment="Center" Spacing="2">
                                        <TextBlock Text="Show Word Count" FontSize="14" FontWeight="Medium" />
                                        <TextBlock Text="Display word count, characters, and reading time in the status bar" FontSize="12" Foreground="{ThemeResource TextFillColorSecondaryBrush}" />
                                    </StackPanel>
                                    <ToggleSwitch x:Name="ShowWordCountToggle" Grid.Column="2" IsOn="True" OnContent="On" OffContent="Off" VerticalAlignment="Center" Toggled="ShowWordCountToggle_Toggled" />
                                </Grid>
                            </Border>

                            <!-- Show Note Snippets -->
                            <Border Background="{ThemeResource CardBackgroundFillColorDefaultBrush}" BorderThickness="1" BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}" CornerRadius="8" Padding="16,12">
                                <Grid ColumnSpacing="32">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="Auto" />
                                        <ColumnDefinition Width="*" />
                                        <ColumnDefinition Width="Auto" />
                                    </Grid.ColumnDefinitions>
                                    <FontIcon Grid.Column="0" Glyph="&#xE8A4;" FontFamily="{ThemeResource SymbolThemeFontFamily}" FontSize="18" VerticalAlignment="Center" Width="24" />
                                    <StackPanel Grid.Column="1" VerticalAlignment="Center" Spacing="2">
                                        <TextBlock Text="Show Note Snippets" FontSize="14" FontWeight="Medium" />
                                        <TextBlock Text="Show a preview of note content below the title in the list" FontSize="12" Foreground="{ThemeResource TextFillColorSecondaryBrush}" />
                                    </StackPanel>
                                    <ToggleSwitch x:Name="ShowSnippetsToggle" Grid.Column="2" IsOn="True" OnContent="On" OffContent="Off" VerticalAlignment="Center" Toggled="ShowSnippetsToggle_Toggled" />
                                </Grid>
                            </Border>

                            <!-- Default Sort Order -->
                            <Border Background="{ThemeResource CardBackgroundFillColorDefaultBrush}" BorderThickness="1" BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}" CornerRadius="8" Padding="16,12">
                                <Grid ColumnSpacing="32">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="Auto" />
                                        <ColumnDefinition Width="*" />
                                        <ColumnDefinition Width="Auto" />
                                    </Grid.ColumnDefinitions>
                                    <FontIcon Grid.Column="0" Glyph="&#xE8CB;" FontFamily="{ThemeResource SymbolThemeFontFamily}" FontSize="18" VerticalAlignment="Center" Width="24" />
                                    <StackPanel Grid.Column="1" VerticalAlignment="Center" Spacing="2">
                                        <TextBlock Text="Default Sort Order" FontSize="14" FontWeight="Medium" />
                                        <TextBlock Text="Choose how notes are ordered when opening the app" FontSize="12" Foreground="{ThemeResource TextFillColorSecondaryBrush}" />
                                    </StackPanel>
                                    <ComboBox x:Name="DefaultSortComboBox" Grid.Column="2" Width="180" VerticalAlignment="Center" SelectionChanged="DefaultSortComboBox_SelectionChanged">
                                        <ComboBoxItem Content="Newest First" Tag="DateCreatedDesc" IsSelected="True" />
                                        <ComboBoxItem Content="Oldest First" Tag="DateCreatedAsc" />
                                        <ComboBoxItem Content="Last Modified" Tag="DateModifiedDesc" />
                                        <ComboBoxItem Content="Title A→Z" Tag="TitleAsc" />
                                        <ComboBoxItem Content="Title Z→A" Tag="TitleDesc" />
                                    </ComboBox>
                                </Grid>
                            </Border>

                            <!-- Confirm Before Delete -->
                            <Border Background="{ThemeResource CardBackgroundFillColorDefaultBrush}" BorderThickness="1" BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}" CornerRadius="8" Padding="16,12">
                                <Grid ColumnSpacing="32">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="Auto" />
                                        <ColumnDefinition Width="*" />
                                        <ColumnDefinition Width="Auto" />
                                    </Grid.ColumnDefinitions>
                                    <FontIcon Grid.Column="0" Glyph="&#xE74D;" FontFamily="{ThemeResource SymbolThemeFontFamily}" FontSize="18" VerticalAlignment="Center" Width="24" />
                                    <StackPanel Grid.Column="1" VerticalAlignment="Center" Spacing="2">
                                        <TextBlock Text="Confirm Before Delete" FontSize="14" FontWeight="Medium" />
                                        <TextBlock Text="Show a confirmation dialog before moving a note to Trash" FontSize="12" Foreground="{ThemeResource TextFillColorSecondaryBrush}" />
                                    </StackPanel>
                                    <ToggleSwitch x:Name="ConfirmDeleteToggle" Grid.Column="2" IsOn="False" OnContent="On" OffContent="Off" VerticalAlignment="Center" Toggled="ConfirmDeleteToggle_Toggled" />
                                </Grid>
                            </Border>
                        </StackPanel>



                        <!-- ── Services & Sync ── -->
                        <StackPanel Spacing="4">
                            <TextBlock Text="Services &amp; Sync" FontSize="12" FontWeight="SemiBold"
                                       Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                                       Margin="4,8,0,8" CharacterSpacing="50" />

                            <!-- Unsplash API Integration -->
                            <Expander IsExpanded="False" ExpandDirection="Down" HorizontalAlignment="Stretch" HorizontalContentAlignment="Stretch">
                                <Expander.Header>
                                    <Grid ColumnSpacing="32" Padding="4,8">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="Auto" />
                                            <ColumnDefinition Width="*" />
                                            <ColumnDefinition Width="Auto" />
                                        </Grid.ColumnDefinitions>
                                        <FontIcon Grid.Column="0" Glyph="&#xEB9F;" FontFamily="{ThemeResource SymbolThemeFontFamily}" FontSize="18" VerticalAlignment="Center" Width="24" />
                                        <StackPanel Grid.Column="1" VerticalAlignment="Center" Spacing="2">
                                            <TextBlock Text="Unsplash API Integration" FontSize="14" FontWeight="Medium" />
                                            <TextBlock Text="Configure a custom Unsplash Access Key for cover banners" FontSize="12" Foreground="{ThemeResource TextFillColorSecondaryBrush}" />
                                        </StackPanel>
                                        <Button x:Name="UnsplashKeyButton" Content="Get Key" Grid.Column="2" Click="GetUnsplashKeyButton_Click" VerticalAlignment="Center" Style="{StaticResource AccentButtonStyle}" />
                                    </Grid>
                                </Expander.Header>
                                <PasswordBox x:Name="UnsplashTokenPasswordBox" Margin="40,0,0,8" PasswordChanged="UnsplashTokenPasswordBox_PasswordChanged" PlaceholderText="Paste your access key here..." PasswordRevealMode="Hidden" Header="Unsplash Access Key" HorizontalAlignment="Stretch" />
                            </Expander>

                            <!-- GitHub Sync & Backup -->
                            <Expander IsExpanded="False" ExpandDirection="Down" HorizontalAlignment="Stretch" HorizontalContentAlignment="Stretch">
                                <Expander.Header>
                                    <Grid ColumnSpacing="32" Padding="4,8">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="Auto" />
                                            <ColumnDefinition Width="*" />
                                            <ColumnDefinition Width="Auto" />
                                        </Grid.ColumnDefinitions>
                                        <FontIcon Grid.Column="0" Glyph="&#xE895;" FontFamily="{ThemeResource SymbolThemeFontFamily}" FontSize="18" VerticalAlignment="Center" Width="24" />
                                        <StackPanel Grid.Column="1" VerticalAlignment="Center" Spacing="2">
                                            <TextBlock Text="GitHub Sync &amp; Backup" FontSize="14" FontWeight="Medium" />
                                            <TextBlock Text="Backup and sync your journal entries to a private GitHub repository" FontSize="12" Foreground="{ThemeResource TextFillColorSecondaryBrush}" />
                                        </StackPanel>
                                        <StackPanel Grid.Column="2" Orientation="Horizontal" Spacing="8" VerticalAlignment="Center">
                                            <Button x:Name="GitHubSyncButton" Content="Sync" Click="GitHubSyncButton_Click" Style="{StaticResource AccentButtonStyle}" />
                                            <Button x:Name="GitHubPullButton" Content="Pull Backup" Click="GitHubPullButton_Click" Visibility="Collapsed" />
                                            <Button x:Name="GitHubDisconnectButton" Content="Disconnect" Click="GitHubDisconnectButton_Click" Visibility="Collapsed" />
                                        </StackPanel>
                                    </Grid>
                                </Expander.Header>
                                <StackPanel Spacing="12" Margin="40,0,0,8">
                                    <Grid ColumnSpacing="12">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="*" />
                                            <ColumnDefinition Width="*" />
                                        </Grid.ColumnDefinitions>
                                        <PasswordBox x:Name="GitHubTokenPasswordBox" Header="GitHub Personal Access Token (PAT)" PlaceholderText="ghp_..." PasswordRevealMode="Hidden" Grid.Column="0" PasswordChanged="GitHubTokenPasswordBox_PasswordChanged" />
                                        <TextBox x:Name="GitHubRepoTextBox" Header="Repository Name" Text="My-JournalApp-Backup" Grid.Column="1" TextChanged="GitHubRepoTextBox_TextChanged" />
                                    </Grid>
                                    <StackPanel x:Name="GitHubStatusPanel" Spacing="4" Visibility="Collapsed">
                                        <TextBlock x:Name="GitHubStatusTitle" Text="Status: Connected" FontSize="13" FontWeight="Medium" />
                                        <TextBlock x:Name="GitHubStatusDetails" Text="Last synced: Never" FontSize="11" Foreground="{ThemeResource TextFillColorSecondaryBrush}" />
                                        <ProgressBar x:Name="GitHubSyncProgressBar" IsIndeterminate="False" Height="4" Value="0" Margin="0,4,0,0" Visibility="Collapsed" />
                                    </StackPanel>
                                    <ToggleSwitch x:Name="AutoBackupToggle" Header="Auto-Backup on Save" IsOn="False" Toggled="AutoBackupToggle_Toggled" OnContent="Enabled" OffContent="Disabled" Margin="0,8,0,0" />
                                </StackPanel>
                            </Expander>

                            <!-- Local/Network Backup -->
                            <Expander IsExpanded="False" ExpandDirection="Down" HorizontalAlignment="Stretch" HorizontalContentAlignment="Stretch">
                                <Expander.Header>
                                    <Grid ColumnSpacing="32" Padding="4,8">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="Auto" />
                                            <ColumnDefinition Width="*" />
                                            <ColumnDefinition Width="Auto" />
                                        </Grid.ColumnDefinitions>
                                        <FontIcon Grid.Column="0" Glyph="&#xE8B7;" FontFamily="{ThemeResource SymbolThemeFontFamily}" FontSize="18" VerticalAlignment="Center" Width="24" />
                                        <StackPanel Grid.Column="1" VerticalAlignment="Center" Spacing="2">
                                            <TextBlock Text="Local/Network Drive Backup" FontSize="14" FontWeight="Medium" />
                                            <TextBlock Text="Backup your journal to a local folder, external SSD, or network drive (NAS)" FontSize="12" Foreground="{ThemeResource TextFillColorSecondaryBrush}" />
                                        </StackPanel>
                                        <StackPanel Grid.Column="2" Orientation="Horizontal" Spacing="8" VerticalAlignment="Center">
                                            <Button x:Name="LocalBackupSyncButton" Content="Sync" Click="LocalBackupSyncButton_Click" Style="{StaticResource AccentButtonStyle}" />
                                            <Button x:Name="LocalBackupPullButton" Content="Pull Backup" Click="LocalBackupPullButton_Click" Visibility="Collapsed" />
                                            <Button x:Name="LocalBackupDisconnectButton" Content="Disconnect" Click="LocalBackupDisconnectButton_Click" Visibility="Collapsed" />
                                        </StackPanel>
                                    </Grid>
                                </Expander.Header>
                                <StackPanel Spacing="12" Margin="40,0,0,8">
                                    <StackPanel Orientation="Horizontal" Spacing="12">
                                        <Button x:Name="LocalBackupChooseFolderButton" Content="Choose Backup Folder..." Click="LocalBackupChooseFolderButton_Click" />
                                        <TextBlock x:Name="LocalBackupSelectedPathText" Text="No folder selected" VerticalAlignment="Center" Foreground="{ThemeResource TextFillColorSecondaryBrush}" />
                                    </StackPanel>
                                    <StackPanel x:Name="LocalBackupStatusPanel" Spacing="4" Visibility="Collapsed">
                                        <TextBlock x:Name="LocalBackupStatusTitle" Text="Status: Connected" FontSize="13" FontWeight="Medium" />
                                        <TextBlock x:Name="LocalBackupStatusDetails" Text="Last synced: Never" FontSize="11" Foreground="{ThemeResource TextFillColorSecondaryBrush}" />
                                        <ProgressBar x:Name="LocalBackupSyncProgressBar" IsIndeterminate="False" Height="4" Value="0" Margin="0,4,0,0" Visibility="Collapsed" />
                                    </StackPanel>
                                </StackPanel>
                            </Expander>

                            <!-- Google Drive Backup -->
                            <Expander IsExpanded="False" ExpandDirection="Down" HorizontalAlignment="Stretch" HorizontalContentAlignment="Stretch" Visibility="Collapsed">
                                <Expander.Header>
                                    <Grid ColumnSpacing="32" Padding="4,8">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="Auto" />
                                            <ColumnDefinition Width="*" />
                                            <ColumnDefinition Width="Auto" />
                                        </Grid.ColumnDefinitions>
                                        <FontIcon Grid.Column="0" Glyph="&#xE8B9;" FontFamily="{ThemeResource SymbolThemeFontFamily}" FontSize="18" VerticalAlignment="Center" Width="24" />
                                        <StackPanel Grid.Column="1" VerticalAlignment="Center" Spacing="2">
                                            <TextBlock Text="Google Drive Backup" FontSize="14" FontWeight="Medium" />
                                            <TextBlock Text="Backup and sync your journal to Google Drive" FontSize="12" Foreground="{ThemeResource TextFillColorSecondaryBrush}" />
                                        </StackPanel>
                                        <StackPanel Grid.Column="2" Orientation="Horizontal" Spacing="8" VerticalAlignment="Center">
                                            <Button x:Name="GoogleDriveSyncButton" Content="Sync" Click="GoogleDriveSyncButton_Click" Style="{StaticResource AccentButtonStyle}" />
                                            <Button x:Name="GoogleDrivePullButton" Content="Pull Backup" Click="GoogleDrivePullButton_Click" Visibility="Collapsed" />
                                            <Button x:Name="GoogleDriveDisconnectButton" Content="Disconnect" Click="GoogleDriveDisconnectButton_Click" Visibility="Collapsed" />
                                        </StackPanel>
                                    </Grid>
                                </Expander.Header>
                                <StackPanel Spacing="12" Margin="40,0,0,8">
                                    <Button x:Name="GoogleDriveSignInButton" Content="Sign In with Google" Click="GoogleDriveSignInButton_Click" Style="{StaticResource AccentButtonStyle}" HorizontalAlignment="Left" />
                                    <PasswordBox x:Name="GoogleDriveTokenPasswordBox" Header="Or Enter Google Drive Access Token Manually" PlaceholderText="ya29.a0A..." PasswordRevealMode="Hidden" PasswordChanged="GoogleDriveTokenPasswordBox_PasswordChanged" />
                                    <StackPanel x:Name="GoogleDriveStatusPanel" Spacing="4" Visibility="Collapsed">
                                        <TextBlock x:Name="GoogleDriveStatusTitle" Text="Status: Connected" FontSize="13" FontWeight="Medium" />
                                        <TextBlock x:Name="GoogleDriveStatusDetails" Text="Last synced: Never" FontSize="11" Foreground="{ThemeResource TextFillColorSecondaryBrush}" />
                                        <ProgressBar x:Name="GoogleDriveSyncProgressBar" IsIndeterminate="False" Height="4" Value="0" Margin="0,4,0,0" Visibility="Collapsed" />
                                    </StackPanel>
                                </StackPanel>
                            </Expander>

                            <!-- OneDrive Backup -->
                            <Expander IsExpanded="False" ExpandDirection="Down" HorizontalAlignment="Stretch" HorizontalContentAlignment="Stretch" Visibility="Collapsed">
                                <Expander.Header>
                                    <Grid ColumnSpacing="32" Padding="4,8">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="Auto" />
                                            <ColumnDefinition Width="*" />
                                            <ColumnDefinition Width="Auto" />
                                        </Grid.ColumnDefinitions>
                                        <FontIcon Grid.Column="0" Glyph="&#xECC9;" FontFamily="{ThemeResource SymbolThemeFontFamily}" FontSize="18" VerticalAlignment="Center" Width="24" />
                                        <StackPanel Grid.Column="1" VerticalAlignment="Center" Spacing="2">
                                            <TextBlock Text="Microsoft OneDrive Backup" FontSize="14" FontWeight="Medium" />
                                            <TextBlock Text="Backup and sync your journal to Microsoft OneDrive" FontSize="12" Foreground="{ThemeResource TextFillColorSecondaryBrush}" />
                                        </StackPanel>
                                        <StackPanel Grid.Column="2" Orientation="Horizontal" Spacing="8" VerticalAlignment="Center">
                                            <Button x:Name="OneDriveSyncButton" Content="Sync" Click="OneDriveSyncButton_Click" Style="{StaticResource AccentButtonStyle}" />
                                            <Button x:Name="OneDrivePullButton" Content="Pull Backup" Click="OneDrivePullButton_Click" Visibility="Collapsed" />
                                            <Button x:Name="OneDriveDisconnectButton" Content="Disconnect" Click="OneDriveDisconnectButton_Click" Visibility="Collapsed" />
                                        </StackPanel>
                                    </Grid>
                                </Expander.Header>
                                <StackPanel Spacing="12" Margin="40,0,0,8">
                                    <Button x:Name="OneDriveSignInButton" Content="Sign In with Microsoft" Click="OneDriveSignInButton_Click" Style="{StaticResource AccentButtonStyle}" HorizontalAlignment="Left" />
                                    <PasswordBox x:Name="OneDriveTokenPasswordBox" Header="Or Enter OneDrive Access Token Manually" PlaceholderText="EwB4A..." PasswordRevealMode="Hidden" PasswordChanged="OneDriveTokenPasswordBox_PasswordChanged" />
                                    <StackPanel x:Name="OneDriveStatusPanel" Spacing="4" Visibility="Collapsed">
                                        <TextBlock x:Name="OneDriveStatusTitle" Text="Status: Connected" FontSize="13" FontWeight="Medium" />
                                        <TextBlock x:Name="OneDriveStatusDetails" Text="Last synced: Never" FontSize="11" Foreground="{ThemeResource TextFillColorSecondaryBrush}" />
                                        <ProgressBar x:Name="OneDriveSyncProgressBar" IsIndeterminate="False" Height="4" Value="0" Margin="0,4,0,0" Visibility="Collapsed" />
                                    </StackPanel>
                                </StackPanel>
                            </Expander>

                            <!-- Dropbox Backup -->
                            <Expander IsExpanded="False" ExpandDirection="Down" HorizontalAlignment="Stretch" HorizontalContentAlignment="Stretch" Visibility="Collapsed">
                                <Expander.Header>
                                    <Grid ColumnSpacing="32" Padding="4,8">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="Auto" />
                                            <ColumnDefinition Width="*" />
                                            <ColumnDefinition Width="Auto" />
                                        </Grid.ColumnDefinitions>
                                        <FontIcon Grid.Column="0" Glyph="&#xE10C;" FontFamily="{ThemeResource SymbolThemeFontFamily}" FontSize="18" VerticalAlignment="Center" Width="24" />
                                        <StackPanel Grid.Column="1" VerticalAlignment="Center" Spacing="2">
                                            <TextBlock Text="Dropbox Backup" FontSize="14" FontWeight="Medium" />
                                            <TextBlock Text="Backup and sync your journal to Dropbox" FontSize="12" Foreground="{ThemeResource TextFillColorSecondaryBrush}" />
                                        </StackPanel>
                                        <StackPanel Grid.Column="2" Orientation="Horizontal" Spacing="8" VerticalAlignment="Center">
                                            <Button x:Name="DropboxSyncButton" Content="Sync" Click="DropboxSyncButton_Click" Style="{StaticResource AccentButtonStyle}" />
                                            <Button x:Name="DropboxPullButton" Content="Pull Backup" Click="DropboxPullButton_Click" Visibility="Collapsed" />
                                            <Button x:Name="DropboxDisconnectButton" Content="Disconnect" Click="DropboxDisconnectButton_Click" Visibility="Collapsed" />
                                        </StackPanel>
                                    </Grid>
                                </Expander.Header>
                                <StackPanel Spacing="12" Margin="40,0,0,8">
                                    <Button x:Name="DropboxSignInButton" Content="Sign In with Dropbox" Click="DropboxSignInButton_Click" Style="{StaticResource AccentButtonStyle}" HorizontalAlignment="Left" />
                                    <PasswordBox x:Name="DropboxTokenPasswordBox" Header="Or Enter Dropbox Access Token Manually" PlaceholderText="sl.u.B..." PasswordRevealMode="Hidden" PasswordChanged="DropboxTokenPasswordBox_PasswordChanged" />
                                    <StackPanel x:Name="DropboxStatusPanel" Spacing="4" Visibility="Collapsed">
                                        <TextBlock x:Name="DropboxStatusTitle" Text="Status: Connected" FontSize="13" FontWeight="Medium" />
                                        <TextBlock x:Name="DropboxStatusDetails" Text="Last synced: Never" FontSize="11" Foreground="{ThemeResource TextFillColorSecondaryBrush}" />
                                        <ProgressBar x:Name="DropboxSyncProgressBar" IsIndeterminate="False" Height="4" Value="0" Margin="0,4,0,0" Visibility="Collapsed" />
                                    </StackPanel>
                                </StackPanel>
                            </Expander>
                        </StackPanel>

                        <!-- ── Security & Privacy ── -->
                        <StackPanel Spacing="4">
                            <TextBlock Text="Security &amp; Privacy" FontSize="12" FontWeight="SemiBold"
                                       Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                                       Margin="4,8,0,8" CharacterSpacing="50" />

                            <!-- Master Password & Category Locking -->
                            <Expander IsExpanded="False" ExpandDirection="Down" HorizontalAlignment="Stretch" HorizontalContentAlignment="Stretch">
                                <Expander.Header>
                                    <Grid ColumnSpacing="32" Padding="4,8">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="Auto" />
                                            <ColumnDefinition Width="*" />
                                        </Grid.ColumnDefinitions>
                                        <FontIcon Grid.Column="0" Glyph="&#xE727;" FontFamily="{ThemeResource SymbolThemeFontFamily}" FontSize="18" VerticalAlignment="Center" Width="24" />
                                        <StackPanel Grid.Column="1" VerticalAlignment="Center" Spacing="2">
                                            <TextBlock Text="Category Encryption &amp; Password Locking" FontSize="14" FontWeight="Medium" />
                                            <TextBlock Text="Secure private journal categories using AES-256 password protection" FontSize="12" Foreground="{ThemeResource TextFillColorSecondaryBrush}" />
                                        </StackPanel>
                                    </Grid>
                                </Expander.Header>
                                <StackPanel Spacing="12" Margin="40,0,0,8">
                                    <PasswordBox x:Name="MasterPasswordBox" Header="Set Master Password" PlaceholderText="Enter password..." PasswordRevealMode="Hidden" PasswordChanged="MasterPasswordBox_PasswordChanged" />
                                    
                                    <TextBlock Text="Select categories to encrypt and lock:" FontSize="13" FontWeight="Medium" Margin="0,4,0,0" />
                                    <StackPanel x:Name="LockedCategoriesStackPanel" Spacing="6">
                                        <!-- Checkboxes will be dynamically loaded here in C# -->
                                    </StackPanel>

                                    <!-- Windows Hello on Startup -->
                                    <ToggleSwitch x:Name="WindowsHelloToggle"
                                                  Header="Windows Hello on Startup"
                                                  IsOn="True"
                                                  OnContent="Enabled" OffContent="Disabled"
                                                  Margin="0,8,0,0"
                                                  Toggled="WindowsHelloToggle_Toggled" />
                                    <TextBlock Text="Automatically prompt Windows Hello (fingerprint / face / PIN) when the app opens"
                                               FontSize="12" Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                                               TextWrapping="Wrap" Margin="0,-4,0,0" />

                                    <!-- Lock on Minimize -->
                                    <ToggleSwitch x:Name="LockOnMinimizeToggle"
                                                  Header="Lock on Minimize"
                                                  IsOn="False"
                                                  OnContent="Enabled" OffContent="Disabled"
                                                  Margin="0,4,0,0"
                                                  Toggled="LockOnMinimizeToggle_Toggled" />
                                    <TextBlock Text="Re-lock the journal whenever the app window is minimized or hidden"
                                               FontSize="12" Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                                               TextWrapping="Wrap" Margin="0,-4,0,0" />
                                </StackPanel>
                            </Expander>
                        </StackPanel>

                        <!-- ── Local AI (Ollama) ── -->
                        <StackPanel Spacing="4">
                            <TextBlock Text="Local AI (Ollama)" FontSize="12" FontWeight="SemiBold"
                                       Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                                       Margin="4,8,0,8" CharacterSpacing="50" />

                            <Expander IsExpanded="False" ExpandDirection="Down" HorizontalAlignment="Stretch" HorizontalContentAlignment="Stretch">
                                <Expander.Header>
                                    <Grid ColumnSpacing="32" Padding="4,8">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="Auto" />
                                            <ColumnDefinition Width="*" />
                                        </Grid.ColumnDefinitions>
                                        <FontIcon Grid.Column="0" Glyph="&#xE99A;" FontFamily="{ThemeResource SymbolThemeFontFamily}" FontSize="18" VerticalAlignment="Center" Width="24" />
                                        <StackPanel Grid.Column="1" VerticalAlignment="Center" Spacing="2">
                                            <TextBlock Text="Local AI Settings" FontSize="14" FontWeight="Medium" />
                                            <TextBlock Text="Configure local Ollama service for AI writing assistance" FontSize="12" Foreground="{ThemeResource TextFillColorSecondaryBrush}" />
                                        </StackPanel>
                                    </Grid>
                                </Expander.Header>
                                <StackPanel Spacing="12" Padding="16,8">
                                    <TextBlock Text="Run a local large language model using Ollama. Make sure Ollama is installed and running on your machine." FontSize="12" Foreground="{ThemeResource TextFillColorSecondaryBrush}" TextWrapping="Wrap" />
                                    
                                    <TextBox x:Name="OllamaUrlTextBox" Header="Ollama API URL" PlaceholderText="http://localhost:11434" Text="http://localhost:11434" TextChanged="OllamaUrlTextBox_TextChanged" />
                                    
                                    <StackPanel Orientation="Horizontal" Spacing="8">
                                        <Button x:Name="SettingsTestOllamaButton" Content="Test Connection" Click="SettingsTestOllamaButton_Click" Style="{StaticResource AccentButtonStyle}" />
                                        <TextBlock x:Name="SettingsOllamaStatusText" Text="Not Tested" VerticalAlignment="Center" FontSize="12" Foreground="{ThemeResource TextFillColorSecondaryBrush}" />
                                    </StackPanel>
                                </StackPanel>
                            </Expander>
                        </StackPanel>

                        <!-- ── Blog Publisher (GitHub Pages) ── -->
                        <StackPanel Spacing="4">
                            <TextBlock Text="Blog Publisher (GitHub Pages)" FontSize="12" FontWeight="SemiBold"
                                       Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                                       Margin="4,8,0,8" CharacterSpacing="50" />

                            <Expander IsExpanded="False" ExpandDirection="Down" HorizontalAlignment="Stretch" HorizontalContentAlignment="Stretch">
                                <Expander.Header>
                                    <Grid ColumnSpacing="32" Padding="4,8">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="Auto" />
                                            <ColumnDefinition Width="*" />
                                        </Grid.ColumnDefinitions>
                                        <FontIcon Grid.Column="0" Glyph="&#xE774;" FontFamily="{ThemeResource SymbolThemeFontFamily}" FontSize="18" VerticalAlignment="Center" Width="24" />
                                        <StackPanel Grid.Column="1" VerticalAlignment="Center" Spacing="2">
                                            <TextBlock Text="GitHub Pages Blog" FontSize="14" FontWeight="Medium" />
                                            <TextBlock Text="Publish selected journal entries to your public GitHub Pages blog" FontSize="12" Foreground="{ThemeResource TextFillColorSecondaryBrush}" />
                                        </StackPanel>
                                    </Grid>
                                </Expander.Header>
                                <StackPanel Spacing="12" Padding="16,8">
                                    <TextBlock Text="Generate a clean, beautiful static blog from your checked 'Blog' entries. The repository must be public for GitHub Pages to host it." FontSize="12" Foreground="{ThemeResource TextFillColorSecondaryBrush}" TextWrapping="Wrap" />
                                    
                                    <TextBox x:Name="BlogRepoTextBox" Header="Blog Repository Name" PlaceholderText="my-journal-blog" Text="my-journal-blog" TextChanged="BlogRepoTextBox_TextChanged" />
                                    <TextBox x:Name="BlogTitleTextBox" Header="Blog Title" PlaceholderText="My Journal Blog" Text="My Journal Blog" TextChanged="BlogTitleTextBox_TextChanged" />
                                    <TextBox x:Name="BlogDescTextBox" Header="Blog Description" PlaceholderText="A collection of my thoughts and memories." Text="A collection of my thoughts and memories." TextChanged="BlogDescTextBox_TextChanged" />
                                    <TextBox x:Name="BlogCustomCssTextBox" Header="Custom CSS Styles (Optional)" PlaceholderText="e.g. body { font-family: monospace; }" AcceptsReturn="True" Height="100" TextWrapping="Wrap" TextChanged="BlogCustomCssTextBox_TextChanged" />

                                    <StackPanel Orientation="Horizontal" Spacing="8" Margin="0,4,0,0">
                                        <TextBlock Text="Live URL:" FontSize="12" VerticalAlignment="Center" FontWeight="SemiBold" />
                                        <HyperlinkButton x:Name="BlogLiveUrlButton" Content="Not Configured" NavigateUri="https://github.com" FontSize="12" Padding="0" VerticalAlignment="Center" />
                                    </StackPanel>

                                    <StackPanel Orientation="Horizontal" Spacing="12" Margin="0,8,0,0">
                                        <Button x:Name="SettingsPublishBlogButton" Content="Publish / Sync Blog" Click="SettingsPublishBlogButton_Click" Style="{StaticResource AccentButtonStyle}" />
                                        <ProgressRing x:Name="BlogPublishProgressRing" Width="20" Height="20" IsActive="False" Visibility="Collapsed" VerticalAlignment="Center" />
                                        <TextBlock x:Name="BlogPublishStatusText" Text="Ready" VerticalAlignment="Center" FontSize="12" Foreground="{ThemeResource TextFillColorSecondaryBrush}" />
                                    </StackPanel>
                                </StackPanel>
                            </Expander>
                        </StackPanel>

                        <!-- ── Maintenance & Data ── -->
                        <StackPanel Spacing="4">
                            <TextBlock Text="Maintenance &amp; Data" FontSize="12" FontWeight="SemiBold"
                                       Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                                       Margin="4,8,0,8" CharacterSpacing="50" />

                            <!-- Data Management -->
                            <Expander IsExpanded="False" ExpandDirection="Down" HorizontalAlignment="Stretch" HorizontalContentAlignment="Stretch">
                                <Expander.Header>
                                    <Grid ColumnSpacing="32" Padding="4,8">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="Auto" />
                                            <ColumnDefinition Width="*" />
                                        </Grid.ColumnDefinitions>
                                        <FontIcon Grid.Column="0" Glyph="&#xE909;" FontFamily="{ThemeResource SymbolThemeFontFamily}" FontSize="18" VerticalAlignment="Center" Width="24" />
                                        <StackPanel Grid.Column="1" VerticalAlignment="Center" Spacing="2">
                                            <TextBlock Text="Data Management" FontSize="14" FontWeight="Medium" />
                                            <TextBlock Text="Clear local files, reset preferences, or export your entries" FontSize="12" Foreground="{ThemeResource TextFillColorSecondaryBrush}" />
                                        </StackPanel>
                                    </Grid>
                                </Expander.Header>
                                <StackPanel Orientation="Horizontal" Spacing="8" Margin="40,0,0,8">
                                    <Button Content="Clear All Data" Click="ClearAllDataButton_Click" Background="#FF3B30" BorderBrush="#FF3B30" Foreground="White" />
                                    <Button Content="Restore to Default" Click="RestoreToDefaultButton_Click" />
                                    <Button Content="Export Journal Data" Click="ExportDataButton_Click" />
                                </StackPanel>
                            </Expander>

                            <!-- Updates -->
                            <Border Background="{ThemeResource CardBackgroundFillColorDefaultBrush}" BorderThickness="1" BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}" CornerRadius="8" Padding="16,12">
                                <Grid ColumnSpacing="32">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="Auto" />
                                        <ColumnDefinition Width="*" />
                                        <ColumnDefinition Width="Auto" />
                                    </Grid.ColumnDefinitions>
                                    <FontIcon Grid.Column="0" Glyph="&#xE896;" FontFamily="{ThemeResource SymbolThemeFontFamily}" FontSize="18" VerticalAlignment="Center" Width="24" />
                                    <StackPanel Grid.Column="1" VerticalAlignment="Center" Spacing="2">
                                        <TextBlock x:Name="UpdateStatusTextBlock" Text="You're up to date!" FontSize="14" FontWeight="Medium" />
                                        <TextBlock x:Name="LastCheckedTextBlock" Text="Last checked: Just now" FontSize="12" Foreground="{ThemeResource TextFillColorSecondaryBrush}" />
                                    </StackPanel>
                                    <Button x:Name="CheckUpdatesButton" Grid.Column="2" Click="CheckUpdatesButton_Click" VerticalAlignment="Center" Style="{StaticResource AccentButtonStyle}" MinWidth="110">
                                        <Button.Content>
                                            <StackPanel x:Name="CheckNowContent" Orientation="Horizontal" Spacing="8">
                                                <TextBlock Text="Check Now" VerticalAlignment="Center" />
                                            </StackPanel>
                                        </Button.Content>
                                    </Button>
                                </Grid>
                            </Border>
                        </StackPanel>

                        <!-- ── About ── -->
                        <StackPanel Spacing="4">
                            <TextBlock Text="About" FontSize="12" FontWeight="SemiBold"
                                       Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                                       Margin="4,8,0,8" CharacterSpacing="50" />

                            <!-- About Card -->
                            <Expander x:Name="AboutCardBorder" IsExpanded="False" ExpandDirection="Down" HorizontalAlignment="Stretch" HorizontalContentAlignment="Stretch">
                                <Expander.Header>
                                    <Grid ColumnSpacing="32" Padding="4,8">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="Auto" />
                                            <ColumnDefinition Width="*" />
                                            <ColumnDefinition Width="Auto" />
                                        </Grid.ColumnDefinitions>
                                        <Image Grid.Column="0" Source="ms-appx:///Assets/AppIcon.ico" Width="28" Height="28" VerticalAlignment="Center" />
                                        <StackPanel Grid.Column="1" VerticalAlignment="Center" Spacing="2">
                                            <TextBlock Text="JournalApp" FontSize="14" FontWeight="Medium" />
                                            <TextBlock Text="© 2026 JournalApp. All rights reserved." FontSize="12" Foreground="{ThemeResource TextFillColorSecondaryBrush}" />
                                        </StackPanel>
                                        <TextBlock x:Name="AboutVersionTextBlock" Grid.Column="2" Text="1.0.5.0" FontSize="13" VerticalAlignment="Center" Foreground="{ThemeResource TextFillColorSecondaryBrush}" />
                                    </Grid>
                                </Expander.Header>
                                <StackPanel x:Name="AboutDetailsPanel" Spacing="8" Margin="44,0,0,8">
                                    <TextBlock Text="JournalApp is a premium, distraction-free journaling application built using WinUI 3 and the Windows App SDK. It helps you keep track of your thoughts, ideas, and reflections with rich text editing, auto-saving, visual cover banners, and custom categories." FontSize="13" TextWrapping="Wrap" LineHeight="18" Foreground="{ThemeResource TextFillColorPrimaryBrush}" />
                                    <TextBlock Text="Designed, Developed and Published by Amitendu Bikash Dhusiya." FontSize="12" Foreground="{ThemeResource TextFillColorSecondaryBrush}" />
                                </StackPanel>
                            </Expander>
                        </StackPanel>
                        <Border Height="32" />
                    </StackPanel>
                </ScrollViewer>

                <!-- Floating Save Settings Bar -->
                <Border Grid.Row="1" Background="{ThemeResource CardBackgroundFillColorDefaultBrush}" BorderThickness="0,1,0,0" BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}" Padding="40,16">
                    <Grid MaxWidth="1000" HorizontalAlignment="Stretch">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="Auto" />
                        </Grid.ColumnDefinitions>
                        <StackPanel Grid.Column="0" VerticalAlignment="Center" Spacing="2">
                            <TextBlock Text="Save Settings" FontSize="14" FontWeight="Medium" />
                            <TextBlock Text="Apply and persist all your current setting preferences" FontSize="12" Foreground="{ThemeResource TextFillColorSecondaryBrush}" />
                        </StackPanel>
                        <Button x:Name="SaveSettingsButton" IsEnabled="False" Grid.Column="1" Click="SaveSettingsButton_Click"
                                HorizontalAlignment="Right" VerticalAlignment="Center"
                                Style="{StaticResource AccentButtonStyle}" MinWidth="120">
                            <StackPanel Orientation="Horizontal" Spacing="8">
                                <FontIcon x:Name="SaveSettingsIcon" Glyph="&#xE74E;" FontFamily="{ThemeResource SymbolThemeFontFamily}" FontSize="13" />
                                <TextBlock x:Name="SaveSettingsText" Text="Save Settings" />
                            </StackPanel>
                        </Button>
                    </Grid>
                </Border>
            </Grid>

            <!-- Blog Publisher Page -->
            <Grid x:Name="BlogPageGrid" Visibility="Collapsed" Padding="0,24,0,0">
                <ScrollViewer VerticalScrollBarVisibility="Auto" HorizontalAlignment="Stretch">
                    <StackPanel MaxWidth="860" HorizontalAlignment="Stretch" Padding="40,40,40,40" Spacing="20">
                        <Border Width="860" Height="0" HorizontalAlignment="Stretch" IsHitTestVisible="False" />

                        <!-- Page Header -->
                        <Grid HorizontalAlignment="Stretch" Margin="0,0,0,8">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="Auto" />
                            </Grid.ColumnDefinitions>
                            <StackPanel VerticalAlignment="Center" Spacing="4">
                                <TextBlock Text="Blog Publisher" FontSize="28" FontWeight="Bold" />
                                <TextBlock Text="Publish selected journal entries to your GitHub Pages blog" FontSize="13" Foreground="{ThemeResource TextFillColorSecondaryBrush}" />
                            </StackPanel>
                            <StackPanel Grid.Column="1" Orientation="Horizontal" Spacing="12" VerticalAlignment="Center">
                                <Button x:Name="BlogPagePublishButton" Style="{StaticResource AccentButtonStyle}" Padding="14,8" CornerRadius="6" Click="SettingsPublishBlogButton_Click">
                                    <StackPanel Orientation="Horizontal" Spacing="8">
                                        <FontIcon Glyph="&#xE898;" FontSize="14" />
                                        <TextBlock Text="Publish / Sync" />
                                    </StackPanel>
                                </Button>
                                <ProgressRing x:Name="BlogPageProgressRing" Width="22" Height="22" IsActive="False" Visibility="Collapsed" VerticalAlignment="Center" />
                                <TextBlock x:Name="BlogPageStatusText" Text="Ready" VerticalAlignment="Center" FontSize="12" Foreground="{ThemeResource TextFillColorSecondaryBrush}" />
                            </StackPanel>
                        </Grid>

                        <!-- Config Card -->
                        <Border Background="{ThemeResource CardBackgroundFillColorDefaultBrush}" BorderThickness="1" BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}" CornerRadius="8" Padding="24">
                            <StackPanel Spacing="16">
                                <TextBlock Text="Blog Configuration" FontSize="15" FontWeight="SemiBold" />
                                <Grid ColumnSpacing="16">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*" />
                                        <ColumnDefinition Width="*" />
                                    </Grid.ColumnDefinitions>
                                    <TextBox x:Name="BlogPageRepoTextBox" Grid.Column="0" Header="Repository Name" PlaceholderText="my-journal-blog" TextChanged="BlogRepoTextBox_TextChanged" />
                                    <TextBox x:Name="BlogPageTitleTextBox" Grid.Column="1" Header="Blog Title" PlaceholderText="My Journal Blog" TextChanged="BlogTitleTextBox_TextChanged" />
                                </Grid>
                                <TextBox x:Name="BlogPageDescTextBox" Header="Blog Description" PlaceholderText="A collection of my thoughts and memories." TextChanged="BlogDescTextBox_TextChanged" />
                                <StackPanel Orientation="Horizontal" Spacing="8" VerticalAlignment="Center">
                                    <TextBlock Text="Live URL:" FontSize="12" VerticalAlignment="Center" FontWeight="SemiBold" />
                                    <HyperlinkButton x:Name="BlogPageLiveUrlButton" Content="Not Configured" NavigateUri="https://github.com" FontSize="12" Padding="0" VerticalAlignment="Center" />
                                </StackPanel>
                            </StackPanel>
                        </Border>

                        <!-- Custom CSS Card -->
                        <Border Background="{ThemeResource CardBackgroundFillColorDefaultBrush}" BorderThickness="1" BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}" CornerRadius="8" Padding="24">
                            <StackPanel Spacing="12">
                                <TextBlock Text="Custom CSS" FontSize="15" FontWeight="SemiBold" />
                                <TextBlock Text="Override or extend the blog stylesheet. Appended after the default styles." FontSize="12" Foreground="{ThemeResource TextFillColorSecondaryBrush}" TextWrapping="Wrap" />
                                <TextBox x:Name="BlogPageCustomCssTextBox" PlaceholderText="/* your custom CSS here */" AcceptsReturn="True" Height="120" TextWrapping="Wrap" TextChanged="BlogCustomCssTextBox_TextChanged" FontFamily="Cascadia Code, Consolas, monospace" />
                            </StackPanel>
                        </Border>

                        <!-- Published Entries Card -->
                        <Border Background="{ThemeResource CardBackgroundFillColorDefaultBrush}" BorderThickness="1" BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}" CornerRadius="8" Padding="24">
                            <StackPanel Spacing="12">
                                <Grid HorizontalAlignment="Stretch">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*" />
                                        <ColumnDefinition Width="Auto" />
                                    </Grid.ColumnDefinitions>
                                    <StackPanel VerticalAlignment="Center" Spacing="2">
                                        <TextBlock Text="Published Entries" FontSize="15" FontWeight="SemiBold" />
                                        <TextBlock x:Name="BlogPagePublishedCountText" Text="0 entries marked for publishing" FontSize="12" Foreground="{ThemeResource TextFillColorSecondaryBrush}" />
                                    </StackPanel>
                                    <Button Grid.Column="1" x:Name="BlogPageRefreshBtn" Padding="10,6" CornerRadius="6" Click="BlogPageRefreshBtn_Click">
                                        <StackPanel Orientation="Horizontal" Spacing="6">
                                            <FontIcon Glyph="&#xE72C;" FontSize="12" />
                                            <TextBlock Text="Refresh" FontSize="12" />
                                        </StackPanel>
                                    </Button>
                                </Grid>
                                <ListView x:Name="BlogPagePublishedList" SelectionMode="None" IsItemClickEnabled="False">
                                    <ListView.ItemTemplate>
                                        <DataTemplate>
                                            <Grid Padding="0,6" ColumnSpacing="12">
                                                <Grid.ColumnDefinitions>
                                                    <ColumnDefinition Width="*" />
                                                    <ColumnDefinition Width="Auto" />
                                                </Grid.ColumnDefinitions>
                                                <StackPanel VerticalAlignment="Center" Spacing="2">
                                                    <TextBlock Text="{Binding Title}" FontWeight="SemiBold" TextTrimming="CharacterEllipsis" />
                                                    <TextBlock FontSize="11" Foreground="{ThemeResource TextFillColorSecondaryBrush}">
                                                        <Run Text="{Binding DateCreated}" />
                                                        <Run Text=" · " />
                                                        <Run Text="{Binding Category}" />
                                                    </TextBlock>
                                                </StackPanel>
                                                <Button Grid.Column="1" Click="BlogPageVisitBtn_Click" Tag="{Binding}" Style="{StaticResource DefaultButtonStyle}" Padding="8,4" CornerRadius="4" VerticalAlignment="Center">
                                                     <StackPanel Orientation="Horizontal" Spacing="6">
                                                         <FontIcon Glyph="&#xE774;" FontSize="11" />
                                                         <TextBlock Text="Visit" FontSize="11" />
                                                     </StackPanel>
                                                 </Button>
                                            </Grid>
                                        </DataTemplate>
                                    </ListView.ItemTemplate>
                                </ListView>
                            </StackPanel>
                        </Border>

                    </StackPanel>
                </ScrollViewer>
            </Grid>

            <!-- Map View Grid -->
            <Grid x:Name="MapGrid" Visibility="Collapsed" Padding="0,24,0,0">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="*" />
                </Grid.RowDefinitions>
                <Grid Padding="40,24,40,12" Grid.Row="0">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="Auto" />
                    </Grid.ColumnDefinitions>
                    <StackPanel Spacing="4">
                        <TextBlock Text="Journal Map" FontSize="28" FontWeight="Bold" />
                        <TextBlock Text="Visualize and revisit entries based on where they were written" FontSize="14" Foreground="{ThemeResource TextFillColorSecondaryBrush}" />
                    </StackPanel>
                    <Button x:Name="RefreshMapBtn" Grid.Column="1" Click="RefreshMapBtn_Click" Style="{StaticResource AccentButtonStyle}" Padding="12,6" CornerRadius="4" VerticalAlignment="Center">
                        <StackPanel Orientation="Horizontal" Spacing="8">
                            <FontIcon Glyph="&#xE72C;" FontFamily="{ThemeResource SymbolThemeFontFamily}" FontSize="12" />
                            <TextBlock Text="Reload Map" />
                        </StackPanel>
                    </Button>
                </Grid>
                <Border Grid.Row="1" Margin="40,0,40,40" CornerRadius="8" BorderThickness="1" BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}" Background="{ThemeResource CardBackgroundFillColorDefaultBrush}">
                    <WebView2 x:Name="JournalMapWebView" HorizontalAlignment="Stretch" VerticalAlignment="Stretch" />
                </Border>
            </Grid>

            <!-- Keyboard Shortcuts Grid -->
            <Grid x:Name="ShortcutsGrid" Visibility="Collapsed" Padding="0,24,0,0">
                <Grid.RowDefinitions>
                    <RowDefinition Height="*" />
                </Grid.RowDefinitions>
                
                <ScrollViewer Grid.Row="0" VerticalScrollBarVisibility="Auto" HorizontalAlignment="Stretch">
                    <StackPanel MaxWidth="1000"
                                HorizontalAlignment="Stretch"
                                Padding="40,40,40,40"
                                Spacing="8">
                        <!-- Hidden element to force uniform 1000px layout width -->
                        <Border Width="1000" Height="0" HorizontalAlignment="Stretch" Visibility="Visible" IsHitTestVisible="False" />
                        
                        <TextBlock Text="Keyboard Shortcuts" FontSize="28" FontWeight="Bold" Margin="0,0,0,16" />

                        <!-- Shortcuts List in dynamic card layout -->
                        <StackPanel Spacing="16" HorizontalAlignment="Stretch">
                            
                            <!-- Application Shortcuts -->
                            <TextBlock Text="Application Shortcuts" FontSize="14" FontWeight="SemiBold" Foreground="{ThemeResource TextFillColorSecondaryBrush}" Margin="4,8,0,4" />
                            
                            <Border Background="{ThemeResource CardBackgroundFillColorDefaultBrush}" BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}" BorderThickness="1" CornerRadius="12" Padding="16">
                                <StackPanel Spacing="12">
                                    <Grid ColumnSpacing="16">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="*" />
                                            <ColumnDefinition Width="Auto" />
                                        </Grid.ColumnDefinitions>
                                        <TextBlock Text="Toggle Sidebar Navigation" VerticalAlignment="Center" FontWeight="Medium" />
                                        <Border Grid.Column="1" Background="{ThemeResource ControlFillColorDefaultBrush}" CornerRadius="4" Padding="6,2" BorderThickness="1" BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}">
                                            <TextBlock Text="Ctrl + Alt + B" FontSize="12" FontFamily="Consolas" />
                                        </Border>
                                    </Grid>
                                    
                                    <Grid ColumnSpacing="16">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="*" />
                                            <ColumnDefinition Width="Auto" />
                                        </Grid.ColumnDefinitions>
                                        <TextBlock Text="Save Current Entry" VerticalAlignment="Center" FontWeight="Medium" />
                                        <Border Grid.Column="1" Background="{ThemeResource ControlFillColorDefaultBrush}" CornerRadius="4" Padding="6,2" BorderThickness="1" BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}">
                                            <TextBlock Text="Ctrl + S" FontSize="12" FontFamily="Consolas" />
                                        </Border>
                                    </Grid>

                                    <Grid ColumnSpacing="16">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="*" />
                                            <ColumnDefinition Width="Auto" />
                                        </Grid.ColumnDefinitions>
                                        <TextBlock Text="Find and Replace Text" VerticalAlignment="Center" FontWeight="Medium" />
                                        <Border Grid.Column="1" Background="{ThemeResource ControlFillColorDefaultBrush}" CornerRadius="4" Padding="6,2" BorderThickness="1" BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}">
                                            <TextBlock Text="Ctrl + F" FontSize="12" FontFamily="Consolas" />
                                        </Border>
                                    </Grid>

                                    <Grid ColumnSpacing="16">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="*" />
                                            <ColumnDefinition Width="Auto" />
                                        </Grid.ColumnDefinitions>
                                        <TextBlock Text="Close Find Bar / Clear Selection" VerticalAlignment="Center" FontWeight="Medium" />
                                        <Border Grid.Column="1" Background="{ThemeResource ControlFillColorDefaultBrush}" CornerRadius="4" Padding="6,2" BorderThickness="1" BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}">
                                            <TextBlock Text="Escape" FontSize="12" FontFamily="Consolas" />
                                        </Border>
                                    </Grid>
                                </StackPanel>
                            </Border>

                            <!-- Editor Text Formatting Shortcuts -->
                            <TextBlock Text="Editor Text Formatting" FontSize="14" FontWeight="SemiBold" Foreground="{ThemeResource TextFillColorSecondaryBrush}" Margin="4,8,0,4" />
                            
                            <Border Background="{ThemeResource CardBackgroundFillColorDefaultBrush}" BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}" BorderThickness="1" CornerRadius="12" Padding="16">
                                <StackPanel Spacing="12">
                                    <Grid ColumnSpacing="16">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="*" />
                                            <ColumnDefinition Width="Auto" />
                                        </Grid.ColumnDefinitions>
                                        <TextBlock Text="Bold Text" VerticalAlignment="Center" FontWeight="Medium" />
                                        <Border Grid.Column="1" Background="{ThemeResource ControlFillColorDefaultBrush}" CornerRadius="4" Padding="6,2" BorderThickness="1" BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}">
                                            <TextBlock Text="Ctrl + B" FontSize="12" FontFamily="Consolas" />
                                        </Border>
                                    </Grid>

                                    <Grid ColumnSpacing="16">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="*" />
                                            <ColumnDefinition Width="Auto" />
                                        </Grid.ColumnDefinitions>
                                        <TextBlock Text="Italic Text" VerticalAlignment="Center" FontWeight="Medium" />
                                        <Border Grid.Column="1" Background="{ThemeResource ControlFillColorDefaultBrush}" CornerRadius="4" Padding="6,2" BorderThickness="1" BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}">
                                            <TextBlock Text="Ctrl + I" FontSize="12" FontFamily="Consolas" />
                                        </Border>
                                    </Grid>

                                    <Grid ColumnSpacing="16">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="*" />
                                            <ColumnDefinition Width="Auto" />
                                        </Grid.ColumnDefinitions>
                                        <TextBlock Text="Underline Text" VerticalAlignment="Center" FontWeight="Medium" />
                                        <Border Grid.Column="1" Background="{ThemeResource ControlFillColorDefaultBrush}" CornerRadius="4" Padding="6,2" BorderThickness="1" BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}">
                                            <TextBlock Text="Ctrl + U" FontSize="12" FontFamily="Consolas" />
                                        </Border>
                                    </Grid>

                                    <Grid ColumnSpacing="16">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="*" />
                                            <ColumnDefinition Width="Auto" />
                                        </Grid.ColumnDefinitions>
                                        <TextBlock Text="Undo Last Action" VerticalAlignment="Center" FontWeight="Medium" />
                                        <Border Grid.Column="1" Background="{ThemeResource ControlFillColorDefaultBrush}" CornerRadius="4" Padding="6,2" BorderThickness="1" BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}">
                                            <TextBlock Text="Ctrl + Z" FontSize="12" FontFamily="Consolas" />
                                        </Border>
                                    </Grid>

                                    <Grid ColumnSpacing="16">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="*" />
                                            <ColumnDefinition Width="Auto" />
                                        </Grid.ColumnDefinitions>
                                        <TextBlock Text="Redo Last Action" VerticalAlignment="Center" FontWeight="Medium" />
                                        <Border Grid.Column="1" Background="{ThemeResource ControlFillColorDefaultBrush}" CornerRadius="4" Padding="6,2" BorderThickness="1" BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}">
                                            <TextBlock Text="Ctrl + Y" FontSize="12" FontFamily="Consolas" />
                                        </Border>
                                    </Grid>
                                </StackPanel>
                            </Border>

                        </StackPanel>
                    </StackPanel>
                </ScrollViewer>
            </Grid>

            <!-- GitHub Commit History Grid -->
            <Grid x:Name="GitHubGrid" Visibility="Collapsed" Padding="0,24,0,0">
                <!-- Scrollable Content -->
                <ScrollViewer VerticalScrollBarVisibility="Auto" HorizontalAlignment="Stretch">
                    <StackPanel MaxWidth="1000"
                                HorizontalAlignment="Stretch"
                                Padding="40,40,40,40"
                                Spacing="8">
                        <!-- Hidden element to force uniform 1000px layout width -->
                        <Border Width="1000" Height="0" HorizontalAlignment="Stretch" Visibility="Visible" IsHitTestVisible="False" />
                        
                        <!-- Header inside the scroll stack -->
                        <Grid Margin="0,0,0,16" HorizontalAlignment="Stretch">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="Auto" />
                            </Grid.ColumnDefinitions>
                            <TextBlock Text="GitHub Sync History" FontSize="28" FontWeight="Bold" VerticalAlignment="Center" />
                            <Button x:Name="RefreshGitHubHistoryBtn" Grid.Column="1" Click="RefreshGitHubHistoryBtn_Click" Style="{StaticResource AccentButtonStyle}" Padding="12,6" CornerRadius="4">
                                <StackPanel Orientation="Horizontal" Spacing="8">
                                    <FontIcon Glyph="&#xE72C;" FontSize="13" />
                                    <TextBlock Text="Refresh History" />
                                </StackPanel>
                            </Button>
                        </Grid>

                        <StackPanel Spacing="24" HorizontalAlignment="Stretch">
                        
                        <!-- Commit Graph Card -->
                        <Border Background="{ThemeResource CardBackgroundFillColorDefaultBrush}" BorderThickness="1" BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}" CornerRadius="8" Padding="20">
                            <StackPanel Spacing="16">
                                <TextBlock Text="Commit Activity (Last 7 Days with commits)" FontSize="16" FontWeight="SemiBold" />

                                <!-- Bar Chart Container — skeleton and real content share same height -->
                                <Grid Height="150" HorizontalAlignment="Stretch">
                                    <Grid.RowDefinitions>
                                        <RowDefinition Height="*" />
                                        <RowDefinition Height="Auto" />
                                    </Grid.RowDefinitions>

                                    <!-- Y Axis line & bars -->
                                    <Border Grid.Row="0" BorderThickness="0,0,0,1" BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}" Margin="0,0,0,8" VerticalAlignment="Stretch">
                                        <Grid>
                                            <!-- Skeleton bars (visible while loading) -->
                                            <StackPanel x:Name="CommitChartSkeleton"
                                                        Orientation="Horizontal" Spacing="24"
                                                        HorizontalAlignment="Center" VerticalAlignment="Bottom"
                                                        Height="130" Visibility="Visible">
                                                <StackPanel.Resources>
                                                    <Style TargetType="Border">
                                                        <Setter Property="CornerRadius" Value="3" />
                                                        <Setter Property="Width" Value="32" />
                                                        <Setter Property="Background" Value="#1AFFFFFF" />
                                                        <Setter Property="VerticalAlignment" Value="Bottom" />
                                                    </Style>
                                                </StackPanel.Resources>
                                                <Border Height="70" />
                                                <Border Height="45" />
                                                <Border Height="90" />
                                                <Border Height="55" />
                                                <Border Height="110" />
                                                <Border Height="40" />
                                                <Border Height="80" />
                                            </StackPanel>
                                            <!-- Real chart bars -->
                                            <StackPanel x:Name="CommitChartContainer"
                                                        Orientation="Horizontal" Spacing="24"
                                                        HorizontalAlignment="Center" VerticalAlignment="Bottom"
                                                        Height="130" Visibility="Collapsed" />
                                        </Grid>
                                    </Border>
                                </Grid>
                            </StackPanel>
                        </Border>

                        <!-- Commits List -->
                        <TextBlock Text="Recent Commits" FontSize="18" FontWeight="SemiBold" Margin="0,12,0,0" />

                        <!-- Error text -->
                        <TextBlock x:Name="GitHubHistoryErrorText" Foreground="Red" Visibility="Collapsed" TextWrapping="Wrap" />

                        <!-- Container that holds skeleton OR real list at the same position -->
                        <Grid x:Name="GitHubCommitsContainer">
                            <!-- Skeleton commit rows (shown while loading) -->
                            <StackPanel x:Name="GitHubHistoryProgressBar" Spacing="8" Visibility="Visible">
                                <!-- 6 shimmer rows -->
                                <Border Height="68" CornerRadius="8" Background="{ThemeResource CardBackgroundFillColorDefaultBrush}"
                                        BorderThickness="1" BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}">
                                    <Grid ColumnSpacing="16" Margin="16,12">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="36" />
                                            <ColumnDefinition Width="*" />
                                            <ColumnDefinition Width="56" />
                                        </Grid.ColumnDefinitions>
                                        <Ellipse Width="36" Height="36" Fill="#1AFFFFFF" VerticalAlignment="Center" />
                                        <StackPanel Grid.Column="1" Spacing="8" VerticalAlignment="Center">
                                            <Border Height="12" CornerRadius="6" Width="240" HorizontalAlignment="Left" Background="#1AFFFFFF" />
                                            <Border Height="10" CornerRadius="5" Width="160" HorizontalAlignment="Left" Background="#0DFFFFFF" />
                                        </StackPanel>
                                        <Border Grid.Column="2" Height="20" CornerRadius="4" Background="#1AFFFFFF" VerticalAlignment="Center" />
                                    </Grid>
                                </Border>
                                <Border Height="68" CornerRadius="8" Background="{ThemeResource CardBackgroundFillColorDefaultBrush}"
                                        BorderThickness="1" BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}">
                                    <Grid ColumnSpacing="16" Margin="16,12">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="36" />
                                            <ColumnDefinition Width="*" />
                                            <ColumnDefinition Width="56" />
                                        </Grid.ColumnDefinitions>
                                        <Ellipse Width="36" Height="36" Fill="#1AFFFFFF" VerticalAlignment="Center" />
                                        <StackPanel Grid.Column="1" Spacing="8" VerticalAlignment="Center">
                                            <Border Height="12" CornerRadius="6" Width="180" HorizontalAlignment="Left" Background="#1AFFFFFF" />
                                            <Border Height="10" CornerRadius="5" Width="130" HorizontalAlignment="Left" Background="#0DFFFFFF" />
                                        </StackPanel>
                                        <Border Grid.Column="2" Height="20" CornerRadius="4" Background="#1AFFFFFF" VerticalAlignment="Center" />
                                    </Grid>
                                </Border>
                                <Border Height="68" CornerRadius="8" Background="{ThemeResource CardBackgroundFillColorDefaultBrush}"
                                        BorderThickness="1" BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}">
                                    <Grid ColumnSpacing="16" Margin="16,12">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="36" />
                                            <ColumnDefinition Width="*" />
                                            <ColumnDefinition Width="56" />
                                        </Grid.ColumnDefinitions>
                                        <Ellipse Width="36" Height="36" Fill="#1AFFFFFF" VerticalAlignment="Center" />
                                        <StackPanel Grid.Column="1" Spacing="8" VerticalAlignment="Center">
                                            <Border Height="12" CornerRadius="6" Width="210" HorizontalAlignment="Left" Background="#1AFFFFFF" />
                                            <Border Height="10" CornerRadius="5" Width="150" HorizontalAlignment="Left" Background="#0DFFFFFF" />
                                        </StackPanel>
                                        <Border Grid.Column="2" Height="20" CornerRadius="4" Background="#1AFFFFFF" VerticalAlignment="Center" />
                                    </Grid>
                                </Border>
                                <Border Height="68" CornerRadius="8" Background="{ThemeResource CardBackgroundFillColorDefaultBrush}"
                                        BorderThickness="1" BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}">
                                    <Grid ColumnSpacing="16" Margin="16,12">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="36" />
                                            <ColumnDefinition Width="*" />
                                            <ColumnDefinition Width="56" />
                                        </Grid.ColumnDefinitions>
                                        <Ellipse Width="36" Height="36" Fill="#1AFFFFFF" VerticalAlignment="Center" />
                                        <StackPanel Grid.Column="1" Spacing="8" VerticalAlignment="Center">
                                            <Border Height="12" CornerRadius="6" Width="200" HorizontalAlignment="Left" Background="#1AFFFFFF" />
                                            <Border Height="10" CornerRadius="5" Width="140" HorizontalAlignment="Left" Background="#0DFFFFFF" />
                                        </StackPanel>
                                        <Border Grid.Column="2" Height="20" CornerRadius="4" Background="#1AFFFFFF" VerticalAlignment="Center" />
                                    </Grid>
                                </Border>
                                <Border Height="68" CornerRadius="8" Background="{ThemeResource CardBackgroundFillColorDefaultBrush}"
                                        BorderThickness="1" BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}">
                                    <Grid ColumnSpacing="16" Margin="16,12">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="36" />
                                            <ColumnDefinition Width="*" />
                                            <ColumnDefinition Width="56" />
                                        </Grid.ColumnDefinitions>
                                        <Ellipse Width="36" Height="36" Fill="#1AFFFFFF" VerticalAlignment="Center" />
                                        <StackPanel Grid.Column="1" Spacing="8" VerticalAlignment="Center">
                                            <Border Height="12" CornerRadius="6" Width="190" HorizontalAlignment="Left" Background="#1AFFFFFF" />
                                            <Border Height="10" CornerRadius="5" Width="120" HorizontalAlignment="Left" Background="#0DFFFFFF" />
                                        </StackPanel>
                                        <Border Grid.Column="2" Height="20" CornerRadius="4" Background="#1AFFFFFF" VerticalAlignment="Center" />
                                    </Grid>
                                </Border>
                                <Border Height="68" CornerRadius="8" Background="{ThemeResource CardBackgroundFillColorDefaultBrush}"
                                        BorderThickness="1" BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}">
                                    <Grid ColumnSpacing="16" Margin="16,12">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="36" />
                                            <ColumnDefinition Width="*" />
                                            <ColumnDefinition Width="56" />
                                        </Grid.ColumnDefinitions>
                                        <Ellipse Width="36" Height="36" Fill="#1AFFFFFF" VerticalAlignment="Center" />
                                        <StackPanel Grid.Column="1" Spacing="8" VerticalAlignment="Center">
                                            <Border Height="12" CornerRadius="6" Width="220" HorizontalAlignment="Left" Background="#1AFFFFFF" />
                                            <Border Height="10" CornerRadius="5" Width="170" HorizontalAlignment="Left" Background="#0DFFFFFF" />
                                        </StackPanel>
                                        <Border Grid.Column="2" Height="20" CornerRadius="4" Background="#1AFFFFFF" VerticalAlignment="Center" />
                                    </Grid>
                                </Border>
                            </StackPanel>

                            <!-- Real commits list (hidden until data loads) -->
                            <ListView x:Name="GitHubCommitsListView" SelectionMode="None" Background="Transparent" IsItemClickEnabled="False" Visibility="Collapsed">
                                <ListView.ItemContainerTransitions>
                                    <TransitionCollection>
                                        <AddDeleteThemeTransition />
                                    </TransitionCollection>
                                </ListView.ItemContainerTransitions>
                            <ListView.ItemTemplate>
                                <DataTemplate>
                                    <Border Background="{ThemeResource CardBackgroundFillColorDefaultBrush}" BorderThickness="1" BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}" CornerRadius="8" Margin="0,0,0,8" Padding="16,12" HorizontalAlignment="Stretch">
                                        <Grid ColumnSpacing="16">
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="Auto" />
                                                <ColumnDefinition Width="*" />
                                                <ColumnDefinition Width="Auto" />
                                            </Grid.ColumnDefinitions>
                                            
                                            <!-- Left: Avatar or commit icon -->
                                            <Border Width="36" Height="36" Background="{ThemeResource AccentFillColorDefaultBrush}" CornerRadius="18" VerticalAlignment="Center">
                                                <FontIcon Glyph="&#xEC27;" Foreground="White" FontSize="16" />
                                            </Border>

                                            <!-- Middle: Commit message, author, SHA -->
                                            <StackPanel Grid.Column="1" Spacing="4" VerticalAlignment="Center">
                                                <TextBlock Text="{Binding Message}" FontSize="14" FontWeight="SemiBold" TextWrapping="Wrap" />
                                                <StackPanel Orientation="Horizontal" Spacing="8">
                                                    <TextBlock Text="{Binding Author}" FontSize="12" Foreground="{ThemeResource TextFillColorSecondaryBrush}" />
                                                    <TextBlock Text="•" FontSize="12" Foreground="{ThemeResource TextFillColorSecondaryBrush}" />
                                                    <TextBlock Text="{Binding DateFormatted}" FontSize="12" Foreground="{ThemeResource TextFillColorSecondaryBrush}" />
                                                </StackPanel>
                                            </StackPanel>

                                            <!-- Right: SHA badge -->
                                            <Border Grid.Column="2" Background="{ThemeResource ControlFillColorDefaultBrush}" CornerRadius="4" Padding="6,2" VerticalAlignment="Center">
                                                <TextBlock Text="{Binding ShortSha}" FontSize="11" FontFamily="Consolas" Foreground="{ThemeResource TextFillColorSecondaryBrush}" />
                                            </Border>
                                        </Grid>
                                    </Border>
                                </DataTemplate>
                            </ListView.ItemTemplate>
                        </ListView>
                        </Grid>
                    </StackPanel>
                </StackPanel>
            </ScrollViewer>
        </Grid>

            <!-- Stats Grid -->
            <Grid x:Name="StatsGrid" Visibility="Collapsed" Padding="0,24,0,0">
                <!-- Scrollable Content -->
                <ScrollViewer VerticalScrollBarVisibility="Auto" HorizontalAlignment="Stretch">
                    <StackPanel MaxWidth="1000"
                                HorizontalAlignment="Stretch"
                                Padding="40,40,40,40"
                                Spacing="8">
                        <!-- Hidden element to force uniform 1000px layout width -->
                        <Border Width="1000" Height="0" HorizontalAlignment="Stretch" Visibility="Visible" IsHitTestVisible="False" />
                        
                        <!-- Header inside scroll stack -->
                        <TextBlock Text="Writing Stats &amp; Insights" FontSize="28" FontWeight="Bold" Margin="0,0,0,16" />

                        <StackPanel Spacing="24" HorizontalAlignment="Stretch">
                        <!-- Contribution Graph Card -->
                        <Border Background="{ThemeResource CardBackgroundFillColorDefaultBrush}" BorderThickness="1" BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}" CornerRadius="8" Padding="20">
                            <StackPanel Spacing="16">
                                <TextBlock Text="Writing Activity" FontSize="16" FontWeight="SemiBold" />
                                <ScrollViewer HorizontalScrollBarVisibility="Disabled" VerticalScrollBarVisibility="Disabled" Padding="0,0,0,8" HorizontalAlignment="Stretch">
                                    <Grid x:Name="ContributionGrid" ColumnSpacing="3" RowSpacing="3" HorizontalAlignment="Stretch" Height="110" />
                                </ScrollViewer>
                                <!-- Legend and Streaks -->
                                <Grid ColumnSpacing="20">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="Auto" />
                                        <ColumnDefinition Width="*" />
                                    </Grid.ColumnDefinitions>
                                    <StackPanel Grid.Column="0" Orientation="Horizontal" Spacing="6" VerticalAlignment="Center">
                                        <TextBlock Text="Less" FontSize="12" Foreground="{ThemeResource TextFillColorSecondaryBrush}" VerticalAlignment="Center" />
                                        <Rectangle Width="10" Height="10" Fill="#15FFFFFF" RadiusX="2" RadiusY="2" />
                                        <Rectangle Width="10" Height="10" Fill="#FF1b4c2b" RadiusX="2" RadiusY="2" />
                                        <Rectangle Width="10" Height="10" Fill="#FF2e6930" RadiusX="2" RadiusY="2" />
                                        <Rectangle Width="10" Height="10" Fill="#FF398b3f" RadiusX="2" RadiusY="2" />
                                        <Rectangle Width="10" Height="10" Fill="#FF4dca57" RadiusX="2" RadiusY="2" />
                                        <TextBlock Text="More" FontSize="12" Foreground="{ThemeResource TextFillColorSecondaryBrush}" VerticalAlignment="Center" />
                                    </StackPanel>
                                    
                                    <StackPanel Grid.Column="1" Orientation="Horizontal" Spacing="24" HorizontalAlignment="Right">
                                        <StackPanel Orientation="Horizontal" Spacing="6">
                                            <TextBlock Text="🔥" FontSize="16" />
                                            <TextBlock Text="Current Streak:" FontSize="13" Foreground="{ThemeResource TextFillColorSecondaryBrush}" VerticalAlignment="Center" />
                                            <TextBlock x:Name="CurrentStreakStatsText" Text="0 days" FontSize="13" FontWeight="SemiBold" VerticalAlignment="Center" />
                                        </StackPanel>
                                        <StackPanel Orientation="Horizontal" Spacing="6">
                                            <TextBlock Text="⚡" FontSize="16" />
                                            <TextBlock Text="Longest Streak:" FontSize="13" Foreground="{ThemeResource TextFillColorSecondaryBrush}" VerticalAlignment="Center" />
                                            <TextBlock x:Name="LongestStreakStatsText" Text="0 days" FontSize="13" FontWeight="SemiBold" VerticalAlignment="Center" />
                                        </StackPanel>
                                        <StackPanel Orientation="Horizontal" Spacing="6">
                                            <TextBlock Text="✍️" FontSize="16" />
                                            <TextBlock Text="Total Entries:" FontSize="13" Foreground="{ThemeResource TextFillColorSecondaryBrush}" VerticalAlignment="Center" />
                                            <TextBlock x:Name="TotalEntriesStatsText" Text="0" FontSize="13" FontWeight="SemiBold" VerticalAlignment="Center" />
                                        </StackPanel>
                                    </StackPanel>
                                </Grid>
                            </StackPanel>
                        </Border>

                        <!-- Mood Statistics Card -->
                        <Border Background="{ThemeResource CardBackgroundFillColorDefaultBrush}" BorderThickness="1" BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}" CornerRadius="8" Padding="20">
                            <StackPanel Spacing="16">
                                <TextBlock Text="Mood Distribution" FontSize="16" FontWeight="SemiBold" />
                                <Grid ColumnSpacing="24" RowSpacing="12">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*" />
                                        <ColumnDefinition Width="*" />
                                    </Grid.ColumnDefinitions>
                                    
                                    <!-- Left Column: Happy, Neutral, Sad -->
                                    <StackPanel Grid.Column="0" Spacing="12">
                                        <StackPanel Spacing="4">
                                            <Grid>
                                                <TextBlock Text="😊 Happy" FontSize="13" FontWeight="Medium" />
                                                <TextBlock x:Name="MoodHappyCountText" Text="0 entries (0%)" FontSize="12" Foreground="{ThemeResource TextFillColorSecondaryBrush}" HorizontalAlignment="Right" />
                                            </Grid>
                                            <ProgressBar x:Name="MoodHappyProgress" Minimum="0" Maximum="100" Value="0" Foreground="#FFD700" Height="8" CornerRadius="4" />
                                        </StackPanel>
                                        <StackPanel Spacing="4">
                                            <Grid>
                                                <TextBlock Text="😐 Neutral" FontSize="13" FontWeight="Medium" />
                                                <TextBlock x:Name="MoodNeutralCountText" Text="0 entries (0%)" FontSize="12" Foreground="{ThemeResource TextFillColorSecondaryBrush}" HorizontalAlignment="Right" />
                                            </Grid>
                                            <ProgressBar x:Name="MoodNeutralProgress" Minimum="0" Maximum="100" Value="0" Foreground="#808080" Height="8" CornerRadius="4" />
                                        </StackPanel>
                                        <StackPanel Spacing="4">
                                            <Grid>
                                                <TextBlock Text="😢 Sad" FontSize="13" FontWeight="Medium" />
                                                <TextBlock x:Name="MoodSadCountText" Text="0 entries (0%)" FontSize="12" Foreground="{ThemeResource TextFillColorSecondaryBrush}" HorizontalAlignment="Right" />
                                            </Grid>
                                            <ProgressBar x:Name="MoodSadProgress" Minimum="0" Maximum="100" Value="0" Foreground="#1E90FF" Height="8" CornerRadius="4" />
                                        </StackPanel>
                                    </StackPanel>

                                    <!-- Right Column: Stressed, Angry, Unspecified -->
                                    <StackPanel Grid.Column="1" Spacing="12">
                                        <StackPanel Spacing="4">
                                            <Grid>
                                                <TextBlock Text="😫 Stressed" FontSize="13" FontWeight="Medium" />
                                                <TextBlock x:Name="MoodStressedCountText" Text="0 entries (0%)" FontSize="12" Foreground="{ThemeResource TextFillColorSecondaryBrush}" HorizontalAlignment="Right" />
                                            </Grid>
                                            <ProgressBar x:Name="MoodStressedProgress" Minimum="0" Maximum="100" Value="0" Foreground="#9370DB" Height="8" CornerRadius="4" />
                                        </StackPanel>
                                        <StackPanel Spacing="4">
                                            <Grid>
                                                <TextBlock Text="😡 Angry" FontSize="13" FontWeight="Medium" />
                                                <TextBlock x:Name="MoodAngryCountText" Text="0 entries (0%)" FontSize="12" Foreground="{ThemeResource TextFillColorSecondaryBrush}" HorizontalAlignment="Right" />
                                            </Grid>
                                            <ProgressBar x:Name="MoodAngryProgress" Minimum="0" Maximum="100" Value="0" Foreground="#FF4500" Height="8" CornerRadius="4" />
                                        </StackPanel>
                                        <StackPanel Spacing="4">
                                            <Grid>
                                                <TextBlock Text="📝 Unspecified" FontSize="13" FontWeight="Medium" />
                                                <TextBlock x:Name="MoodNoneCountText" Text="0 entries (0%)" FontSize="12" Foreground="{ThemeResource TextFillColorSecondaryBrush}" HorizontalAlignment="Right" />
                                            </Grid>
                                            <ProgressBar x:Name="MoodNoneProgress" Minimum="0" Maximum="100" Value="0" Foreground="#A9A9A9" Height="8" CornerRadius="4" />
                                        </StackPanel>
                                    </StackPanel>
                                </Grid>
                            </StackPanel>
                        </Border>
                        
                        <!-- Mood Trends Chart Card -->
                        <Border Background="{ThemeResource CardBackgroundFillColorDefaultBrush}" BorderThickness="1" BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}" CornerRadius="8" Padding="20" Margin="0,16,0,0">
                            <StackPanel Spacing="16">
                                <TextBlock Text="Mood Trends (Last 30 Days)" FontSize="16" FontWeight="SemiBold" />
                                <Grid Height="300" HorizontalAlignment="Stretch">
                                    <WebView2 x:Name="MoodChartWebView" MinHeight="300" HorizontalAlignment="Stretch" VerticalAlignment="Stretch" />
                                </Grid>
                            </StackPanel>
                        </Border>

                        <!-- Tag Cloud Card -->
                        <Border Background="{ThemeResource CardBackgroundFillColorDefaultBrush}" BorderThickness="1" BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}" CornerRadius="8" Padding="20" Margin="0,16,0,0">
                            <StackPanel Spacing="16">
                                <TextBlock Text="Frequently Used Tags" FontSize="16" FontWeight="SemiBold" />
                                <VariableSizedWrapGrid x:Name="TagCloudPanel" Orientation="Horizontal" HorizontalAlignment="Stretch" VerticalAlignment="Center" />
                            </StackPanel>
                        </Border>
                    </StackPanel>
                </StackPanel>
            </ScrollViewer>
        </Grid>

            <!-- Gallery Grid -->
            <Grid x:Name="GalleryGrid" Visibility="Collapsed" Padding="0,24,0,0">
                <ScrollViewer VerticalScrollBarVisibility="Auto" HorizontalAlignment="Stretch">
                    <StackPanel MaxWidth="1000" HorizontalAlignment="Center"
                                Padding="40,40,40,40" Spacing="16">
                        <!-- Hidden element to force uniform 1000px layout width -->
                        <Border Width="1000" Height="0" HorizontalAlignment="Stretch" Visibility="Visible" IsHitTestVisible="False" />

                        <!-- Header -->
                        <TextBlock Text="Photo Gallery" FontSize="28" FontWeight="Bold" />

                        <!-- Empty state -->
                        <Border x:Name="GalleryEmptyState" Visibility="Collapsed"
                                Background="{ThemeResource CardBackgroundFillColorDefaultBrush}"
                                BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}"
                                BorderThickness="1" CornerRadius="12" Padding="40,56"
                                HorizontalAlignment="Stretch">
                            <StackPanel HorizontalAlignment="Center" Spacing="14">
                                <FontIcon Glyph="&#xEB9F;" FontFamily="{ThemeResource SymbolThemeFontFamily}"
                                          FontSize="52" Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                                          HorizontalAlignment="Center" />
                                <TextBlock Text="No photos yet"
                                           FontSize="20" FontWeight="SemiBold"
                                           HorizontalAlignment="Center" />
                                <TextBlock Text="Add a cover image to a journal entry and it will appear here. Open any note and click the banner area to add a photo."
                                           FontSize="13" Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                                           TextAlignment="Center" TextWrapping="Wrap" MaxWidth="340"
                                           HorizontalAlignment="Center" />
                            </StackPanel>
                        </Border>

                        <!-- Photo grid: ItemsWrapGrid with 3 equal columns -->
                        <GridView x:Name="GalleryGridView"
                                  SelectionMode="None"
                                  IsItemClickEnabled="True"
                                  ItemClick="GalleryGridView_ItemClick"
                                  Visibility="Collapsed"
                                  HorizontalAlignment="Left">
                            <GridView.ItemContainerTransitions>
                                <TransitionCollection>
                                    <AddDeleteThemeTransition />
                                    <ReorderThemeTransition />
                                </TransitionCollection>
                            </GridView.ItemContainerTransitions>
                            <GridView.ItemContainerStyle>
                                <Style TargetType="GridViewItem">
                                    <Setter Property="Padding" Value="0" />
                                    <Setter Property="Margin" Value="0" />
                                </Style>
                            </GridView.ItemContainerStyle>
                            <GridView.ItemsPanel>
                                <ItemsPanelTemplate>
                                    <ItemsWrapGrid Orientation="Horizontal" MaximumRowsOrColumns="3" />
                                </ItemsPanelTemplate>
                            </GridView.ItemsPanel>
                            <GridView.ItemTemplate>
                                <DataTemplate x:DataType="local:GalleryItem">
                                    <Grid Width="250" Height="180" Margin="5"
                                          Opacity="{x:Bind IsPlaceholder, Converter={StaticResource BoolToOpacityConverter}, Mode=OneTime}"
                                          IsHitTestVisible="{x:Bind IsPlaceholder, Converter={StaticResource BoolInverseConverter}, Mode=OneTime}">
                                        <Grid CornerRadius="10"
                                              BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}"
                                              BorderThickness="1"
                                              Background="{ThemeResource CardBackgroundFillColorDefaultBrush}">
                                            <Image Source="{x:Bind HeroImagePath, Converter={StaticResource ImagePathConverter}, Mode=OneTime}"
                                                   Stretch="UniformToFill"
                                                   HorizontalAlignment="Center"
                                                   VerticalAlignment="Center" />
                                            <Border VerticalAlignment="Bottom" MinHeight="52"
                                                    Background="#BB000000" CornerRadius="0,0,10,10" Padding="10,8">
                                                <StackPanel Spacing="2">
                                                    <TextBlock Text="{x:Bind Title, Mode=OneTime}" Foreground="White"
                                                               FontSize="13" FontWeight="SemiBold"
                                                               TextTrimming="CharacterEllipsis" />
                                                    <TextBlock Text="{x:Bind DateModifiedFormatted, Mode=OneTime}"
                                                               Foreground="#CCCCCC" FontSize="10" />
                                                </StackPanel>
                                            </Border>
                                        </Grid>
                                    </Grid>
                                </DataTemplate>
                            </GridView.ItemTemplate>
                        </GridView>

                    </StackPanel>
                </ScrollViewer>

                <!-- Full Page Overlay for Note Images Viewer -->
                <Grid x:Name="GalleryNoteViewerOverlay" Visibility="Collapsed" Background="#E608080A" HorizontalAlignment="Stretch" VerticalAlignment="Stretch">
                    <Grid.Transitions>
                        <TransitionCollection>
                            <EntranceThemeTransition FromVerticalOffset="24" FromHorizontalOffset="0" />
                        </TransitionCollection>
                    </Grid.Transitions>
                    <Grid.ChildrenTransitions>
                        <TransitionCollection>
                            <EntranceThemeTransition FromVerticalOffset="40" FromHorizontalOffset="0" />
                        </TransitionCollection>
                    </Grid.ChildrenTransitions>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="*" />
                    </Grid.RowDefinitions>
                    
                    <!-- Header -->
                    <Grid Grid.Row="0" Padding="40,24" BorderThickness="0,0,0,1" BorderBrush="#10FFFFFF">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="Auto" />
                        </Grid.ColumnDefinitions>
                        <StackPanel VerticalAlignment="Center" Spacing="6">
                            <TextBlock x:Name="GalleryViewerNoteTitle" Text="Note Title" FontSize="22" FontWeight="SemiBold" Foreground="White" />
                            <TextBlock x:Name="GalleryViewerNoteDate" Text="Date" FontSize="13" Foreground="#B3FFFFFF" />
                        </StackPanel>
                        <Button x:Name="CloseGalleryViewerBtn" Grid.Column="1" Click="CloseGalleryViewerBtn_Click" Content="&#xE711;" FontFamily="{ThemeResource SymbolThemeFontFamily}" FontSize="14" Width="40" Height="40" CornerRadius="20" Background="#14FFFFFF" Foreground="White" BorderThickness="1" BorderBrush="#20FFFFFF" VerticalAlignment="Center" HorizontalAlignment="Right" Padding="0">
                            <Button.Resources>
                                <SolidColorBrush x:Key="ButtonBackgroundPointerOver" Color="#33FFFFFF"/>
                                <SolidColorBrush x:Key="ButtonBackgroundPressed" Color="#4DFFFFFF"/>
                                <SolidColorBrush x:Key="ButtonBorderThemeBrush" Color="#30FFFFFF"/>
                            </Button.Resources>
                        </Button>
                    </Grid>
                    
                    <!-- Images content -->
                    <ScrollViewer Grid.Row="1" Padding="40,24" VerticalScrollBarVisibility="Auto">
                        <StackPanel Spacing="32" MaxWidth="1000" HorizontalAlignment="Center">
                            <!-- FlipView for full-size viewing -->
                            <Border CornerRadius="12" Background="Transparent" Height="520">
                                <FlipView x:Name="GalleryViewerFlipView" HorizontalAlignment="Stretch" VerticalAlignment="Stretch" SelectionChanged="GalleryViewerFlipView_SelectionChanged">
                                    <FlipView.ItemTemplate>
                                        <DataTemplate x:DataType="x:String">
                                            <Image Source="{Binding}" Stretch="Uniform" HorizontalAlignment="Center" VerticalAlignment="Center" />
                                        </DataTemplate>
                                    </FlipView.ItemTemplate>
                                </FlipView>
                            </Border>

                            <!-- Thumbnail strip Dock -->
                            <Border Background="#12FFFFFF" BorderBrush="#1AFFFFFF" BorderThickness="1" CornerRadius="16" Padding="16,10" HorizontalAlignment="Center">
                                <GridView x:Name="GalleryViewerGridView" SelectionMode="Single" SelectionChanged="GalleryViewerGridView_SelectionChanged" HorizontalAlignment="Center" Padding="0" Margin="0">
                                    <GridView.ItemContainerStyle>
                                        <Style TargetType="GridViewItem">
                                            <Setter Property="Margin" Value="4" />
                                            <Setter Property="Padding" Value="0" />
                                            <Setter Property="CornerRadius" Value="8" />
                                            <Setter Property="MinWidth" Value="80" />
                                            <Setter Property="MinHeight" Value="80" />
                                        </Style>
                                    </GridView.ItemContainerStyle>
                                    <GridView.ItemTemplate>
                                        <DataTemplate x:DataType="x:String">
                                            <Border CornerRadius="8" Width="80" Height="80" BorderThickness="1" BorderBrush="#1CFFFFFF" Background="#20000000">
                                                <Image Source="{Binding}" Stretch="UniformToFill" HorizontalAlignment="Center" VerticalAlignment="Center" />
                                            </Border>
                                        </DataTemplate>
                                    </GridView.ItemTemplate>
                                </GridView>
                            </Border>
                        </StackPanel>
                    </ScrollViewer>
                </Grid>
            </Grid>
        </Grid>
    </NavigationView>

        <!-- Edit Category Dialog (Placed in visual tree to fix WinUI 3 overlay bugs) -->
        <ContentDialog x:Name="EditCategoryDialog" Title="Edit Category" PrimaryButtonText="Save" CloseButtonText="Cancel" DefaultButton="Primary">
            <StackPanel Spacing="12" Width="280">
                <TextBlock Text="Select Icon" FontSize="12" Foreground="{ThemeResource TextFillColorSecondaryBrush}" />
                <GridView x:Name="EditIconSelectionGridView" SelectionMode="Single" Height="100" Padding="4" Background="{ThemeResource CardBackgroundFillColorDefaultBrush}" BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}" BorderThickness="1" CornerRadius="4">
                    <GridView.ItemTemplate>
                        <DataTemplate x:DataType="local:IconOption">
                            <FontIcon Glyph="{x:Bind Glyph}" FontFamily="{ThemeResource SymbolThemeFontFamily}" FontSize="18" Margin="8" ToolTipService.ToolTip="{x:Bind Name}" />
                        </DataTemplate>
                    </GridView.ItemTemplate>
                </GridView>

                <TextBlock Text="Select Color" FontSize="12" Foreground="{ThemeResource TextFillColorSecondaryBrush}" />
                <GridView x:Name="EditColorSelectionGridView" SelectionMode="Single" Height="70" Padding="4" Background="{ThemeResource CardBackgroundFillColorDefaultBrush}" BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}" BorderThickness="1" CornerRadius="4">
                    <GridView.ItemTemplate>
                        <DataTemplate x:DataType="local:ColorOption">
                            <Ellipse Width="20" Height="20" Fill="{x:Bind Hex, Converter={StaticResource HexToBrushConverter}}" Margin="6" ToolTipService.ToolTip="{x:Bind Name}" />
                        </DataTemplate>
                    </GridView.ItemTemplate>
                </GridView>
            </StackPanel>
        </ContentDialog>

        <!-- New Category Dialog (Placed in visual tree to fix WinUI 3 overlay bugs) -->
        <ContentDialog x:Name="NewCategoryDialog" Title="Create Category" PrimaryButtonText="Create" CloseButtonText="Cancel" DefaultButton="Primary">
            <StackPanel Spacing="12" Width="280">
                <TextBox x:Name="NewCategoryTextBox" PlaceholderText="Category Name" Header="Name" />
                
                <TextBlock Text="Select Icon" FontSize="12" Foreground="{ThemeResource TextFillColorSecondaryBrush}" />
                <GridView x:Name="IconSelectionGridView" SelectionMode="Single" Height="100" Padding="4" Background="{ThemeResource CardBackgroundFillColorDefaultBrush}" BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}" BorderThickness="1" CornerRadius="4">
                    <GridView.ItemTemplate>
                        <DataTemplate x:DataType="local:IconOption">
                            <FontIcon Glyph="{x:Bind Glyph}" FontFamily="{ThemeResource SymbolThemeFontFamily}" FontSize="18" Margin="8" ToolTipService.ToolTip="{x:Bind Name}" />
                        </DataTemplate>
                    </GridView.ItemTemplate>
                </GridView>

                <TextBlock Text="Select Color" FontSize="12" Foreground="{ThemeResource TextFillColorSecondaryBrush}" />
                <GridView x:Name="ColorSelectionGridView" SelectionMode="Single" Height="70" Padding="4" Background="{ThemeResource CardBackgroundFillColorDefaultBrush}" BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}" BorderThickness="1" CornerRadius="4">
                    <GridView.ItemTemplate>
                        <DataTemplate x:DataType="local:ColorOption">
                            <Ellipse Width="20" Height="20" Fill="{x:Bind Hex, Converter={StaticResource HexToBrushConverter}}" Margin="6" ToolTipService.ToolTip="{x:Bind Name}" />
                        </DataTemplate>
                    </GridView.ItemTemplate>
                </GridView>
            </StackPanel>
        </ContentDialog>

        <!-- Unsplash Search ContentDialog (Placed in visual tree to fix WinUI 3 overlay bugs) -->
        <ContentDialog x:Name="UnsplashSearchDialog" 
                       Title="Search Unsplash Banners"
                       PrimaryButtonText="Close"
                       DefaultButton="Primary">
            <ContentDialog.Resources>
                <Style x:Key="UnsplashImageCardStyle" TargetType="GridViewItem">
                    <Setter Property="Margin" Value="6" />
                    <Setter Property="Padding" Value="0" />
                </Style>
            </ContentDialog.Resources>
            
            <Grid Width="500" Height="400" RowSpacing="12">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="*" />
                </Grid.RowDefinitions>
                
                <Grid Grid.Row="0" ColumnSpacing="8">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="Auto" />
                    </Grid.ColumnDefinitions>
                    <TextBox x:Name="UnsplashSearchTextBox" PlaceholderText="Type search keywords (e.g. mountains, workspace)..." KeyDown="UnsplashSearchTextBox_KeyDown" Grid.Column="0" />
                    <Button x:Name="UnsplashSearchButton" Click="UnsplashSearchButton_Click" Grid.Column="1" Width="36" Height="32" Padding="0">
                        <Button.Content>
                            <FontIcon Glyph="&#xE721;" FontFamily="{ThemeResource SymbolThemeFontFamily}" FontSize="14" />
                        </Button.Content>
                    </Button>
                </Grid>
                
                <StackPanel Grid.Row="1" HorizontalAlignment="Center" VerticalAlignment="Center">
                    <ProgressRing x:Name="UnsplashProgressRing" IsActive="False" Visibility="Collapsed" Width="32" Height="32" Margin="0,6" />
                    <TextBlock x:Name="UnsplashErrorTextBlock" Foreground="Red" FontSize="12" HorizontalAlignment="Center" TextAlignment="Center" Visibility="Collapsed" TextWrapping="Wrap" MaxWidth="400" Margin="0,6" />
                </StackPanel>
                
                <ScrollViewer Grid.Row="2" VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Disabled">
                    <GridView x:Name="UnsplashResultsGridView" 
                               SelectionMode="None" 
                               ItemContainerStyle="{StaticResource UnsplashImageCardStyle}" 
                               IsItemClickEnabled="True" 
                               ItemClick="UnsplashResultsGridView_ItemClick">
                        <GridView.ItemTemplate>
                            <DataTemplate>
                                <Grid Width="144" Height="96" CornerRadius="8" BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}" BorderThickness="1" Background="{ThemeResource CardBackgroundFillColorDefaultBrush}">
                                    <Image Source="{Binding ThumbUrl}" Stretch="UniformToFill" HorizontalAlignment="Center" VerticalAlignment="Center" />
                                    <Border VerticalAlignment="Bottom" Height="24" Background="#AA000000" CornerRadius="0,0,8,8">
                                        <TextBlock Text="{Binding Photographer}" Foreground="White" FontSize="9" FontWeight="Medium" VerticalAlignment="Center" HorizontalAlignment="Left" Margin="8,0" TextTrimming="CharacterEllipsis" />
                                    </Border>
                                </Grid>
                            </DataTemplate>
                        </GridView.ItemTemplate>
                    </GridView>
                </ScrollViewer>
            </Grid>
        </ContentDialog>
        <!-- App Lock Overlay Screen -->
        <Grid x:Name="AppLockOverlay"
              Visibility="Collapsed"
              Background="{ThemeResource SolidBackgroundFillColorBaseAltBrush}">
            <Grid.Transitions>
                <TransitionCollection>
                    <EntranceThemeTransition FromHorizontalOffset="0" FromVerticalOffset="24" />
                </TransitionCollection>
            </Grid.Transitions>
            <StackPanel HorizontalAlignment="Center" VerticalAlignment="Center" Spacing="24" Width="360">
                <Border Background="{ThemeResource CardBackgroundFillColorDefaultBrush}"
                        BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}"
                        BorderThickness="1"
                        CornerRadius="12"
                        Padding="28"
                        Shadow="{StaticResource SharedShadow}">
                    <StackPanel Spacing="16">
                        <!-- Icon -->
                        <FontIcon x:Name="AppLockIcon" Glyph="&#xE72E;" FontSize="44" Foreground="{ThemeResource AccentFillColorDefaultBrush}" />
                        
                        <TextBlock Text="Journal Locked" FontSize="20" FontWeight="SemiBold" HorizontalAlignment="Center" />
                        <TextBlock Text="Please authenticate to access your personal journal entries." 
                                   HorizontalAlignment="Center" 
                                   TextAlignment="Center" 
                                   TextWrapping="Wrap" 
                                   FontSize="13" 
                                   Foreground="{ThemeResource TextFillColorSecondaryBrush}" />
                        
                        <!-- Windows Hello Button -->
                        <Button x:Name="WindowsHelloButton"
                                HorizontalAlignment="Stretch"
                                Height="40"
                                Margin="0,8,0,0"
                                Style="{ThemeResource AccentButtonStyle}"
                                Click="WindowsHelloButton_Click"
                                Visibility="Collapsed">
                            <StackPanel Orientation="Horizontal" Spacing="8">
                                <FontIcon Glyph="&#xE785;" FontFamily="{ThemeResource SymbolThemeFontFamily}" FontSize="16" />
                                <TextBlock Text="Sign in with Windows Hello" />
                            </StackPanel>
                        </Button>

                        <!-- Password input section -->
                        <StackPanel x:Name="AppLockPasswordSection" Spacing="8" Margin="0,8,0,0">
                            <PasswordBox x:Name="AppLockPasswordBox" 
                                         PlaceholderText="Enter Master Password" 
                                         PasswordRevealMode="Hidden"
                                         Height="38"
                                         KeyDown="AppLockPasswordBox_KeyDown"/>
                            <Button Content="Unlock" 
                                    HorizontalAlignment="Stretch" 
                                    Height="38" 
                                    Click="UnlockWithPassword_Click"/>
                        </StackPanel>

                        <!-- Status text -->
                        <TextBlock x:Name="AppLockStatusText" 
                                   Foreground="#FF3B30" 
                                   FontSize="12" 
                                   HorizontalAlignment="Center" 
                                   TextAlignment="Center"
                                   TextWrapping="Wrap" 
                                   Visibility="Collapsed" />
                    </StackPanel>
                </Border>
            </StackPanel>
        </Grid>
    </Grid>
</Page>
