<Page
    x:Class="MarkdownEditor.MarkdownEditorPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:local="using:MarkdownEditor.Controls"
    Background="#1A1A24">

    <Grid RowDefinitions="Auto,*">

        <!-- ── Toolbar ────────────────────────────────────────────────────── -->
        <Grid Grid.Row="0" Background="#12121C" Padding="12,6">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="Auto"/>
            </Grid.ColumnDefinitions>

            <!-- File name -->
            <TextBlock x:Name="FileNameText"
                       Text="Untitled.md"
                       Foreground="#888899"
                       FontFamily="Segoe UI Variable Text"
                       FontSize="13"
                       VerticalAlignment="Center"
                       Margin="8,0,0,0"/>

            <!-- Toolbar buttons -->
            <StackPanel Grid.Column="1" Orientation="Horizontal" Spacing="2">

                <Button x:Name="BoldButton" Click="BoldButton_Click"
                        Style="{StaticResource DateTimePickerFlyoutButtonStyle}"
                        ToolTipService.ToolTip="Bold (Ctrl+B)"
                        Padding="10,6">
                    <TextBlock Text="B" FontWeight="Bold" Foreground="#DCDCE8" FontSize="14"/>
                </Button>

                <Button x:Name="ItalicButton" Click="ItalicButton_Click"
                        Style="{StaticResource DateTimePickerFlyoutButtonStyle}"
                        ToolTipService.ToolTip="Italic (Ctrl+I)"
                        Padding="10,6">
                    <TextBlock Text="I" FontStyle="Italic" Foreground="#DCDCE8" FontSize="14"/>
                </Button>

                <Button x:Name="CodeButton" Click="CodeButton_Click"
                        Style="{StaticResource DateTimePickerFlyoutButtonStyle}"
                        ToolTipService.ToolTip="Inline Code"
                        Padding="10,6">
                    <TextBlock Text="&lt;/&gt;" FontFamily="Cascadia Code"
                               Foreground="#FF79C6" FontSize="12"/>
                </Button>

                <Rectangle Width="1" Fill="#333344" Margin="4,4"/>

                <Button x:Name="H1Button" Click="H1Button_Click"
                        Style="{StaticResource DateTimePickerFlyoutButtonStyle}"
                        ToolTipService.ToolTip="Heading 1"
                        Padding="10,6">
                    <TextBlock Text="H1" Foreground="#5A8CFF" FontSize="13" FontWeight="Bold"/>
                </Button>

                <Button x:Name="H2Button" Click="H2Button_Click"
                        Style="{StaticResource DateTimePickerFlyoutButtonStyle}"
                        ToolTipService.ToolTip="Heading 2"
                        Padding="10,6">
                    <TextBlock Text="H2" Foreground="#5A8CFF" FontSize="13"/>
                </Button>

                <Button x:Name="H3Button" Click="H3Button_Click"
                        Style="{StaticResource DateTimePickerFlyoutButtonStyle}"
                        ToolTipService.ToolTip="Heading 3"
                        Padding="10,6">
                    <TextBlock Text="H3" Foreground="#5A8CFF" FontSize="12"/>
                </Button>

                <Rectangle Width="1" Fill="#333344" Margin="4,4"/>

                <Button x:Name="BulletButton" Click="BulletButton_Click"
                        Style="{StaticResource DateTimePickerFlyoutButtonStyle}"
                        ToolTipService.ToolTip="Bullet List"
                        Padding="10,6">
                    <FontIcon Glyph="&#xE8FD;" FontSize="14" Foreground="#DCDCE8"/>
                </Button>

                <Button x:Name="NumberButton" Click="NumberButton_Click"
                        Style="{StaticResource DateTimePickerFlyoutButtonStyle}"
                        ToolTipService.ToolTip="Numbered List"
                        Padding="10,6">
                    <FontIcon Glyph="&#xE9D5;" FontSize="14" Foreground="#DCDCE8"/>
                </Button>

                <Rectangle Width="1" Fill="#333344" Margin="4,4"/>

                <Button x:Name="NewButton" Click="NewButton_Click"
                        Style="{StaticResource DateTimePickerFlyoutButtonStyle}"
                        ToolTipService.ToolTip="New (Ctrl+N)"
                        Padding="10,6">
                    <FontIcon Glyph="&#xE8A5;" FontSize="14" Foreground="#DCDCE8"/>
                </Button>

                <Button x:Name="OpenButton" Click="OpenButton_Click"
                        Style="{StaticResource DateTimePickerFlyoutButtonStyle}"
                        ToolTipService.ToolTip="Open (Ctrl+O)"
                        Padding="10,6">
                    <FontIcon Glyph="&#xE8E5;" FontSize="14" Foreground="#DCDCE8"/>
                </Button>

                <Button x:Name="SaveButton" Click="SaveButton_Click"
                        Style="{StaticResource DateTimePickerFlyoutButtonStyle}"
                        ToolTipService.ToolTip="Save (Ctrl+S)"
                        Padding="10,6">
                    <FontIcon Glyph="&#xE74E;" FontSize="14" Foreground="#DCDCE8"/>
                </Button>

            </StackPanel>
        </Grid>

        <!-- ── Editor — centred column like Obsidian ─────────────────────── -->
        <Grid Grid.Row="1">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="720" MaxWidth="860"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>

            <local:MarkdownEditorBox
                x:Name="Editor"
                Grid.Column="1"
                VerticalAlignment="Stretch"/>
        </Grid>

    </Grid>
</Page>
