<?xml version="1.0" encoding="utf-8"?>
<Window
    x:Class="JournalApp.CoverRepositionWindow"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    mc:Ignorable="d"
    Title="Reposition Cover Image">

    <Grid RequestedTheme="Dark" Background="#1A1A1A">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- Header -->
        <StackPanel Grid.Row="0" HorizontalAlignment="Center" Margin="0,28,0,18" Spacing="5">
            <TextBlock Text="Reposition Cover Image"
                       FontSize="18" FontWeight="SemiBold"
                       Foreground="White" HorizontalAlignment="Center"/>
            <TextBlock Text="Drag the image to choose which area appears in the cover banner"
                       FontSize="12" Foreground="#99FFFFFF" HorizontalAlignment="Center"/>
        </StackPanel>

        <!-- Main canvas area (dark background, image + fixed crop frame) -->
        <Grid Grid.Row="1" x:Name="CanvasContainer"
              HorizontalAlignment="Stretch" VerticalAlignment="Stretch"
              Background="#0D0D0D"
              SizeChanged="CanvasContainer_SizeChanged">
            <Canvas x:Name="MainCanvas">

                <!-- Draggable image -->
                <Image x:Name="RepoImage"
                       Stretch="Fill"
                       Canvas.Left="0" Canvas.Top="0"
                       PointerPressed="RepoImage_PointerPressed"
                       PointerMoved="RepoImage_PointerMoved"
                       PointerReleased="RepoImage_PointerReleased"
                       PointerCanceled="RepoImage_PointerReleased"/>

                <!-- Dim overlays — 4 rects outside the fixed crop frame -->
                <Rectangle x:Name="DimTop"    Fill="#BB000000" IsHitTestVisible="False"/>
                <Rectangle x:Name="DimBottom" Fill="#BB000000" IsHitTestVisible="False"/>
                <Rectangle x:Name="DimLeft"   Fill="#BB000000" IsHitTestVisible="False"/>
                <Rectangle x:Name="DimRight"  Fill="#BB000000" IsHitTestVisible="False"/>

                <!-- Fixed crop frame (does NOT move) -->
                <Grid x:Name="CropFrameGrid" IsHitTestVisible="False" Canvas.Left="0" Canvas.Top="0">
                    <!-- White border -->
                    <Border BorderBrush="White" BorderThickness="2" Background="Transparent"/>

                    <!-- Rule-of-thirds grid lines -->
                    <Grid Margin="2">
                        <Grid.RowDefinitions>
                            <RowDefinition Height="*"/>
                            <RowDefinition Height="*"/>
                            <RowDefinition Height="*"/>
                        </Grid.RowDefinitions>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>
                        <Border Grid.Row="0" Grid.Column="1" BorderThickness="0.5,0,0.5,0" BorderBrush="#40FFFFFF"/>
                        <Border Grid.Row="1" Grid.Column="0" Grid.ColumnSpan="3" BorderThickness="0,0.5,0,0.5" BorderBrush="#40FFFFFF"/>
                        <Border Grid.Row="2" Grid.Column="1" BorderThickness="0.5,0,0.5,0" BorderBrush="#40FFFFFF"/>
                    </Grid>

                    <!-- Corner handles -->
                    <Border Width="14" Height="14" Background="White" CornerRadius="2"
                            HorizontalAlignment="Left"  VerticalAlignment="Top"    Margin="-1,-1,0,0"/>
                    <Border Width="14" Height="14" Background="White" CornerRadius="2"
                            HorizontalAlignment="Right" VerticalAlignment="Top"    Margin="0,-1,-1,0"/>
                    <Border Width="14" Height="14" Background="White" CornerRadius="2"
                            HorizontalAlignment="Left"  VerticalAlignment="Bottom" Margin="-1,0,0,-1"/>
                    <Border Width="14" Height="14" Background="White" CornerRadius="2"
                            HorizontalAlignment="Right" VerticalAlignment="Bottom" Margin="0,0,-1,-1"/>

                    <!-- Edge midpoint handles -->
                    <Border Width="22" Height="8"  Background="White" CornerRadius="2"
                            HorizontalAlignment="Center" VerticalAlignment="Top"    Margin="0,-1,0,0"/>
                    <Border Width="22" Height="8"  Background="White" CornerRadius="2"
                            HorizontalAlignment="Center" VerticalAlignment="Bottom" Margin="0,0,0,-1"/>
                    <Border Width="8"  Height="22" Background="White" CornerRadius="2"
                            HorizontalAlignment="Left"   VerticalAlignment="Center" Margin="-1,0,0,0"/>
                    <Border Width="8"  Height="22" Background="White" CornerRadius="2"
                            HorizontalAlignment="Right"  VerticalAlignment="Center" Margin="0,0,-1,0"/>
                </Grid>

            </Canvas>
        </Grid>

        <!-- Bottom action bar -->
        <StackPanel Grid.Row="2" Orientation="Horizontal"
                    HorizontalAlignment="Center" Spacing="12" Margin="0,18,0,28">
            <Button x:Name="DoneButton" Click="DoneButton_Click"
                    CornerRadius="8" Padding="28,10"
                    Background="#0078D4" Foreground="White"
                    BorderThickness="0">
                <StackPanel Orientation="Horizontal" Spacing="8">
                    <FontIcon Glyph="&#xE73E;"
                              FontFamily="Segoe MDL2 Assets" FontSize="14"
                              Foreground="White"/>
                    <TextBlock Text="Done" FontWeight="SemiBold" Foreground="White"/>
                </StackPanel>
            </Button>
            <Button x:Name="CancelButton" Click="CancelButton_Click"
                    CornerRadius="8" Padding="28,10" Content="Cancel"/>
        </StackPanel>
    </Grid>
</Window>
